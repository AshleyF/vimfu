{
  "title": "VimFu — survival.open-save-quit (example screenshots)",
  "description": "Lesson used by content/examples/survival.open-save-quit.json to capture authentic Vim frames. Not intended for video.",
  "speed": 1.0,
  "humanize": 0,
  "rows": 10,
  "cols": 40,
  "ttsEnabled": false,
  "recordVideo": false,
  "clickKeys": false,
  "captureDedup": false,
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f hello.txt .hello.txt.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "hello.txt",
      "content": "greetings\nfrom vi\n",
      "noDedent": true
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim hello.txt"
    },
    {
      "waitForScreen": "hello.txt",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    },
    {
      "keys": "gg1j0"
    },
    {
      "keys": "A"
    },
    {
      "type": "m"
    },
    "escape"
  ],
  "steps": [
    {
      "ex": "w"
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f hello.txt"
    }
  ]
}