{
  "title": "VimFu — textobj.tags (example screenshots)",
  "description": "Lesson used by content/examples/textobj.tags.json to capture authentic Vim frames. Not intended for video.",
  "speed": 1.0,
  "humanize": 0,
  "rows": 10,
  "cols": 40,
  "ttsEnabled": false,
  "recordVideo": false,
  "clickKeys": false,
  "captureDedup": false,
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f practice.html .practice.html.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "practice.html",
      "content": "<p>hello world</p>\n",
      "noDedent": true
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim practice.html"
    },
    {
      "waitForScreen": "practice.html",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    },
    {
      "keys": "gg05l"
    }
  ],
  "steps": [
    {
      "keys": "cit"
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f practice.html"
    }
  ]
}