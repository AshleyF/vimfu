{
  "title": "VimFu — editing.yank-put (example screenshots)",
  "description": "Lesson used by content/examples/editing.yank-put.json to capture authentic Vim frames. Not intended for video.",
  "speed": 1.0,
  "humanize": 0,
  "rows": 10,
  "cols": 40,
  "ttsEnabled": false,
  "recordVideo": false,
  "clickKeys": false,
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f list.txt .list.txt.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "list.txt",
      "content": "alpha\nbravo\ncharlie\n",
      "noDedent": true
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim -c 'set report=0' list.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    },
    {
      "keys": "gg1j0"
    }
  ],
  "steps": [
    {
      "keys": "yy"
    },
    {
      "keys": "p"
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f list.txt"
    }
  ]
}