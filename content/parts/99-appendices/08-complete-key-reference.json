    },
    {
      "type": "table",
      "headers": [
        "Key",
        "Function"
      ],
      "rows": [
        [
          "a",
          "Append after cursor"
        ],
        [
          "b",
          "Word back"
        ],
        [
          "c",
          "Change operator"
        ],
        [
          "d",
          "Delete operator"
        ],
        [
          "e",
          "End of word"
