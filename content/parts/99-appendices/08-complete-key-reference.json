        [
          "{key:Ctrl-Q}",
          "Block visual on terminals where Ctrl-V is paste"
        ],
        [
          "{key:Ctrl-R}",
          "Redo (or paste-register in Insert/cmdline)"
        ],
        [
          "{key:Ctrl-T}",
          "Pop tag stack"
        ],
        [
          "{key:Ctrl-U}",
          "Half-page up"
        ],
        [
          "{key:Ctrl-V}",
          "Block visual"
        ],
        [
          "{key:Ctrl-W}",
          "Window prefix"
        ],
        [
          "{key:Ctrl-X}",
          "Decrement number"
        ],
        [
          "{key:Ctrl-Y}",
          "Scroll line up"
        ],
        [
          "{key:Ctrl-Z}",
          "Suspend Vim (resume with `fg`)"
        ],
        [
          "{key:Ctrl-]}",
          "Jump to tag under cursor"
        ],
        [
          "{key:Ctrl-^}",
          "Switch to alternate file"
        ],
        [
          "{key:Ctrl-\\\\}",
          "Reserved prefix (e.g. Ctrl-\\\\ {key:Ctrl-N} to force Normal)"
