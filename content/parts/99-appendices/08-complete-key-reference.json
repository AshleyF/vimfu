        [
          "%",
          "Match bracket / go to N% / file size"
        ],
        [
          "*, #",
          "Search word forward / back"
        ],
        [
          "/, ?",
          "Search forward / back"
        ],
        [
          ".",
          "Repeat last change"
        ],
        [
          ",",
          "Reverse last f/F/t/T"
        ],
        [
          ";",
          "Repeat last f/F/t/T"
        ],
        [
          "~",
          "Toggle case of char under cursor"
        ],
        [
          "&",
          "Repeat last `:s` on current line"
        ],
        [
          "@",
          "Run macro from register"
        ],
        [
          ":",
          "Enter Ex command line"
        ],
        [
          "!",
          "Filter operator"
        ],
        [
          "|",
          "Go to column [count]"
