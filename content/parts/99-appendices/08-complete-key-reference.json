        [
          "{, }",
          "Previous / next paragraph"
        ],
        [
          "(, )",
          "Previous / next sentence"
        ],
        [
          "[, ]",
          "Backward / forward bracket prefixes"
        ],
        [
          "<, >",
          "Outdent / indent operators"
        ],
        [
          "=",
          "Reindent operator"
        ],
        [
          "'",
          "Jump to mark (line)"
        ],
        [
          "`",
          "Jump to mark (exact position)"
        ],
        [
          "\"",
          "Register prefix"
        ]
      ]
