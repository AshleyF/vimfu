  "id": "prefixes.ctrl-w",
  "title": "The {key:Ctrl-W} Family",
  "subtitle": "30+ window commands hide behind the {key:Ctrl-W} prefix.",
  "part": "prefixes",
  "summary": "{key:Ctrl-W} is the window prefix: navigate (h/j/k/l), close (c, o), split (s, v), move (H/J/K/L), resize (+/-/</>/=), and more.",
