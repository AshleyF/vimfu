  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "The {key:Ctrl-W} Family"
    },
    {
      "type": "prose",
      "text": "You've been using the {key:Ctrl-W} family since Part 14 — splitting, navigating, moving, and resizing windows. This chapter is the full map of the prefix: every chord in one place, organized by what it does. {key:Ctrl-W} is the window prefix. Everything window-related lives behind it. Like the {key:[} family, it's symmetric in places — capital direction = move, lowercase = navigate."
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Navigation"
    },
    {
      "type": "table",
      "headers": [
        "Key",
        "Action"
      ],
      "rows": [
        [
          "{key:Ctrl-W}{key:h/j/k/l}",
          "Move to window in direction"
        ],
        [
          "{key:Ctrl-W}{key:w}",
          "Cycle to next window"
        ],
        [
          "{key:Ctrl-W}{key:W}",
          "Cycle to previous window"
        ],
        [
          "{key:Ctrl-W}{key:p}",
          "Switch to previous window"
        ],
        [
          "{key:Ctrl-W}{key:t}",
          "Top-most window"
        ],
        [
          "{key:Ctrl-W}{key:b}",
          "Bottom-most window"
        ]
      ]
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Splitting"
    },
    {
      "type": "table",
      "headers": [
        "Key",
        "Action"
      ],
      "rows": [
        [
          "{key:Ctrl-W}{key:s}",
          "Horizontal split (same buffer)"
        ],
        [
          "{key:Ctrl-W}{key:v}",
          "Vertical split (same buffer)"
        ],
        [
          "{key:Ctrl-W}{key:n}",
          "New empty horizontal split"
        ],
        [
          "{key:Ctrl-W}{key:^}",
          "Split with alternate buffer"
        ],
        [
          "{key:Ctrl-W}{key:f}",
          "Split and edit file under cursor"
        ],
        [
          "{key:Ctrl-W}{key:g}{key:f}",
          "Open file under cursor in new tab"
        ]
      ]
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Closing"
    },
    {
      "type": "table",
      "headers": [
        "Key",
        "Action"
      ],
      "rows": [
        [
          "{key:Ctrl-W}{key:c}",
          "Close current window"
        ],
        [
          "{key:Ctrl-W}{key:q}",
          "Quit (close window or Vim)"
        ],
        [
          "{key:Ctrl-W}{key:o}",
          "Close all but current"
        ]
      ]
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Move and resize"
    },
    {
      "type": "table",
      "headers": [
        "Key",
        "Action"
      ],
      "rows": [
        [
          "{key:Ctrl-W}{key:H/J/K/L}",
          "Move window to far left/bottom/top/right"
        ],
        [
          "{key:Ctrl-W}{key:r} / {key:Ctrl-W}{key:R}",
          "Rotate windows down / up"
        ],
        [
          "{key:Ctrl-W}{key:x}",
          "Exchange with next window"
        ],
        [
          "{key:Ctrl-W}{key:+} / {key:Ctrl-W}{key:-}",
          "Increase / decrease height"
        ],
        [
          "{key:Ctrl-W}{key:>} / {key:Ctrl-W}{key:<}",
          "Increase / decrease width"
        ],
        [
          "{key:Ctrl-W}{key:_}",
          "Maximize height"
        ],
        [
          "{key:Ctrl-W}{key:|}",
          "Maximize width"
        ],
        [
          "{key:Ctrl-W}{key:=}",
          "Equalize all"
