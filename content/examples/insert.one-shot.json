{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "insert.one-shot",
  "title": "{key:Ctrl-O} in *insert mode*",
  "summary": "One *normal mode* command without leaving *insert mode*.",
  "topic": "insert.one-shot-normal",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "hello world",
          "-- INSERT --                            "
        ],
        "cursor": [
          0,
          5
        ]
      }
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "hello world",
          "-- INSERT --                            "
        ],
        "cursor": [
          0,
          11
        ]
      },
      "caption": "{key:Ctrl-O}{key:$} \u2014 jumped to EOL, still in *insert mode.*",
      "keys": "Ctrl-O $"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "hello world!",
          "-- INSERT --                            "
        ],
        "cursor": [
          0,
          11
        ]
      },
      "caption": "Type {key:!} \u2014 *insert mode* resumes seamlessly.",
      "keys": "!"
    }
  ]
}