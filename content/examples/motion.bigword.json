{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "motion.bigword",
  "title": "W vs w",
  "summary": "WORD motions ignore punctuation as separators.",
  "topic": "wider-motions.WORD",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "foo.bar baz"
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "Cursor on 'f'."
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "foo.bar baz"
        ],
        "cursor": [
          0,
          3
        ]
      },
      "caption": "w \u2014 stopped at '.'.",
      "narration": "Lower-case w treats '.' as a word boundary.",
      "keys": "w"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "foo.bar baz"
        ],
        "cursor": [
          0,
          8
        ]
      },
      "caption": "W \u2014 skipped to 'baz'.",
      "narration": "Upper-case W treats whitespace-separated chunks as one WORD.",
      "keys": "0W"
    }
  ]
}