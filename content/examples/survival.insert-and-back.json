{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "survival.insert-and-back",
  "title": "i and Esc",
  "summary": "Enter Insert with i; leave with Esc.",
  "topic": "survival.insert-and-back",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "foo"
        ],
        "cursor": [
          0,
          0
        ]
      }
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "foo",
          "-- INSERT --                            "
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "Insert mode begins.",
      "keys": "i"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "barfoo",
          "-- INSERT --                            "
        ],
        "cursor": [
          0,
          2
        ]
      },
      "caption": "Three letters typed.",
      "keys": "bar"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "barfoo"
        ],
        "cursor": [
          0,
          2
        ]
      },
      "caption": "Esc \u2014 back to Normal.",
      "narration": "Insert mode is for typing characters; Normal mode is for everything else.",
      "keys": "Esc"
    }
  ]
}