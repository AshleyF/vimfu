{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "survival.insert-and-back",
  "title": "{key:i} and {key:Esc}",
  "summary": "Enter *insert mode* with {key:i}; leave with {key:Esc}.",
  "topic": "survival.insert-and-back",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "foo"
        ],
        "cursor": [
          0,
          0
        ]
      }
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "foo",
          "-- INSERT --                            "
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "{key:i} \u2014 *insert mode* begins.",
      "keys": "i"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "barfoo",
          "-- INSERT --                            "
        ],
        "cursor": [
          0,
          2
        ]
      },
      "caption": "Three letters typed.",
      "keys": "bar"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "barfoo"
        ],
        "cursor": [
          0,
          2
        ]
      },
      "caption": "{key:Esc} \u2014 back to *normal mode.*",
      "narration": "*Insert mode* is for typing characters; *normal mode* is for everything else.",
      "keys": "Esc"
    }
  ]
}