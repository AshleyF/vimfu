{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "registers.numbered",
  "title": "\"1p and \"2p",
  "summary": "Walk back through deletion history.",
  "topic": "registers.numbered",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "A",
          "B",
          "C"
        ],
        "cursor": [
          0,
          0
        ]
      }
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "B",
          "C"
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "{key:d}{key:d} \u2014 A goes to `\"1`.",
      "keys": "dd"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "C"
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "{key:d}{key:d} \u2014 B goes to `\"1`, A pushed to `\"2`.",
      "keys": "dd"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "C",
          "B"
        ],
        "cursor": [
          1,
          0
        ]
      },
      "caption": "{key:\"}{key:1}{key:p} \u2014 most recent (B) back.",
      "keys": "\"1p"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "C",
          "B",
          "A"
        ],
        "cursor": [
          2,
          0
        ]
      },
      "caption": "{key:\"}{key:2}{key:p} \u2014 older one (A) back.",
      "narration": "`\"1`-`\"9` hold the last 9 line-deletes. They shift each time you delete.",
      "keys": "\"3p"
    }
  ]
}