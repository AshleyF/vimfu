{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "pattern.block-comment",
  "title": "{key:Ctrl-V} {key:j}{key:j}{key:j} {key:I}{key:/}{key:/}{key:Esc}",
  "summary": "Block-prefix many lines at once.",
  "topic": "patterns.block-comment",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "x = 1",
          "y = 2",
          "z = 3"
        ],
        "cursor": [
          0,
          0
        ]
      }
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "x = 1",
          "y = 2",
          "z = 3",
          "-- VISUAL BLOCK --                      "
        ],
        "cursor": [
          2,
          0
        ],
        "highlights": [
          {
            "row": 0,
            "col": 0,
            "len": 1,
            "bg": "666666"
          },
          {
            "row": 1,
            "col": 0,
            "len": 1,
            "bg": "666666"
          },
          {
            "row": 2,
            "col": 0,
            "len": 1,
            "bg": "666666"
          }
        ]
      },
      "caption": "{key:Ctrl-V}{key:j}{key:j} \u2014 three rows selected.",
      "keys": "Ctrl-V jj"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "// x = 1",
          "y = 2",
          "z = 3",
          "-- INSERT --                            "
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "{key:I}// \u2014 typing on the first row only.",
      "keys": "I//"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "// x = 1",
          "// y = 2",
          "// z = 3"
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "{key:Esc} \u2014 Vim replays the insertion on every selected row.",
      "narration": "The trick: in block *insert mode,* the typing only shows on row one until you press {key:Esc}.",
      "keys": "Esc"
    }
  ]
}