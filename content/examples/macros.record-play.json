    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "1. one",
          "two",
          "three",
          "recording @a"
        ],
        "cursor": [
          1,
          0
        ]
      },
      "caption": "Move to next line (recorded).",
      "keys": "j0"
