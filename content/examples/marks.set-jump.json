{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "marks.set-jump",
  "title": "{key:m}{key:a} and {key:'}{key:a}",
  "summary": "Set a mark, jump back later.",
  "topic": "marks.local-global",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "chapter one",
          "...content...",
          "chapter two",
          "..."
        ],
        "cursor": [
          0,
          0
        ]
      }
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "chapter one",
          "...content...",
          "chapter two",
          "..."
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "{key:m}{key:a} \u2014 mark `a` set at this line.",
      "keys": "ma"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "chapter one",
          "...content...",
          "chapter two",
          "..."
        ],
        "cursor": [
          2,
          0
        ]
      },
      "caption": "Wandered to chapter two.",
      "keys": "2j"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "chapter one",
          "...content...",
          "chapter two",
          "..."
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "{key:'}{key:a} \u2014 jumped back to mark `a`.",
      "narration": "Lowercase marks are file-local; uppercase marks are global (jump across files).",
      "keys": "'a"
    }
  ]
