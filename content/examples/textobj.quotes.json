{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "textobj.quotes",
  "title": "ci\" and ca\"",
  "summary": "Operate on whatever is in the quotes.",
  "topic": "text-objects.quotes",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "greeting = \"hello, world\""
        ],
        "cursor": [
          0,
          15
        ]
      },
      "caption": "Cursor inside the string."
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "greeting = \"\"",
          "-- INSERT --                            "
        ],
        "cursor": [
          0,
          12
        ]
      },
      "caption": "ci\" \u2014 string contents gone.",
      "narration": "You don't need to be on a quote \u2014 Vim finds the surrounding pair on the line. Same for ', `, (), [], {}, <>, t (tag).",
      "keys": "ci\""
    }
  ]
