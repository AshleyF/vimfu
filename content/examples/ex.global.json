{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "ex.global",
  "title": "{key::}{key:g}/TODO/{key:d}",
  "summary": "Run an Ex command on every matching line.",
  "topic": "ex.global",
  "lang": "markdown",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "x = 1",
          "# TODO: fix",
          "y = 2",
          "# TODO: again"
        ],
        "cursor": [
          0,
          0
        ]
      }
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "x = 1",
          "y = 2",
          ":g/TODO/d"
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "All TODO lines deleted.",
      "narration": ":g/pat/cmd runs cmd on each matching line. :v/pat/cmd runs on every NON-matching line.",
      "keys": ":g/TODO/d Enter"
    }
  ]
}