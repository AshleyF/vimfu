{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "textobj.brackets",
  "title": "di( vs da(",
  "summary": "Brackets work like quotes.",
  "topic": "operators-textobjects.brackets",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "call(arg1, arg2)"
        ],
        "cursor": [
          0,
          8
        ]
      },
      "caption": "Cursor on 'a' of arg1."
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "call()"
        ],
        "cursor": [
          0,
          5
        ]
      },
      "caption": "di( \u2014 args removed.",
      "keys": "di("
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "call"
        ],
        "cursor": [
          0,
          4
        ]
      },
      "caption": "da( \u2014 parens removed too.",
      "keys": "u da("
    }
  ]
}