{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "motion.match",
  "title": "{key:%} on different brackets",
  "summary": "{key:%} picks the right pair automatically.",
  "topic": "wider-motions.match-bracket",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "arr[i] = (a + b);"
        ],
        "cursor": [
          0,
          3
        ]
      },
      "caption": "Cursor on '['."
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "arr[i] = (a + b);"
        ],
        "cursor": [
          0,
          5
        ]
      },
      "caption": "% \u2014 to ']'.",
      "keys": "%"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "arr[i] = (a + b);"
        ],
        "cursor": [
          0,
          9
        ]
      },
      "caption": "From '(', % goes to ')'.",
      "keys": "ww %"
    }
  ]
}