{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "foundations.modes",
  "title": "Normal -> Insert -> Normal",
  "summary": "The mode transition every editing change goes through.",
  "topic": "foundations.modes-overview",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "Hello world",
          "",
          "~",
          "~",
          "~",
          "~",
          "~",
          "~",
          "hi.txt                   1,7            "
        ],
        "cursor": [
          0,
          6
        ],
        "statusRow": 8
      },
      "caption": "Normal mode. Cursor as a block on the space.",
      "narration": "When you open a file, you start in Normal mode. Keystrokes are commands."
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "Hello, vim world",
          "",
          "~",
          "~",
          "~",
          "~",
          "~",
          "~",
          "hi.txt [+]               1,12           ",
          "-- INSERT --                            "
        ],
        "cursor": [
          0,
          11
        ],
        "highlights": [
          {
            "row": 11,
            "col": 0,
            "len": 12,
            "b": true
          }
        ],
        "statusRow": 8
      },
      "caption": "i then ', vim' \u2014 Insert mode, text added.",
      "narration": "i enters Insert at the cursor; subsequent keys produce text. The status line below advertises the mode.",
      "keys": "i, vim"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "Hello, vim world",
          "",
          "~",
          "~",
          "~",
          "~",
          "~",
          "~",
          "hi.txt [+]               1,11           "
        ],
        "cursor": [
          0,
          10
        ],
        "statusRow": 8
      },
      "caption": "Esc \u2014 back to Normal mode.",
      "narration": "Esc commits the insert and returns to Normal. The whole insertion is one undoable change.",
      "keys": "Esc"
    }
  ]
}