        "cursor": [
          2,
          4
        ],
        "highlights": [
          {
            "row": 0,
            "col": 4,
            "len": 3,
            "bg": "666666"
          },
          {
            "row": 2,
            "col": 4,
            "len": 3,
            "bg": "666666"
          }
        ]
      },
      "caption": "{key:n} — next match.",
