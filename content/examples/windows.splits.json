  "id": "windows.splits",
  "title": ":split and :vsplit",
  "summary": "Two views of one buffer (or two).",
  "topic": "windows.splits",
  "lang": "python",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "main.py",
          "def f():"
        ],
        "cursor": [
          1,
          0
        ]
      }
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "main.py",
          "def f():",
          "    pass",
          "main.py",
          "def f():",
          "Press ENTER to continue"
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": ":sp — horizontal split.",
      "keys": ":sp"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "main.py        |main.py",
          "def f():       |def f():",
          "    pass       |    pass"
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": ":vsp — vertical split.",
      "narration": "Each split is an independent view. Use {key:Ctrl-W} with {key:h}/{key:j}/{key:k}/{key:l} to navigate.",
      "keys": ":vsp"
    }
  ]
