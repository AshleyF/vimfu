        "cursor": [
          0,
          0
        ]
      }
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "xxx bar",
          "foo baz",
          "foo qux"
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "{key:c}{key:w}, type `xxx`, {key:Esc}.",
      "keys": "cw Esc"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "xxx bar",
          "xxx baz",
          "foo qux"
        ],
        "cursor": [
          1,
          0
        ]
      },
      "caption": ". \u2014 same change at new cursor.",
      "narration": "Dot replays the last *change* (anything that modified the buffer). Cheap revolution: structure your motions so dot becomes useful.",
      "keys": "j0 ."
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "xxx bar",
          "xxx baz",
          "xxx qux"
        ],
        "cursor": [
          2,
          0
        ]
      },
      "caption": ". again \u2014 third line.",
      "narration": "Move-and-dot is a Vim idiom. Beats keyboard macros for trivial repetitions.",
      "keys": "j0 ."
    }
  ]
