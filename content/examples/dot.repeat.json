  "id": "dot.repeat",
  "title": ".",
  "summary": "The single most powerful key in Vim.",
  "topic": "dot.repeat",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "foo bar",
          "foo baz",
          "foo qux"
