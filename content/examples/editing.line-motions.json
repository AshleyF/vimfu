{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "editing.line-motions",
  "title": "0 ^ $",
  "summary": "Three flavors of line start/end.",
  "topic": "editing.line-motions",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "    hello world"
        ],
        "cursor": [
          0,
          8
        ]
      }
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "    hello world"
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "0 \u2014 column 0 (literal start).",
      "keys": "0"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "    hello world"
        ],
        "cursor": [
          0,
          4
        ]
      },
      "caption": "^ \u2014 first non-blank.",
      "keys": "^"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "    hello world"
        ],
        "cursor": [
          0,
          14
        ]
      },
      "caption": "$ \u2014 end of line.",
      "narration": "Use ^ when you want code, 0 when you want column zero, $ to land on the last char.",
      "keys": "$"
    }
  ]
}