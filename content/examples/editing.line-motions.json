{
  "format": "vimfu-content-example",
  "version": 1,
  "id": "editing.line-motions",
  "title": "{key:0} {key:^} {key:$}",
  "summary": "Three flavors of line start/end.",
  "topic": "editing.line-motions",
  "frames": [
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "    hello world"
        ],
        "cursor": [
          0,
          8
        ]
      }
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "    hello world"
        ],
        "cursor": [
          0,
          0
        ]
      },
      "caption": "{key:0} \u2014 column 0 (literal start).",
      "keys": "0"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "    hello world"
        ],
        "cursor": [
          0,
          4
        ]
      },
      "caption": "{key:^} \u2014 first non-blank.",
      "keys": "^"
    },
    {
      "compact": {
        "rows": 10,
        "cols": 40,
        "lines": [
          "    hello world"
        ],
        "cursor": [
          0,
          14
        ]
      },
      "caption": "{key:$} \u2014 end of line.",
      "narration": "Use {key:^} when you want code, {key:0} when you want column zero, and {key:$} to land on the last char.",
      "keys": "$"
    }
  ]
}