{
  "title": "VimFu — O — Other Corner (Block)",
  "description": "In blockwise visual mode, capital O moves the cursor to the other end of the current row. Lowercase o jumps diagonally to the opposite corner.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 589,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "visual mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f grid.py .grid.py.swp .grid.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "grid.py",
      "content": "# grid data\nrow1 = [10, 20, 30]\nrow2 = [40, 50, 60]\nrow3 = [70, 80, 90]\nrow4 = [11, 22, 33]"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim grid.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "O — Other Corner",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "In *visual-block mode,* {key:O} flips the cursor horizontally to the other end of the same row. {key:o} jumps diagonally to the opposite corner."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Start with only the middle scores selected, then use the corners to grow the block.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2j012l",
      "overlay": "middle score"
    },
    {
      "keys": "\u0016"
    },
    {
      "keys": "jl",
      "overlay": "small block"
    },
    {
      "wait": 0.4
    },
    {
      "say": "The active corner is bottom right. Press {key:O} to jump to the bottom left, then extend left.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "wait": 0.3
    },
    {
      "keys": "O",
      "overlay": "flip horizontal"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "4h",
      "overlay": "extend left"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Now {key:o} jumps diagonally to the top right. From that corner, extend upward and right.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "o",
      "overlay": "diagonal"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "k4l",
      "overlay": "top and right"
    },
    {
      "wait": 0.5
    },
    {
      "say": "One more diagonal jump puts the cursor at the lower left, so {key:j} can add the last row.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "o",
      "overlay": "diagonal"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": "last row"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Now the block covers every score inside the brackets. {key:O} and {key:o} let you choose which corner grows next."
    },
    {
      "wait": 0.3
    },
    "escape",
    {
      "wait": 0.3
    },
    {
      "say": "{key:o} and {key:O}. Navigate the corners of a block selection."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f grid.py"
    }
  ],
  "youtube": {
    "videoId": "mFU8uX4mCtE",
    "url": "https://youtube.com/watch?v=mFU8uX4mCtE"
  }
}
