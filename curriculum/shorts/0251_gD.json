{
  "title": "VimFu \u2014 gD Go to Global Definition",
  "description": "gD jumps to the global definition of the word under the cursor. It searches from the top of the file, not just the current function.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
