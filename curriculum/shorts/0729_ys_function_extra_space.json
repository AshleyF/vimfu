{
  "title": "VimFu — Surround with Function — Extra Space",
  "description": "ysiwFprint↵ wraps the word in a function call with spaces inside: print( word ).",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 688,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f funcsp.py .funcsp.py.swp .funcsp.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "funcsp.py",
      "content": "result = value\noutput = name"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim funcsp.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Function — Extra Space",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Capital F wraps in a function call with spaces inside the parentheses. The padded version of lowercase F."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Lowercase F first. Y S I W F, print, enter.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fv",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "type": "ysiwfprint",
      "overlay": "ysiwfprint↵"
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Tight. Print paren value paren."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Capital F. Y S I W capital F, print, enter.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": "ysiwFprint",
      "overlay": "ysiwFprint↵"
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Padded. Print, space, value, space. Capital F adds spaces inside the call."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f funcsp.py"
    }
  ]
}
