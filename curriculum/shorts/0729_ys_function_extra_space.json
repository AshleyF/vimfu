{
  "title": "VimFu — Change Function Name",
  "description": "{key:c}{key:s}{key:f} opens a prompt to change the function name around the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 688,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f funcsp.py .funcsp.py.swp .funcsp.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "funcsp.py",
      "content": "result = print(value)\noutput = len(name)"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim funcsp.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change Function Name",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "In nvim-surround, lowercase {key:f} is the function-call surround. There is no capital {key:F} padded function form."
    },
    {
      "wait": 0.3
    },
    {
      "say": "To change an existing function call, put the cursor inside it and press {key:c}{key:s}{key:f}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fv",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "csf"
    },
    {
      "wait": 0.8
    },
    {
      "type": "debug"
    },
    {
      "wait": 0.5
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "The prompt changed `print` to `debug`, while keeping the argument."
    },
    {
      "say": "Line two: change `len` to `str` the same way.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfn",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "csf"
    },
    {
      "wait": 0.8
    },
    {
      "type": "str"
    },
    {
      "wait": 0.5
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "{key:c}{key:s}{key:f} changes the function name through the bottom prompt. The arguments stay in place."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f funcsp.py"
    }
  ],
  "youtube": {
    "videoId": "B2Nf0X0nP6c",
    "url": "https://youtube.com/watch?v=B2Nf0X0nP6c"
  }
}
