{
  "title": "VimFu — Align Text with Substitute",
  "description": "Use a visual-range substitute with an expression replacement to align text to a specific column.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 628,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "practical"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f data.txt .data.txt.swp .data.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "data.txt",
      "content": "name = Alice\nage = 30\ncity = Portland\nrole = engineer\nid = 42"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim data.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Align with :s",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "A visual-range substitute can align text when the replacement is an expression. Let's align the equals signs."
    },
    {
      "wait": 0.3
    },
    {
      "say": "First, select all lines with V G.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "V",
      "overlay": "visual line"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "G",
      "overlay": "to last line"
    },
    {
      "wait": 0.4
    },
    {
      "say": "First, type the command so we can read it.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": ":",
      "overlay": "command line"
    },
    {
      "wait": 0.3
    },
    {
      "type": "s/\\s*=/\\=repeat(' ',6-col('.')).'='/"
    },
    {
      "wait": 0.8
    },
    {
      "say": "The pattern `\\s*=` finds any spaces before each equals sign. The replacement starts with `\\=`, so Vim evaluates code instead of inserting literal text.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "say": "`repeat(' ', 6-col('.'))` makes enough spaces to put the equals sign in column 6. Now pause, read it, then run it.",
      "wait": false
    },
    {
      "wait": 1.4
    },
    "enter",
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.4
    },
    {
      "say": "The equals signs are now aligned. Each line has the right number of spaces so the equals column lines up neatly."
    },
    {
      "wait": 0.3
    },
    {
      "say": "This technique works for aligning any character. Just change the column number and the target character."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f data.txt"
    }
  ],
  "youtube": {
    "videoId": "5fyzUNYSkRE",
    "url": "https://youtube.com/watch?v=5fyzUNYSkRE"
  }
}
