{
  "title": "VimFu — Delete Surrounding Brackets",
  "description": "ds] or dsr removes square brackets around the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 662,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f brackets.py .brackets.py.swp .brackets.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "brackets.py",
      "content": "items = [1, 2, 3]\nfirst = [\"alpha\"]\ncoord = [x, y]"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim brackets.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete Surrounding Brackets",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "D S close bracket deletes surrounding square brackets. D S R is the alias. R for rectangle."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside the brackets on line one. D S close bracket.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "f1",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds]",
      "overlay": "ds]"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Brackets removed."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Same thing with D S R.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfa",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "dsr",
      "overlay": "dsr"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Identical result. D S bracket or D S R."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f brackets.py"
    }
  ],
  "youtube": {
    "videoId": "wF_XqXxibXs",
    "url": "https://youtube.com/watch?v=wF_XqXxibXs"
  }
}
