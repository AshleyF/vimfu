{
  "title": "VimFu — Visual Yank",
  "description": "Use visual yank when you need to copy an exact irregular span, not a whole line.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 592,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "visual mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f incident.txt .incident.txt.swp .incident.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "incident.txt",
      "content": "# incident note\nImpact: payment webhooks were delayed\nfor EU merchants during deploy 42\nuntil the retry worker caught up.\n\nSummary:"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim incident.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "visual yank",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "If one motion names the range, use that motion. Visual yank is for exact spans you want to inspect first."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Here, copy from `payment` through `worker`. It crosses lines and stops before the rest of the sentence.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "/",
      "overlay": "start"
    },
    {
      "type": "payment"
    },
    {
      "keys": "enter"
    },
    {
      "keys": "v",
      "overlay": "visual"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "/",
      "overlay": "end"
    },
    {
      "type": "worker"
    },
    {
      "keys": "enter"
    },
    {
      "keys": "e",
      "overlay": "extend"
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:y} copies exactly the visible selection. Now paste it after Summary.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "y",
      "overlay": "yank"
    },
    {
      "wait": 0.4
    },
    {
      "keys": "G$"
    },
    {
      "keys": "A "
    },
    "escape",
    {
      "keys": "p",
      "overlay": "paste"
    },
    {
      "wait": 0.8
    },
    {
      "say": "That is the useful case: copy a weird span after you can see exactly what is selected."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f incident.txt"
    }
  ],
  "youtube": {
    "videoId": "GfnRXECDtFM",
    "url": "https://youtube.com/watch?v=GfnRXECDtFM"
  }
}
