{
  "title": "VimFu — Surround with Arbitrary Character",
  "description": "ysiw/ and ysiw| wrap a word with any symmetric character.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 690,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f arb.md .arb.md.swp .arb.md.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "arb.md",
      "content": "bold text here\nitalic text here\ncode text here"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim arb.md"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Surround with Any Character",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Any punctuation character works as a surround. It wraps symmetrically, same character on both sides."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Wrap bold in asterisks. Y S I W asterisk.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw*",
      "overlay": "ysiw*"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Bold is now wrapped in asterisks. Markdown bold."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Underscores. Y S I W underscore.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfi",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw_",
      "overlay": "ysiw_"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Underscored."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Backticks. Y S I W backtick.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfc",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw`",
      "overlay": "ysiw`"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Code wrapped in backticks. Any character works."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f arb.md"
    }
  ],
  "youtube": {
    "videoId": "suKH5StK6II",
    "url": "https://youtube.com/watch?v=suKH5StK6II"
  }
}
