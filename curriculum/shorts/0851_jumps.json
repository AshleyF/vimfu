{
  "title": "VimFu — :jumps Show Jump List",
  "description": "The :jumps command displays the jump list — a history of cursor positions you've jumped between.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 753,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp .demo.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.py",
      "content": "# config\nhost = \"localhost\"\nport = 8080\n\n# logic\ndef run():\n    pass\n\n# main\nif __name__ == \"__main__\":\n    run()"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with -i NONE so shada doesn't restore stale jumps from prior sessions"
    },
    {
      "line": "nvim -i NONE demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":jumps — Show Jump List",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Colon jumps shows your jump history. Every big cursor movement is recorded."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: clear the list, make three deliberate jumps, then show ---"
    },
    {
      "say": "Let me clear the list first so we start fresh.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":clearjumps",
      "overlay": ":clearjumps"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.5
    },
    {
      "say": "We're at the top. Jump to the bottom.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "G",
      "overlay": "bottom"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Now jump to the middle, line six.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "6G",
      "overlay": "line 6 (middle)"
    },
    {
      "wait": 0.5
    },
    {
      "say": "And back to the top.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gg",
      "overlay": "top"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Show jump list, narrate while popup is on screen ---"
    },
    {
      "type": ":jumps",
      "overlay": ":jumps"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 1.0
    },
    {
      "say": "Three jumps — top, bottom, middle — exactly the trail we made. Use Control O to go back through them, Control I forward."
    },
    {
      "wait": 0.5
    },
    {
      "keys": "q",
      "overlay": "dismiss"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon jumps. Your breadcrumb trail through the file."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "JA6myshr9E4",
    "url": "https://youtube.com/watch?v=JA6myshr9E4"
  }
}
