{
  "title": "VimFu — :s Flag i — Case Insensitive",
  "description": "The i flag on :s makes the search pattern case insensitive, matching regardless of upper or lower case.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 740,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with mixed case"
    },
    {
      "writeFile": "demo.txt",
      "content": "Hello hello HELLO hElLo\nWorld WORLD world\nfoo Foo FOO"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":s Flag i — Case Insensitive",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "The I flag makes substitute ignore case."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: without i flag ---"
    },
    {
      "say": "Line one has hello in mixed cases. Without I, only exact case matches.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":s/hello/HI/g",
      "overlay": ":s/hello/HI/g"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Only lowercase hello was replaced. The others survived."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: with i flag ---"
    },
    {
      "say": "Line three has foo in three cases. Add the I flag.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2j",
      "overlay": "move to line 3"
    },
    {
      "wait": 0.3
    },
    {
      "type": ":s/foo/bar/gi",
      "overlay": ":s/foo/bar/gi"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.6
    },
    {
      "say": "All three replaced. Foo, capital FOO, lowercase foo. The I flag matched them all."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "The I flag. Case insensitive substitution. Combine with G to replace all on the line."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.txt"
    }
  ],
  "youtube": {
    "videoId": "DQsWRob46yQ",
    "url": "https://youtube.com/watch?v=DQsWRob46yQ"
  }
}
