{
  "title": "VimFu — Recipe: Add to Every Line",
  "description": "Use :%norm A; to append a semicolon to every line. The norm command runs normal mode keystrokes on each line.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 822,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "recipes"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f code.js .code.js.swp .code.js.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo JS file missing semicolons"
    },
    {
      "writeFile": "code.js",
      "content": "let x = 1\nlet y = 2\nlet z = x + y\nconsole.log(x)\nconsole.log(y)\nconsole.log(z)"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim code.js"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Recipe: Add to Every Line",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Every line in this JavaScript file is missing a semicolon. Let's fix them all at once."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Append semicolons ---"
    },
    {
      "say": "Use the norm command to run normal-mode keystrokes on every line."
    },
    {
      "type": ":%norm A;",
      "overlay": ":%norm A;"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Percent norm A semicolon. Capital A appends at end of line; norm replays it on every line in the file."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Every line now ends with a semicolon. Six lines fixed in one command."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Percent norm followed by keystrokes. Run any normal mode command on every line."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f code.js"
    }
  ],
  "youtube": {
    "videoId": "SulGFxJ-EuE",
    "url": "https://youtube.com/watch?v=SulGFxJ-EuE"
  }
}
