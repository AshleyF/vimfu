{
  "title": "VimFu — :[range]nu Print with Numbers",
  "description": "The :nu (or :#) command prints lines with their line numbers shown.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 750,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.txt",
      "content": "apple\nbanana\ncherry\ndate\nelderberry\nfig\ngrape\nhoneydew"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":[range]nu — Print with Numbers",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Colon N U prints lines with their line numbers. Just like colon P but with numbers."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: single line with number ---"
    },
    {
      "say": "Print line four with its number.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":4nu",
      "overlay": ":4nu"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.8
    },
    {
      "say": "It shows the number four, then the word date."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: range with numbers ---"
    },
    {
      "say": "Print lines two through five with numbers.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":2,5nu",
      "overlay": ":2,5nu"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 1.0
    },
    {
      "say": "Each line is prefixed with its number. You can also use colon hash for the same thing."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon N U. Print lines with line numbers. Handy for quick reference."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.txt"
    }
  ],
  "youtube": {
    "videoId": "HCL8DKN5e_M",
    "url": "https://youtube.com/watch?v=HCL8DKN5e_M"
  }
}
