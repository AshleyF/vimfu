{
  "title": "VimFu — Change with Word Target",
  "description": "cswb and csWB use word motions as shortcut targets for surrounding the current word.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 678,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f word.py .word.py.swp .word.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "word.py",
      "content": "name = hello\npath = /home/user"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim word.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change with Word Target",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "The letters W and capital W can be used as shortcut targets with C S. C S W B wraps the word in parens. Think of it as change surround word to bracket."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor on hello. C S W B.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cswb",
      "overlay": "cswb"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Hello is now wrapped in parentheses."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Capital W targets a big word. C S capital W capital B on the path.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jf/",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "csWB",
      "overlay": "csWB"
    },
    {
      "wait": 0.8
    },
    {
      "say": "The whole path including slashes is wrapped in braces. Capital W grabs the WORD."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f word.py"
    }
  ]
}
