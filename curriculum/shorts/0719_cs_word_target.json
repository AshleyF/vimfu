{
  "title": "VimFu — Change with Target Aliases",
  "description": "{key:c}{key:s} can use surround aliases as targets, like {key:q} for quotes and {key:r} for square brackets.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 678,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f word.py .word.py.swp .word.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "word.py",
      "content": "name = \"hello\"\nitems = [alpha beta]"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim word.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change with Target Aliases",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:c}{key:s} can use aliases as the target. {key:q} means the nearest quote pair. {key:r} means square brackets."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside quoted hello. {key:c}{key:s}{key:q}{key:)} changes the nearest quotes to parentheses.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "csq)"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "csq)"
    },
    {
      "wait": 0.8
    },
    {
      "say": "The quotes changed to parentheses. Line two uses {key:r}, the bracket alias.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jf[ll",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "csr}"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "csr}"
    },
    {
      "wait": 0.8
    },
    {
      "say": "{key:c}{key:s}{key:r}{key:}} changes square brackets to braces. Aliases save you from remembering every paired delimiter key."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f word.py"
    }
  ],
  "youtube": {
    "videoId": "w6TMqrOjw5w",
    "url": "https://youtube.com/watch?v=w6TMqrOjw5w"
  }
}
