{
  "title": "VimFu — :earlier / :later",
  "description": "Use :earlier and :later to travel backward and forward through undo history by change count or time.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 638,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "advanced"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f timeline.txt .timeline.txt.swp .timeline.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "timeline.txt",
      "content": ""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim timeline.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":earlier / :later",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Vim can time travel through undo states. `:earlier` moves to an older state; `:later` moves forward again."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Type three chunks. Between chunks, press {key:Ctrl-G}, then {key:u}. That creates separate undo states.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "i",
      "overlay": "insert"
    },
    {
      "type": "one"
    },
    {
      "ctrl": "g",
      "overlay": "undo break"
    },
    {
      "keys": "u",
      "overlay": "finish break"
    },
    {
      "type": " two"
    },
    {
      "ctrl": "g",
      "overlay": "undo break"
    },
    {
      "keys": "u",
      "overlay": "finish break"
    },
    {
      "type": " three"
    },
    {
      "keys": "escape"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Now the line says `one two three`. Run `:earlier 2` to go back two undo states.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":earlier 2",
      "beforeEnter": 1.2
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "ctrl": "l",
      "overlay": "redraw"
    },
    {
      "wait": 0.5
    },
    {
      "say": "`two three` disappears. We are back at the first chunk."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Run `:later 2` to move forward again.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":later 2",
      "beforeEnter": 1.2
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "ctrl": "l",
      "overlay": "redraw"
    },
    {
      "wait": 0.5
    },
    {
      "say": "`three` is back. You can use counts, or time units like `:earlier 10s` and `:later 5m`."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f timeline.txt"
    }
  ],
  "youtube": {
    "videoId": "K42WOcFwS9Y",
    "url": "https://youtube.com/watch?v=K42WOcFwS9Y"
  }
}
