{
  "title": "VimFu — Change to HTML Tag",
  "description": "{key:c}{key:s}{key:\"}{key:t} opens a tag prompt; type `em>` to change quotes to an HTML tag pair.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 674,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f page.html .page.html.swp .page.html.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "page.html",
      "content": "title = \"Hello World\"\nlabel = \"Click Me\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim page.html"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change to HTML Tag",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:c}{key:s} can change any surrounding into an HTML tag. Use {key:t} to open the tag prompt at the bottom."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Double quotes around Hello World. Use {key:c}{key:s}{key:\"}{key:t}. When the prompt appears, type `em>` and press {key:Enter}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fH",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs\"t"
    },
    {
      "wait": 0.8
    },
    {
      "type": "em>"
    },
    {
      "wait": 0.5
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "The tag name was typed at the bottom prompt. Quotes became em tags."
    },
    {
      "say": "Line two: open the same prompt and type `h1>`.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfC",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs\"t"
    },
    {
      "wait": 0.8
    },
    {
      "type": "h1>"
    },
    {
      "wait": 0.5
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Now both lines use real opening and closing tags. The replacement tag text goes into the prompt, not the key overlay."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f page.html"
    }
  ],
  "youtube": {
    "videoId": "dCrXsfbecSg",
    "url": "https://youtube.com/watch?v=dCrXsfbecSg"
  }
}
