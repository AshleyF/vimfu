{
  "title": "VimFu — Ctrl-W hjkl Navigate Splits",
  "description": "Ctrl-W h/j/k/l moves the cursor to the left, down, up, or right window. Navigate between splits with Vim motions.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 478,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "windows",
    "splits"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f north.py south.py east.py .north.py.swp .south.py.swp .east.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create three demo files"
    },
    {
      "writeFile": "north.py",
      "content": "# North Kingdom\ncastle = \"Winterhold\"\nking = \"Frost King\"\narmy = 5000"
    },
    {
      "writeFile": "east.py",
      "content": "# East Kingdom\ncastle = \"Sunspire\"\nqueen = \"Sun Queen\"\narmy = 3000"
    },
    {
      "writeFile": "south.py",
      "content": "# South Kingdom\ncastle = \"Stonehold\"\nlord = \"Stone Lord\"\narmy = 2000"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with left pane + vertical split + horizontal split on right"
    },
    {
      "line": "nvim -c 'set splitright splitbelow' -c 'vsplit east.py' -c 'split south.py' -c 'wincmd t' north.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-W hjkl — Navigate Splits",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control W H J K L moves between windows. Same directions as normal mode. H left. J down. K up. L right."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: L right ---"
    },
    {
      "say": "Three panes. Cursor starts in the left pane. Control W L to go right.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0017l",
      "overlay": "right"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Top right pane. East kingdom."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: J down ---"
    },
    {
      "say": "Control W J to go down.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0017j",
      "overlay": "down"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Bottom right pane. South kingdom."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 3: K up ---"
    },
    {
      "say": "Control W K to go back up.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0017k",
      "overlay": "up"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Back to east."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 4: H left ---"
    },
    {
      "say": "Control W H to go all the way left.",
      "wait": false
