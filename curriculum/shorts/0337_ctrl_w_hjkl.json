    {
      "wait": 0.3
    },
    {
      "keys": "\u0017h",
      "overlay": "left"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Back to north. Same muscle memory as normal mode."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Control W H J K L. Navigate splits with the same keys you use to move in a file. Natural and fast."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
