{
  "title": "VimFu — :tabclose Close Tab",
  "description": "The :tabclose command closes the current tab page.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 558,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "tabs"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f a.py b.py .*.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "a.py",
      "content": "# Tab A"
    },
    {
      "writeFile": "b.py",
      "content": "# Tab B"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim -p a.py b.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":tabclose — Close Tab",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "Colon tab close closes the current tab. The buffer stays loaded, just the tab goes away."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Go to the second tab, then close it.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gt",
      "overlay": "next tab"
    },
    {
      "wait": 0.4
    },
    {
      "type": ":tabclose",
      "overlay": ":tabclose"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "say": "Tab gone. Back to one tab. The buffer is still in memory. Just the tab view is closed."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Colon tab close. Clean up tabs you don't need."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":qa!"
    },
    "enter",
    {
      "line": "rm -f a.py b.py"
    }
  ],
  "youtube": {
    "videoId": "MduLd9tbduw",
    "url": "https://youtube.com/watch?v=MduLd9tbduw"
  }
}
