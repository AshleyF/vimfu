  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.txt",
      "content": "one\ntwo\nthree\nfour\nfive\nsix\nseven\neight"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":[range]p — Print Lines",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Colon P prints lines in the command area at the bottom of the screen."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: print single line ---"
    },
    {
      "say": "Print line three.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":3p",
      "overlay": ":3p"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.8
    },
    {
      "say": "It shows three in the status area."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: print range ---"
    },
    {
      "say": "Print lines five through eight.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":5,8p",
      "overlay": ":5,8p"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 1.0
    },
    {
      "say": "Four lines printed. Press enter to dismiss."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon P. Quick way to peek at lines without moving the cursor."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.txt"
    }
