{
  "title": "VimFu — Visual Surround — Linewise",
  "description": "In linewise visual mode, {key:S} wraps the selected lines with the surrounding on separate lines.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 697,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f lines.html .lines.html.swp .lines.html.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "lines.html",
      "content": "First line\nSecond line\nThird line"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim lines.html"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Visual Surround — Linewise",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "In linewise *visual mode,* {key:S} places the surrounding on separate lines. The selected lines sit between them."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Select all three lines with {key:V}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "Vjj",
      "overlay": "V → select lines"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Press {key:S}{key:{} to wrap the selected lines in braces.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "S{"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Opening brace above, selected lines in the middle, closing brace below. That is linewise visual surround."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f lines.html"
    }
  ],
  "youtube": {
    "videoId": "jEcQN2GkZSU",
    "url": "https://youtube.com/watch?v=jEcQN2GkZSU"
  }
}
