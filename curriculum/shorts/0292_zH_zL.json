  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f wide.py .wide.py.swp .wide.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with very long lines"
    },
    {
      "writeFile": "wide.py",
      "content": "# Inventory Database\nweapons = [\"flame_sword\", \"ice_dagger\", \"thunder_bow\", \"shadow_staff\", \"holy_mace\", \"venom_whip\", \"storm_axe\"]\narmor_sets = {\"plate\": 90, \"chain\": 60, \"leather\": 30, \"cloth\": 10, \"dragon_scale\": 120, \"mithril\": 100}\nshort = True"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with nowrap"
    },
    {
      "line": "nvim -c 'set nowrap' wide.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "zH zL \u2014 Scroll Half-Screen",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Capital Z capital H and capital Z capital L scroll half a screen width at a time. Much faster than Z H and Z L."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: scroll right with zL ---"
    },
    {
      "say": "Line two is cut off. Jump to it and scroll right with capital Z capital L.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": "down"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "zL",
      "overlay": "scroll right half-screen"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Half a screen width in one shot. Hit it again.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "zL",
      "overlay": "scroll right"
    },
    {
      "wait": 0.6
    },
    {
      "comment": "--- Demo 2: scroll back with zH ---"
    },
    {
      "say": "Capital Z capital H scrolls back to the left.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "zH",
      "overlay": "scroll left half-screen"
    },
    {
      "wait": 0.5
    },
    {
      "keys": "zH",
      "overlay": "scroll left"
    },
    {
      "wait": 0.6
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Capital Z capital H and capital Z capital L. Half-screen horizontal scrolling. Perfect for wide files."
