  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f stats.py .stats.py.swp .stats.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*stats.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "stats.py",
      "content": "hp = 100\nmp = \nspeed = 42\nxp = \nlives = 3"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim stats.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
