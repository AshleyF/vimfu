{
  "title": "VimFu \u2014 Ctrl-U Delete Line in Insert",
  "description": "Ctrl-U in insert mode deletes all text before the cursor on the current line.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 512,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "insert mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\nresult = 0"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-U \u2014 Delete to Start",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control U in insert mode deletes everything before the cursor on the current line. A quick way to clear what you've typed."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: type then clear ---"
    },
    {
      "say": "Open a new line and type something.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "o",
      "overlay": "open line"
    },
    {
      "wait": 0.2
    },
    {
      "type": "this is the wrong text",
      "overlay": ""
    },
    {
      "wait": 0.4
    },
    {
      "say": "That's all wrong. Control U to erase it.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0015",
      "overlay": "clear line"
    },
    {
      "wait": 0.5
    },
    {
      "say": "All gone. Start fresh on the same line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": "total = 100",
      "overlay": ""
    },
    {
      "wait": 0.4
    },
    {
      "say": "Control W deletes a word. Control U deletes the whole line. Two levels of undo without leaving insert mode."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Control U. Clear the line in insert mode. Start over without pressing Escape."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ]
}
