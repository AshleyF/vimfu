    "keyboard"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f squad.py .squad.py.swp .squad.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*squad.py*"
    },
    {
      "comment": "Create demo file — 15 lines for multi-digit count demo"
    },
    {
      "writeFile": "squad.py",
      "content": "a = \"sword\"\nb = \"bow\"\nc = \"spear\"\nd = \"axe\"\ne = \"mace\"\nf = \"staff\"\ng = \"shield\"\nh = \"lance\"\ni = \"dagger\"\nj = \"hammer\"\nk = \"flail\"\nl = \"pike\"\nm = \"whip\"\nn = \"sling\"\no = \"club\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim squad.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Count Prefix (1-9)",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Type a number before any command to repeat it. The digit keys one through nine start a count. But the count itself can be any number you like."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: 5j ---"
    },
    {
      "say": "Five J. Move down five lines.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "5j",
      "overlay": "5 down"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Jumped from line one to line six. The count multiplied the motion."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: 4w ---"
    },
    {
      "say": "Four W. Jump four words forward.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "4w",
      "overlay": "4 words"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Skipped four words. Works with any motion."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 3: multi-digit count 12j ---"
    },
    {
      "say": "Counts aren't limited to single digits. Go back to the top. Now, twelve J.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gg",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "12j",
      "overlay": "12 down"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Jumped twelve lines. Just type the full number — one, two — then the command."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Count prefix. Type any number, then the action. Five J, four W, twelve J. Vim multiplies everything."
    },
    {
      "wait": 1.5
    }
  ],
