{
  "title": "VimFu — Count Prefix (1-9)",
  "description": "Type any number before a command to repeat it. The keys 1-9 start a count prefix. Multi-digit counts like 12 or 42 work too.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 330,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
