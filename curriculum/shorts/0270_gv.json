{
  "title": "VimFu — gv Reselect Visual",
  "description": "gv reselects the last visual selection. Jump right back to where you were selecting without starting over.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 411,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "g commands",
    "visual"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f items.py .items.py.swp .items.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "items.py",
      "content": "# Inventory\nitems = [\n    \"sword\",\n    \"shield\",\n    \"potion\",\n    \"scroll\",\n]\nprint(items)"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim items.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "gv — Reselect Visual",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "G V reselects the last visual selection. Lost your selection? G V brings it right back."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: select, escape, reselect ---"
    },
    {
      "say": "Select lines three through six. The items.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "3GV",
      "overlay": "visual line"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "3j",
      "overlay": "select 4 lines"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Four lines selected. Now escape.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape",
      "overlay": "escape"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Selection gone. But G V brings it back.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gv",
      "overlay": "reselect!"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Same four lines selected again."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: indent then reselect ---"
    },
    {
      "say": "Indent the selection with greater than. Then G V and indent again.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": ">",
      "overlay": "indent"
    },
    {
      "wait": 0.4
    },
    {
      "keys": "gv",
      "overlay": "reselect"
    },
    {
      "wait": 0.3
    },
    {
      "keys": ">",
      "overlay": "indent again"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Double indented. G V makes it easy to repeat operations on the same block."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "G V. Reselect. Use it after indenting, after escaping, anytime you need the last selection back."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f items.py"
    }
  ],
  "youtube": {
    "videoId": "c6emiIPoPAE",
    "url": "https://youtube.com/watch?v=c6emiIPoPAE"
  }
}
