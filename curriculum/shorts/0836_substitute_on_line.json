{
  "title": "VimFu — :s/old/new/ Substitute on Line",
  "description": "The :s command substitutes the first occurrence of a pattern on the current line. Basic find-and-replace at the line level.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 738,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    { "writeFile": "demo.txt", "content": "the cat sat on the mat\nthe dog ran to the park\nthe fox fox jumped over" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim demo.txt" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":s/old/new/ — Substitute on Line", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "Colon S is the substitute command. It replaces text on the current line." },
    { "wait": 0.3 },
    { "comment": "--- Demo 1: basic substitute ---" },
    { "say": "The cursor is on line one. Replace the word cat with dog.", "wait": false },
    { "wait": 0.3 },
    { "type": ":s/cat/dog/", "overlay": ":s/cat/dog/" },
    { "wait": 0.3 },
    { "keys": "enter" },
    { "wait": 0.6 },
    { "say": "Cat became dog. Only the first match on the line was replaced." },
    { "wait": 0.3 },
    { "comment": "--- Demo 2: only first occurrence ---" },
    { "say": "Line three has fox twice. Let's substitute on that line.", "wait": false },
    { "wait": 0.3 },
    { "keys": "2j", "overlay": "move to line 3" },
    { "wait": 0.3 },
    { "type": ":s/fox/cat/", "overlay": ":s/fox/cat/" },
    { "wait": 0.3 },
    { "keys": "enter" },
    { "wait": 0.6 },
    { "say": "Only the first fox became cat. The second fox is still there. Without the G flag, S replaces just the first match." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Colon S slash old slash new slash. Substitute the first match on the current line." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f demo.txt" }
  ]
}
