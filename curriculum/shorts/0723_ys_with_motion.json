{
  "title": "VimFu — Surround with Motion",
  "description": "ys$\" and ysf.\" — any motion works as the first argument to ys.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 682,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f motion.py .motion.py.swp .motion.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "motion.py",
      "content": "msg = hello world\npath = config.yaml"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim motion.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Surround with Motion",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Y S takes any motion as its first argument, not just text objects. You can use dollar sign, F, T, or any movement."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Y S dollar sign, double quote. Surround from cursor to end of line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ys$\"",
      "overlay": "ys$\""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Everything from cursor to end of line is wrapped in quotes."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Y S F dot, double quote. Surround from cursor to the dot.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfc",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysf.\"",
      "overlay": "ysf.\""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Config dot is wrapped. Any motion defines the region to surround."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f motion.py"
    }
  ],
  "youtube": {
    "videoId": "Ia33WCB3Ym8",
    "url": "https://youtube.com/watch?v=Ia33WCB3Ym8"
  }
}
