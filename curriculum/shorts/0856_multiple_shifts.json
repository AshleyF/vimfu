{
  "title": "VimFu — Multiple Shifts :>> :<<<",
  "description": "Repeat the > or < symbol to shift by multiple shiftwidths at once.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 758,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp .demo.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.py",
      "content": "class Game:\n    def run(self):\nstart()\nupdate()\nrender()\n    def stop(self):\n        pass"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim -c 'set shiftwidth=4' demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Multiple Shifts — :>> :<<<",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Repeat the greater than or less than sign to shift by multiple levels."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: double indent ---"
    },
    {
      "say": "Lines three through five need two levels of indentation. Use double greater than.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":3,5>>",
      "overlay": ":3,5>>"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Two levels added. Eight spaces. They're now properly nested inside the method."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: triple dedent ---"
    },
    {
      "say": "You can also go the other way. Triple less than removes three levels.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":3<<<",
      "overlay": ":3<<<"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Line three lost all indentation. Three shifts at once."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Stack the arrows. Double greater than for two shifts, triple for three. Works with less than too."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "TDI6TY4BsVE",
    "url": "https://youtube.com/watch?v=TDI6TY4BsVE"
  }
}
