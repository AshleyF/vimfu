{
  "title": "VimFu — Surround with Space",
  "description": "ysiw( or ysiw{ — using the opening mark adds space inside the surrounding.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 680,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f spaced.py .spaced.py.swp .spaced.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "spaced.py",
      "content": "name = hello\nval = world"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim spaced.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Surround with Space",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Opening mark adds padding. Closing mark gives tight wrapping. This rule is consistent across all surround operations."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Y S I W close paren. Tight.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw)",
      "overlay": "ysiw)"
    },
    {
      "wait": 0.8
    },
    {
      "say": "No spaces inside."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Y S I W open paren. Padded.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw(",
      "overlay": "ysiw("
    },
    {
      "wait": 0.8
    },
    {
      "say": "Spaces inside. Open paren adds padding."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Same with braces. Y S I W open brace.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfw",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw{",
      "overlay": "ysiw{"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Braces with space inside. Opening mark, padded. Closing mark, tight."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f spaced.py"
    }
  ]
}
