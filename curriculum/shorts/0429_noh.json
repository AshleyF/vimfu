{
  "title": "VimFu — :noh",
  "description": "Clear search highlighting with :noh (nohlsearch) in Vim without changing the hlsearch setting.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 570,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "settings"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\ndef greet(name):\n    return f\"Hello {name}\"\n\nresult = greet(\"World\")\nprint(result)"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":noh",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "After a search, highlights can be distracting. The noh command clears them temporarily."
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set hlsearch",
      "overlay": ":set hlsearch"
    },
    "enter",
    {
      "wait": 0.3
    },
    {
      "type": "/name",
      "overlay": "/name"
    },
    "enter",
    {
      "wait": 1.0
    },
    {
      "say": "I searched for name and all matches are highlighted. Now I'll clear them with noh."
    },
    {
      "wait": 0.3
    },
    {
      "type": ":noh",
      "overlay": ":noh"
    },
    "enter",
    {
      "wait": 1.0
    },
    {
      "say": "The highlights are gone, but hlsearch is still enabled. The next time you search, highlights will appear again."
    },
    {
      "wait": 0.5
    },
    {
      "type": "/greet",
      "overlay": "/greet"
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "See? New search, new highlights. Use noh whenever you want a clean view without changing your settings."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "gH3I2EK7K3U",
    "url": "https://youtube.com/watch?v=gH3I2EK7K3U"
  }
}
