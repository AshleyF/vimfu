{
  "title": "VimFu — The C Key",
  "description": "Capital C changes from the cursor to the end of the line. Delete the rest and start typing. C for change to end.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 305,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "keyboard"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f boss.py .boss.py.swp .boss.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*boss.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "boss.py",
      "content": "name = \"goblin king\"\nhp = 500\natk = \"fireball\"\nweak = \"ice\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim boss.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "The C Key",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Capital C deletes from the cursor to the end of the line and enters insert mode. Change the rest."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: change the value ---"
    },
    {
      "say": "Change the boss name. Move to the quote. Capital C.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "f\"",
      "overlay": "find \""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "C",
      "overlay": "change to end"
    },
    {
      "type": "\"dragon lord\""
    },
    "escape",
    {
      "wait": 0.6
    },
    {
      "say": "Everything from the quote to the end, replaced. One key to start."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: change from middle of line ---"
    },
    {
      "say": "Change H P to nine thousand. Move to the number. Capital C.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j0f5",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "C",
      "overlay": "change to end"
    },
    {
      "type": "9001"
    },
    "escape",
    {
      "wait": 0.6
    },
    {
      "say": "Five hundred became nine thousand and one. C wiped the rest and I typed the new value."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 3: compare with D ---"
    },
    {
      "say": "Capital D also deletes to the end, but stays in normal mode. Capital C enters insert. That's the difference.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2j0f\"",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "C",
      "overlay": "change to end"
    },
    {
      "type": "\"thunder\""
    },
    "escape",
    {
      "wait": 0.6
    },
    {
      "say": "Fireball became thunder. Capital C. Delete and replace in one move."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Capital C. Change to the end of the line. Like D but drops you into insert mode."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f boss.py"
    }
  ],
