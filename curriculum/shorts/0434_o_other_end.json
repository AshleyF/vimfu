{
  "title": "VimFu — o — Other End",
  "description": "In visual mode, press o to jump the cursor to the other end of the selection. The selection stays — only the cursor moves.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 588,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "visual mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f range.py .range.py.swp .range.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "range.py",
      "content": "# data range\nalpha = 10\nbeta = 20\ngamma = 30\ndelta = 40\nepsilon = 50"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim range.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "o — Other End",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "In visual mode, O moves the cursor to the other end of the selection. The highlight stays."
    },
    {
      "wait": 0.3
    },
    {
      "say": "V on beta, then J J to select three lines.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2j"
    },
    {
      "keys": "V"
    },
    {
      "keys": "jj"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Cursor is on delta at the bottom. Press O.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "o",
      "overlay": "other end"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Cursor jumped to beta at the top. Selection unchanged."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now K to extend the selection upward.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "k"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Four lines now. Alpha through delta."
    },
    {
      "wait": 0.3
    },
    {
      "say": "O again to flip back down.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "o"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Back at the bottom. You can extend in either direction by flipping with O."
    },
    {
      "wait": 0.3
    },
    "escape",
    {
      "wait": 0.3
    },
    {
      "say": "Works in charwise mode too. V E to select a word.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gg0"
    },
    {
      "keys": "jw"
    },
    {
      "keys": "ve"
    },
    {
      "wait": 0.4
    },
    {
      "keys": "o"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Cursor flipped to the start of the word."
    },
    {
      "wait": 0.3
    },
    "escape",
    {
      "wait": 0.3
    },
    {
      "say": "O in visual mode. Jump to the other end. Adjust from either side."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f range.py"
    }
  ],
