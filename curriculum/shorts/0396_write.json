{
  "title": "VimFu \u2014 :w Write (Save)",
  "description": "The :w command saves the current file to disk.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 537,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\nprint(\"hello\")"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":w \u2014 Write (Save)",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "Colon W saves your file. The most important command you'll learn."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Let's make a change first.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jA",
      "overlay": "append"
    },
    {
      "type": "\nprint(\"world\")",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now save. Colon W.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":w",
      "overlay": "write"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "say": "Saved. Look at the bottom. It confirms the file was written with the byte count."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Colon W. Save early, save often. You'll type it a thousand times."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ]
}
