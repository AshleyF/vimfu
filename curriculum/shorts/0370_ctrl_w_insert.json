  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\nresult = 0"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-W — Delete Word",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control W in insert mode deletes the word behind the cursor. Faster than pressing Backspace many times."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: type and delete a word ---"
    },
    {
      "say": "Let's type a long line and then delete the last word.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "o",
      "overlay": "open line"
    },
    {
      "wait": 0.2
    },
    {
      "type": "total = calculate_result",
      "overlay": ""
    },
    {
      "wait": 0.4
    },
    {
      "say": "Wrong word. Control W to delete it.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0017",
      "overlay": "delete word"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Gone. Now type the right word.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": "compute_sum",
      "overlay": ""
    },
    {
      "wait": 0.4
    },
    {
      "comment": "--- Demo 2: delete multiple words ---"
    },
    {
      "say": "Control W again deletes another word.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0017",
      "overlay": "another word"
    },
    {
      "wait": 0.4
    },
    {
      "keys": "\u0017",
      "overlay": "and another"
    },
    {
