{
  "title": "VimFu — :s Backreference &",
  "description": "In :s replacement, & refers to the entire matched text. Wrap, prefix, or suffix matches easily.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 814,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f words.txt .words.txt.swp .words.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "words.txt",
      "content": "apple\nbanana\ncherry\ndate\nelderberry"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim words.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":s Backreference &",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "In a substitute replacement, ampersand means the entire matched text. Use it to wrap or decorate matches without retyping them."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: wrap words in brackets ---"
    },
    {
      "say": "Wrap every word in square brackets."
    },
    {
      "type": ":%s/\\w\\+/[&]/g",
      "overlay": ":%s/\\w\\+/[&]/g"
    },
    {
      "wait": 0.4
    },
    {
      "say": "The pattern matches each word; the replacement bracket ampersand bracket reinserts the match between brackets."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Each word is now wrapped in brackets."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: undo and prefix ---"
    },
    {
      "say": "Undo, then add a dash prefix to each line."
    },
    {
      "keys": "u"
    },
    {
      "wait": 0.5
    },
    {
      "type": ":%s/.*/ - &/",
      "overlay": ":%s/.*/ - &/"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Dot star matches the whole line. Dash space ampersand puts a dash in front of the original text."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Each line got a dash prefix."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Ampersand in the replacement means the whole match. Wrap, prefix, suffix, anything."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f words.txt"
    }
  ],
  "youtube": {
    "videoId": "7HP7D8o7Huo",
    "url": "https://youtube.com/watch?v=7HP7D8o7Huo"
  }
}
