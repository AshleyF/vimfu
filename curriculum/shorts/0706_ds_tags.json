{
  "title": "VimFu — Delete Surrounding Tags",
  "description": "dst removes the HTML/XML tag pair around the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 665,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f tags.html .tags.html.swp .tags.html.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "tags.html",
      "content": "<div>hello</div>\n<em>world</em>\n<p>content here</p>"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim tags.html"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete Surrounding Tags",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "D S T deletes the surrounding tag pair. T for tag. It finds the nearest H T M L or X M L tag around the cursor."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside the div tags. D S T.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "dst",
      "overlay": "dst"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Both the opening div and closing div are gone. Just hello remains."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Line two. Inside the em tags. D S T.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfw",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "dst",
      "overlay": "dst"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Em tags removed. D S T works on any tag."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f tags.html"
    }
  ]
}
