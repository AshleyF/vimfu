{
  "title": "VimFu — Mark-Based Ranges",
  "description": "Use marks as range endpoints. :'a,'b d deletes from mark a to mark b.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 712,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f entries.txt .entries.txt.swp .entries.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "entries.txt",
      "content": "line 1 — alpha\nline 2 — bravo\nline 3 — charlie\nline 4 — delta\nline 5 — echo\nline 6 — foxtrot\nline 7 — golf\nline 8 — hotel\nline 9 — india\nline 10 — juliet\nline 11 — kilo\nline 12 — lima"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers"
    },
    {
      "line": "nvim -c 'set number' entries.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Mark-Based Ranges",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "You can use marks as range endpoints. Set a mark on one line, another mark on a different line, then use them in a range."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: set marks ---"
    },
    {
      "say": "Go to line three. Set mark A.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":3"
    },
    {
      "wait": 1.0
    },
    "enter",
    {
      "wait": 0.3
    },
    {
      "keys": "ma",
      "overlay": "mark a"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Go to line seven. Set mark B.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":7"
    },
    {
      "wait": 1.0
    },
    "enter",
    {
      "wait": 0.3
    },
    {
      "keys": "mb",
      "overlay": "mark b"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Use marks in range ---"
    },
    {
      "say": "Now delete from mark A to mark B. Colon quote A comma quote B d.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":'a,'bd"
    },
    {
      "wait": 1.2
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Lines three through seven are gone. The marks defined the range."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Quote mark in a range means that mark's line. Set marks first, then reference them in any Ex command."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f entries.txt"
    }
  ],
  "youtube": {
    "videoId": "3ZrgB7llhIc",
    "url": "https://youtube.com/watch?v=3ZrgB7llhIc"
  }
}
