{
  "title": "VimFu — :set expandtab / tabstop / shiftwidth",
  "description": "Control tab behavior with :set expandtab (et), :set tabstop (ts), and :set shiftwidth (sw).",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 776,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp .demo.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.py",
      "content": "def hello():\n    print(\"hi\")\n    return True"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":set expandtab / tabstop / shiftwidth",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Three settings control tab behavior in vim."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: set all three ---"
    },
    {
      "say": "Set expand tab, tab stop to four, and shift width to four.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set expandtab tabstop=4 shiftwidth=4",
      "overlay": ":set et ts=4 sw=4"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Expand tab converts tabs to spaces, tab stop sets the visual width, shift width sets the indent step."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "comment": "--- Demo: add a new indented line ---"
    },
    {
      "say": "Go to the end and add a new line. The tab key inserts four spaces.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "G"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "o"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "tab"
    },
    {
      "wait": 0.3
    },
    {
      "type": "x = 42"
    },
    {
      "wait": 0.5
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "say": "Spaces, not a tab character. Python needs this."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: show short forms ---"
    },
    {
      "say": "The short forms are E T, T S, and S W. Most developers set these in their config.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set et? ts? sw?",
      "overlay": ":set et? ts? sw?"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Question mark queries each — E-T, T-S, S-W."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "comment": "--- Wrap up ---"
    },
    "enter",
    {
      "say": "Expand tab, tab stop, shift width. The trio that controls indentation."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "Ekuk195xpQU",
    "url": "https://youtube.com/watch?v=Ekuk195xpQU"
  }
}
