{
  "title": "VimFu — Tag to Quote in Two Steps",
  "description": "In nvim-surround, {key:c}{key:s}{key:t} opens the tag prompt. To turn a tag into quotes, delete the tag with {key:d}{key:s}{key:t}, then add quotes.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 676,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f detag.html .detag.html.swp .detag.html.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "detag.html",
      "content": "<em>hello</em>\n<strong>world</strong>"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim detag.html"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Tag to Quote in Two Steps",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "In nvim-surround, {key:c}{key:s}{key:t} opens the tag prompt. It does not change tags to quotes."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Use two steps instead. First delete the em tag with {key:d}{key:s}{key:t}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "dst"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "dst"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Now add double quotes around the word with {key:y}{key:s}{key:i}{key:w}{key:\"}.",
      "wait": false
    },
    {
      "overlay": "ysiw\""
    },
    {
      "wait": 0.8
    },
    {
      "keys": "ysiw\""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Line one is quoted. Line two: delete the strong tag, then add single quotes.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j0fw",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "dst"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "dst"
    },
    {
      "wait": 0.8
    },
    {
      "overlay": "ysiw'"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "ysiw'"
    },
    {
      "wait": 0.8
    },
    {
      "say": "No tag prompt, no stray prompt text. Delete the tag, then surround the remaining text with quotes."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f detag.html"
    }
  ],
  "youtube": {
    "videoId": "oWD_0mfi6tM",
    "url": "https://youtube.com/watch?v=oWD_0mfi6tM"
  }
}
