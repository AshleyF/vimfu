{
  "title": "VimFu — Change Tag to Quote",
  "description": "cst\" changes an HTML tag pair to quotes.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 676,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f detag.html .detag.html.swp .detag.html.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "detag.html",
      "content": "<em>hello</em>\n<strong>world</strong>"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim detag.html"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change Tag to Quote",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "C S T followed by a quote character replaces the tag pair with quotes."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside the em tag. C S T, double quote.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cst\"",
      "overlay": "cst\""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Em tags became double quotes."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Line two. C S T, single quote.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfw",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cst'",
      "overlay": "cst'"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Strong tags became single quotes. C S T swaps tags for anything."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f detag.html"
    }
  ]
}
