{
  "title": "VimFu — Surround Entire Line on Separate Lines",
  "description": "ySS{ wraps the entire line in braces, each on its own new line.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 695,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f wrap.js .wrap.js.swp .wrap.js.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "wrap.js",
      "content": "return x + y"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim wrap.js"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "ySS — Line on Separate Lines",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Capital Y S S wraps the entire line and puts the content on a separate indented line. It's the multi-line version of Y S S."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Capital Y S S, open brace.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ySS{",
      "overlay": "ySS{"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Opening brace on top, content indented in the middle, closing brace below. A proper code block."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Capital Y S S. Wrap the line into a block. Great for JavaScript and C style code."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f wrap.js"
    }
  ]
}
