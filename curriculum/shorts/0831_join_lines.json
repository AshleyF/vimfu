{
  "title": "VimFu — :[range]j — Join Lines",
  "description": "The :j command joins a range of lines into one line. :3,5j joins lines 3-5. Add ! to skip extra spaces.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 733,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f address.txt .address.txt.swp .address.txt.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    {
      "writeFile": "address.txt",
      "content": "Jane Smith\n123 Main Street\nApartment 4B\nNew York\nNY 10001\nUSA"
    },
    { "line": "clear" },
    { "comment": "Launch nvim with line numbers" },
    { "line": "nvim -c 'set number' address.txt" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":[range]j — Join Lines", "duration": 2.0 },
    { "wait": 0.7 },
    { "comment": "--- Intro ---" },
    { "say": "Colon J joins lines together. A range of lines becomes one line." },
    { "wait": 0.3 },
    { "comment": "--- Demo 1: join a range ---" },
    { "say": "Join lines two through four. Colon two comma four j.", "wait": false },
    { "wait": 0.3 },
    { "type": ":2,4j" },
    "enter",
    { "wait": 0.6 },
    { "say": "Three lines merged into one. Spaces were added between them." },
    { "wait": 0.3 },
    { "keys": "u", "overlay": "undo" },
    { "wait": 0.5 },
    { "comment": "--- Demo 2: join without spaces ---" },
    { "say": "Add a bang for no spaces. Colon two comma four j bang.", "wait": false },
    { "wait": 0.3 },
    { "type": ":2,4j!" },
    "enter",
    { "wait": 0.6 },
    { "say": "Same lines joined, but no spaces this time. The text is smashed together." },
    { "wait": 0.3 },
    { "keys": "u", "overlay": "undo" },
    { "wait": 0.5 },
    { "comment": "--- Wrap up ---" },
    { "say": "Colon J joins lines with spaces. Colon J bang joins without spaces. Works on any range." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "comment": "Clean up" },
    { "line": "rm -f address.txt" }
  ]
}
