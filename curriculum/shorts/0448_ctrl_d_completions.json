{
  "title": "VimFu \u2014 Ctrl-D \u2014 Show Completions",
  "description": "Press Ctrl-D on the command line to list all possible completions for what you've typed so far.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 604,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "command line"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp .demo.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.py",
      "content": "# demo\nprint(\"hello\")\nprint(\"world\")\nx = 42"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Ctrl-D \u2014 Show Completions",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Control D on the command line shows all possible completions. It's like peeking at every option before choosing."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Type colon S E.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":se"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Now press Control D.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ctrl+d",
      "overlay": "completions"
    },
    {
      "wait": 0.8
    },
    {
      "say": "A list of every command starting with S E. You can see set, setfiletype, setlocal, and more."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Try it with a longer prefix. Colon S E T.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set "
    },
    {
      "wait": 0.3
    },
    {
      "type": "nu"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ctrl+d",
      "overlay": "completions"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Now it shows options starting with N U. Control D. See all your choices at once."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Control D on the command line. List every completion."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f demo.py"
    }
  ]
}
