{
  "title": "VimFu — :[range]sort — Sort Lines",
  "description": "The :sort command sorts lines alphabetically. :%sort sorts the whole file. Add a range to sort part of it.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 735,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f fruits.txt .fruits.txt.swp .fruits.txt.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file with unsorted items" },
    {
      "writeFile": "fruits.txt",
      "content": "banana\ncherry\napple\nfig\ndate\nelderberry\ngrape\nkiwi"
    },
    { "line": "clear" },
    { "comment": "Launch nvim with line numbers" },
    { "line": "nvim -c 'set number' fruits.txt" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":[range]sort — Sort Lines", "duration": 2.0 },
    { "wait": 0.7 },
    { "comment": "--- Intro ---" },
    { "say": "Colon sort arranges lines in alphabetical order." },
    { "wait": 0.3 },
    { "comment": "--- Demo 1: sort entire file ---" },
    { "say": "Sort the whole file. Colon percent sort.", "wait": false },
    { "wait": 0.3 },
    { "type": ":%sort" },
    { "wait": 1.2 },
    "enter",
    { "wait": 0.6 },
    { "say": "Alphabetical. Apple, banana, cherry, date, elderberry, fig, grape, kiwi." },
    { "wait": 0.3 },
    { "keys": "u", "overlay": "undo" },
    { "wait": 0.5 },
    { "comment": "--- Demo 2: sort a range ---" },
    { "say": "Sort just the first four lines. Colon one comma four sort.", "wait": false },
    { "wait": 0.3 },
    { "type": ":1,4sort" },
    { "wait": 1.2 },
    "enter",
    { "wait": 0.6 },
    { "say": "Only the first four lines were sorted. The rest stayed in place." },
    { "wait": 0.3 },
    { "keys": "u", "overlay": "undo" },
    { "wait": 0.5 },
    { "comment": "--- Wrap up ---" },
    { "say": "Colon sort. Alphabetical ordering. Use percent for the whole file, or a range for part of it." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    { "wait": 1.2 },
    "enter",
    { "comment": "Clean up" },
    { "line": "rm -f fruits.txt" }
  ]
}
