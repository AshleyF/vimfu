{
  "title": "VimFu — Ctrl-X Ctrl-L Line Completion",
  "description": "Ctrl-X Ctrl-L in insert mode completes entire lines matching what you've typed.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 527,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "insert mode",
    "completion"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\nprint(\"hello world\")\nprint(\"goodbye world\")\nresult = 42\n"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-X Ctrl-L — Line Complete",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control X Control L completes entire lines. Start typing, and Vim finds matching lines from the file."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: complete a line ---"
    },
    {
      "say": "Go to the end and start a new line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "Go",
      "overlay": "open at end"
    },
    {
      "wait": 0.3
    },
    {
      "type": "pri",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "say": "Control X Control L to complete the whole line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0018\f",
      "overlay": "line complete"
    },
    {
      "wait": 0.6
    },
    {
      "say": "It found print hello world. The entire line matched. Press Control L again to cycle."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\f",
      "overlay": "next match"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Print goodbye world. Full line completion."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Control X Control L. Complete whole lines from your file. Great for duplicating similar lines with slight changes."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "z_jle5KQhIQ",
    "url": "https://youtube.com/watch?v=z_jle5KQhIQ"
  }
}
