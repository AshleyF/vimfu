{
  "title": "VimFu — :tabnew / :tabe — New Tab",
  "description": "Use :tabnew or :tabedit to open a new tab in Vim.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 796,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f main.py utils.py .*.swp .*.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo files" },
    { "writeFile": "main.py", "content": "# Main file\ndef main():\n    print(\"main\")" },
    { "writeFile": "utils.py", "content": "# Utilities\ndef helper():\n    return 42" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim main.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":tabnew / :tabe — New Tab", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "Vim has tabs. Each tab can hold one or more windows. Use tab new to open a new tab." },
    { "wait": 0.3 },
    { "comment": "--- Demo: open new empty tab ---" },
    { "say": "Open a new empty tab.", "wait": false },
    { "wait": 0.3 },
    { "type": ":tabnew", "overlay": ":tabnew" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "A tab bar appeared at the top. Two tabs now. The new one is empty." },
    { "wait": 0.3 },
    { "comment": "--- Demo: open file in new tab ---" },
    { "say": "Open a file in a new tab with tab edit.", "wait": false },
    { "wait": 0.3 },
    { "type": ":tabe utils.py", "overlay": ":tabe utils.py" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Three tabs. Each shows a different file. The tab bar shows all the filenames." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Tab new for empty tab. Tab edit with a filename to open a file in a new tab." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":qa!" },
    "enter",
    { "line": "rm -f main.py utils.py" }
  ]
}
