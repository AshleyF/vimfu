{
  "title": "VimFu — gQ Ex Mode",
  "description": "gQ enters Ex mode, a line-oriented command mode. It's like being stuck in the colon command line. Type visual to get back.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 418,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "g commands",
    "ex mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f batch.txt .batch.txt.swp .batch.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "batch.txt",
      "content": "apple\nbanana\ncherry\ndate\nelderberry"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim batch.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "gQ — Ex Mode",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "G shift Q enters ex mode. Every command you type is an ex command. Like being permanently on the colon command line."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: enter ex mode ---"
    },
    {
      "say": "G shift Q.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gQ",
      "overlay": "enter Ex mode"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Now every line is a command. Print line one.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": "1p"
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Apple. Run a substitution.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": "%s/cherry/mango/"
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Replaced cherry with mango. No colon needed, we're already in command mode."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: exit ex mode ---"
    },
    {
      "say": "Type visual to go back to normal Vim.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": "visual"
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Back to normal mode. The change is there. Mango replaced cherry."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "G shift Q for ex mode. Type visual to get back. Mostly a historical curiosity, but useful for batch scripting."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f batch.txt"
    }
  ],
  "youtube": {
    "videoId": "Afq2HPOA-dI",
    "url": "https://youtube.com/watch?v=Afq2HPOA-dI"
  }
}
