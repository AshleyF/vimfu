{
  "title": "VimFu \u2014 Visual Join",
  "description": "Use visual {key:J} to join a selected block of lines, such as a pasted paragraph with hard breaks.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 594,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "visual mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f note.md .note.md.swp .note.md.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "note.md",
      "content": "The retry worker\ncaught up after the deploy\nand payment webhooks are current.\n\nKeep this line separate."
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim note.md"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "visual join",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "If a simple command already names the range, use it. Visual {key:J} is for a block you want to see first."
    },
    {
      "wait": 0.3
    },
    {
      "say": "After pasting prose with hard breaks, select the paragraph and join just that block.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "vip",
      "overlay": "select paragraph"
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:J} turns those selected lines into one sentence. The line after the blank stays separate.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "J",
      "overlay": "join paragraph"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Use visual join when seeing the block is clearer than naming or counting it."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f note.md"
    }
  ]
}
