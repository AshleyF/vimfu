{
  "title": "VimFu \u2014 Ctrl-O in Insert Mode",
  "description": "Press Ctrl-O in insert mode to execute one normal-mode command without leaving insert mode.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 631,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
