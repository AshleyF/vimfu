{
  "title": "VimFu — Delete with Count",
  "description": "{key:2}{key:d}{key:s}{key:)} deletes two enclosing parenthesis levels. {key:2}{key:d}{key:s}{key:t} deletes two enclosing tag levels.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 669,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f nested.py .nested.py.swp .nested.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "nested.py",
      "content": "one = ((x + y) * z)\ntwo = ((x + y) * z)\nhtml1 = <div><span>hi</span></div>\nhtml2 = <div><span>hi</span></div>"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim nested.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete with Count",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "A count before {key:d}{key:s} deletes that many enclosing surrounds, moving outward through nested structures."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Line one: {key:d}{key:s}{key:)} removes one parenthesis level.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fx",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "ds)"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "ds)"
    },
    {
      "wait": 0.8
    },
    {
      "say": "The outer pair remains. Line two: {key:2}{key:d}{key:s}{key:)} removes two parenthesis levels.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfx",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "2ds)"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "2ds)",
      "overlay": ""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Compare the two lines. One level leaves outer parentheses; two levels removes both."
    },
    {
      "say": "Tags work the same way. Line three: {key:d}{key:s}{key:t} removes the inner span tag.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "dst"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "dst",
      "overlay": ""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Line four: {key:2}{key:d}{key:s}{key:t} removes the span and the outer div."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "2dst"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "2dst",
      "overlay": ""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Counted delete is not outer-only. It deletes one level, then the next level outward."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f nested.py"
    }
  ],
  "youtube": {
    "videoId": "L-S1mkQsz1M",
    "url": "https://youtube.com/watch?v=L-S1mkQsz1M"
  }
}
