{
  "title": "VimFu — Delete with Count",
  "description": "2ds) targets the 2nd enclosing parentheses. 2dst targets the 2nd enclosing tag.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 669,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f nested.py .nested.py.swp .nested.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "nested.py",
      "content": "val = ((x + y))\nhtml = <div><p>hi</p></div>"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim nested.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete with Count",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "A count before D S targets the Nth enclosing pair. Useful for nested structures."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Double parens around x plus y. D S paren removes the inner pair.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fx",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds)",
      "overlay": "ds)"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Inner parens gone, outer still there. Undo.",
      "wait": false
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Now two D S paren to target the outer pair.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2ds)",
      "overlay": "2ds)"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Outer parens removed, inner still there."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Tags too. Two D S T on the nested tags.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2dst",
      "overlay": "2dst"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Outer div removed, inner p tag stays. Count lets you reach outward."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f nested.py"
    }
  ]
}
