{
  "title": "VimFu — Ctrl-O One Normal Command",
  "description": "Ctrl-O in insert mode lets you run one normal mode command, then returns to insert mode.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 509,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "insert mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo File\ngreet()\n    print(\"hello\")\n    print(\"world\")\n    return True\n"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-O — One Normal Command",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "{key:Ctrl-O} lets you run one normal mode command without leaving insert mode. One shot, then back to typing."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: fix greet() into a real def ---"
    },
    {
      "say": "Move down to the broken function and insert at the start of the line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": "down"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "I",
      "overlay": "insert at start"
    },
    {
      "wait": 0.3
    },
    {
      "type": "def ",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now {key:Ctrl-O} then dollar to jump to the end of the line, without leaving insert.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u000f$",
      "overlay": "end of line"
    },
    {
      "wait": 0.5
    },
    {
      "type": ":",
      "overlay": ""
    },
    {
      "wait": 0.4
    },
    {
      "say": "The function is fixed. {key:Ctrl-O} ran dollar, then dropped us back in insert mode to add the colon."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.4
    },
    {
      "comment": "--- Demo 2: expand string, then dd the redundant print ---"
    },
    {
      "say": "Now let's expand the first print to hello world, and remove the redundant second print.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j$",
      "overlay": "down, end of line"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "F\"",
      "overlay": "back to quote"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "i",
      "overlay": "insert"
    },
    {
      "wait": 0.3
    },
    {
      "type": " world",
      "overlay": ""
    },
    {
      "wait": 0.4
    },
    {
      "say": "Now {key:Ctrl-O} J to step down, then {key:Ctrl-O} D D to delete the duplicate line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u000fj",
      "overlay": "Ctrl-O j"
    },
    {
      "wait": 0.4
    },
    {
      "keys": "\u000fdd",
      "overlay": "Ctrl-O dd"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Duplicate gone. Still in insert mode, ready to keep typing."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "{key:Ctrl-O}. Run one normal mode command from insert. Jump, delete, yank. One shot, then back to insert."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "lqS_HH-aZz8",
    "url": "https://youtube.com/watch?v=lqS_HH-aZz8"
  }
}
