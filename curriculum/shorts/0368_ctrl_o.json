{
  "title": "VimFu \u2014 Ctrl-O One Normal Command",
  "description": "Ctrl-O in insert mode lets you run one normal mode command, then returns to insert mode.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 509,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "insert mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo File\ndef greet():\n    print(\"hello\")\n    print(\"world\")\n    return True"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-O \u2014 One Normal Command",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control O lets you run one normal mode command without leaving insert mode. Type it, it runs, and you're back in insert."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: jump to end of line ---"
    },
    {
      "say": "Enter insert mode on line two.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": "down"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "i",
      "overlay": "insert mode"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now Control O, then dollar to jump to the end of the line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u000f$",
      "overlay": "end of line"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Cursor moved to the end. Still in insert mode. Keep typing.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":",
      "overlay": ""
    },
    {
      "wait": 0.4
    },
    {
      "comment": "--- Demo 2: delete a line ---"
    },
    {
      "say": "Control O again. This time D D to delete a line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u000fdd",
      "overlay": "delete line"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Line deleted. Still in insert mode. One command, then right back to typing."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Control O. Run one normal mode command from insert mode. Jump, delete, yank. One shot, then back to insert."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ]
}
