{
  "title": "VimFu — Delete Arbitrary Surroundings",
  "description": "ds| ds* ds_ — any punctuation character works symmetrically as a surrounding pair.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 667,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f marks.md .marks.md.swp .marks.md.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "marks.md",
      "content": "Use *bold* text\nUse _italic_ text\nUse |column| data"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim marks.md"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete Arbitrary Surroundings",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Surround works with any punctuation character, not just brackets and quotes. If a character appears on both sides, D S can remove it."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Asterisks around bold. D S asterisk.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fb",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds*",
      "overlay": "ds*"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Asterisks gone."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Underscores around italic. D S underscore.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfi",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds_",
      "overlay": "ds_"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Underscores removed."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Pipes around column. D S pipe.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfc",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds|",
      "overlay": "ds|"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Any symmetric character works with D S."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f marks.md"
    }
  ],
  "youtube": {
    "videoId": "9xCce3yKk_0",
    "url": "https://youtube.com/watch?v=9xCce3yKk_0"
  }
}
