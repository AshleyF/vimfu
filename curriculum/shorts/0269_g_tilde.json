{
  "title": "VimFu — g~ Toggle Case",
  "description": "g~ toggles the case of text covered by a motion. Uppercase becomes lowercase and vice versa.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 410,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "g commands", "case"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f flip.py .flip.py.swp .flip.py.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    { "writeFile": "flip.py", "content": "# Case Flipper\nname = \"Alice\"\nMODE = \"debug\"\nTitle = \"Hello World\"\nprint(name)" },
    { "line": "clear" },
    { "line": "nvim flip.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": "g~ — Toggle Case", "duration": 2.0 },
    { "wait": 0.7 },
    { "comment": "--- Intro ---" },
    { "say": "G tilde toggles case. Uppercase becomes lowercase, lowercase becomes uppercase. It's an operator, so give it a motion." },
    { "wait": 0.3 },
    { "comment": "--- Demo 1: toggle a word ---" },
    { "say": "Line two. Cursor on Alice. G tilde W.", "wait": false },
    { "wait": 0.3 },
    { "keys": "2Gf\"l", "overlay": "on Alice" },
    { "wait": 0.3 },
    { "keys": "g~w", "overlay": "toggle word" },
    { "wait": 0.5 },
    { "say": "Alice became a LICE. Capital A flipped to lowercase, lowercase letters flipped to uppercase." },
    { "wait": 0.3 },
    { "comment": "--- Demo 2: toggle whole line ---" },
    { "say": "G tilde tilde toggles the whole line.", "wait": false },
    { "wait": 0.3 },
    { "keys": "3G", "overlay": "line 3" },
    { "wait": 0.3 },
    { "keys": "g~~", "overlay": "toggle line" },
    { "wait": 0.5 },
    { "say": "MODE was uppercase, now mode is lowercase. Debug was lowercase, now uppercase." },
    { "wait": 0.3 },
    { "comment": "--- Demo 3: tilde for single char ---" },
    { "say": "And remember, plain tilde without G toggles one character at a time.", "wait": false },
    { "wait": 0.3 },
    { "keys": "4G0", "overlay": "line 4" },
    { "wait": 0.3 },
    { "keys": "~", "overlay": "toggle one" },
    { "wait": 0.3 },
    { "keys": "~", "overlay": "toggle one" },
    { "wait": 0.5 },
    { "say": "One character per press." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "G tilde with a motion. Toggle case across a range. Tilde alone for one character at a time." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f flip.py" }
  ]
}
