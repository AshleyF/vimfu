    },
    {
      "wait": 0.3
    },
    {
      "keys": "gg",
      "overlay": "top"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now G J.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gj",
      "overlay": "one screen row"
    },
    {
      "wait": 0.4
    },
    {
