    },
    {
      "wait": 0.3
    },
    {
      "keys": "gj",
      "overlay": "gj"
    },
    {
      "wait": 0.4
    },
    {
      "keys": "gj",
      "overlay": "gj"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Moving through the wrapped text one row at a time. Still on logical line two."
