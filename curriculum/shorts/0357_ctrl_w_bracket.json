{
  "title": "VimFu \u2014 Ctrl-W ] Split Tag",
  "description": "Ctrl-W ] splits the window and jumps to the tag definition of the word under the cursor. Requires ctags.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 498,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "windows",
    "splits",
    "ctags"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f spell.py tags .spell.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "spell.py",
      "content": "# Spell System\ndef fireball(target):\n    return target - 40\n\ndef icebolt(target):\n    return target - 25\n\n# Cast spells\ndmg1 = fireball(100)\ndmg2 = icebolt(100)"
    },
    {
      "comment": "Create a tags file with proper tab separation"
    },
    {
      "line": "printf '%s\\t%s\\t%s\\n' fireball spell.py 2 icebolt spell.py 5 > tags"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim spell.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-W ] \u2014 Split Tag",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control W right bracket splits the window and jumps to the tag definition. It uses a tags file generated by C tags."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: jump to fireball tag ---"
    },
    {
      "say": "Move to where fireball is called.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "9G",
      "overlay": "line 9"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "w",
      "overlay": "next word"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "w",
      "overlay": "to fireball"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor on fireball. Split and jump to its tag.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "w",
      "overlay": "split to tag"
    },
    {
      "keys": "\u001d"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Split opened at the fireball definition. Tags make this work across multiple files too."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Close split ---"
    },
    {
      "keys": "\u0017c",
      "overlay": "close"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Control W right bracket. Split and tag jump. Generate tags with C tags, then navigate your codebase in splits."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f spell.py tags"
    }
  ]
}
