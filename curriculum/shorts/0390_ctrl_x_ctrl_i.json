{
  "title": "VimFu — Ctrl-X Ctrl-I Identifier Complete",
  "description": "Ctrl-X Ctrl-I in insert mode completes identifiers from included files and the current file.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 531,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "insert mode",
    "completion"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\nfirst_value = 10\nfinal_result = 20\nfigure_out = 30\nx = "
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-X Ctrl-I — Identifiers",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control X Control I completes identifiers. It scans the current file and any included files for identifier-like words."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: complete an identifier ---"
    },
    {
      "say": "Go to the last line and type a prefix.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "4jA",
      "overlay": "last line, append"
    },
    {
      "wait": 0.3
    },
    {
      "type": "fi",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "say": "Control X Control I.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0018\t",
      "overlay": "identifiers"
    },
    {
      "wait": 0.6
    },
    {
      "say": "All identifiers starting with F I. First value, final result, figure out."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Control X Control I. Identifier completion from the file and includes. Similar to Control N but scans more broadly."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "EeeHno5iw9k",
    "url": "https://youtube.com/watch?v=EeeHno5iw9k"
  }
}
