{
  "title": "VimFu — :{range}= Show Line Number",
  "description": "Use :.= to show the current line number, or :$= for the last line number.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 752,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    { "writeFile": "demo.txt", "content": "alpha\nbeta\ngamma\ndelta\nepsilon\nzeta\neta\ntheta\niota\nkappa" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim demo.txt" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":.= :$= — Show Line Number", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "Dot equals shows the current line number. Dollar equals shows the last line." },
    { "wait": 0.3 },
    { "comment": "--- Demo 1: current line ---" },
    { "say": "Move to line five and check with dot equals.", "wait": false },
    { "wait": 0.3 },
    { "keys": "4j", "overlay": "move to line 5" },
    { "wait": 0.3 },
    { "type": ":.=", "overlay": ":.=" },
    { "wait": 0.3 },
    { "keys": "enter" },
    { "wait": 0.8 },
    { "say": "Five. That's the current line number." },
    { "wait": 0.3 },
    { "comment": "--- Demo 2: last line ---" },
    { "say": "Now dollar equals for the last line.", "wait": false },
    { "wait": 0.3 },
    { "type": ":$=", "overlay": ":$=" },
    { "wait": 0.3 },
    { "keys": "enter" },
    { "wait": 0.8 },
    { "say": "Ten. The file has ten lines. Dollar always means the last line." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Dot equals for the current line number. Dollar equals for the last." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f demo.txt" }
  ]
}
