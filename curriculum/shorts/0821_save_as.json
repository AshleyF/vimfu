  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":sav {file} — Save As", "duration": 2.0 },
    { "wait": 0.7 },
    { "comment": "--- Intro ---" },
    { "say": "Colon sav saves to a new filename and switches to it. Like Save As in other editors." },
    { "wait": 0.3 },
    { "comment": "--- Demo ---" },
    { "say": "We are editing report dot T X T. Save as report V two dot T X T.", "wait": false },
    { "wait": 0.3 },
    { "type": ":sav report_v2.txt" },
    "enter",
    { "wait": 0.6 },
    { "say": "Look at the status bar. We are now editing report V two. The original report dot T X T still exists on disk." },
    { "wait": 0.3 },
    { "comment": "--- Explain difference from :w ---" },
    { "say": "Unlike colon W with a filename, colon sav switches you to the new file. Colon W keeps you on the original." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Colon sav. Save as a new name and continue editing that new file." },
    { "wait": 1.5 }
