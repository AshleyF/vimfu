{
  "title": "VimFu — :v/{pattern}/{cmd} Inverse Global",
  "description": "The :v command (or :g!) is the inverse of :g. It executes a command on lines that do NOT match the pattern.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 767,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.txt",
      "content": "keep: apple\nremove this\nkeep: banana\njunk line\nkeep: cherry\nmore junk\nkeep: date"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":v/{pattern}/{cmd} — Inverse Global",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Colon V is the inverse of colon G. It acts on lines that don't match the pattern."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: type the command, narrate while it's on the cmdline, then commit ---"
    },
    {
      "say": "Let's delete every line that doesn't contain the word keep.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":v/keep/d",
      "overlay": ":v/keep/d"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Colon V is the inverse of colon G. Slash keep slash is the pattern. D for delete. So this deletes the lines that don't match."
    },
    {
      "wait": 0.4
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Three junk lines deleted. Only the lines with keep remain."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon V. The inverse global. Think of it as keep the matches, act on the rest."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.txt"
    }
  ],
  "youtube": {
    "videoId": "RvOt1lVtefA",
    "url": "https://youtube.com/watch?v=RvOt1lVtefA"
  }
}
