{
  "title": "VimFu — The Black Hole Register",
  "description": "Double-quote underscore sends deleted text into the void. Nothing goes to any register. Use it to delete without overwriting your yank.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 1240,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "registers"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f items.py .items.py.swp .items.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*items.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "items.py",
      "content": "keep = \"gold\"\njunk = \"trash\"\ncopy = \"none\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim items.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "The Black Hole Register",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Double-quote underscore is the black hole register. Anything you delete into it just disappears. No register gets overwritten."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: normal delete clobbers the yank ---"
    },
    {
      "say": "Yank the first line. Then delete the junk line with D D.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "yy",
      "overlay": "yy  yank line"
    },
    {
      "wait": 0.4
    },
    {
      "keys": "j",
      "overlay": ""
    },
    {
      "wait": 0.2
    },
    {
      "keys": "dd",
      "overlay": "dd  delete line"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Now paste. We wanted the gold line, but watch what happens.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "p",
      "overlay": "p  put"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Junk. The delete overwrote our yank."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Undo and redo with black hole ---"
    },
    {
      "say": "Undo and try again. This time delete with double-quote underscore D D.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "uu",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gg",
      "overlay": ""
    },
    {
      "wait": 0.2
    },
    {
      "keys": "yy",
      "overlay": "yy  yank line"
    },
    {
      "wait": 0.4
    },
    {
      "keys": "j",
      "overlay": ""
    },
    {
      "wait": 0.2
    },
    {
      "keys": "\"_dd",
      "overlay": "\"_dd  delete to black hole"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Now paste.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "p",
      "overlay": "p  put"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Gold. The black hole register ate the delete. Our yank stayed safe."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Double-quote underscore. The black hole register. Delete without clobbering your clipboard."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f items.py"
    }
  ],
  "youtube": {
    "videoId": "JYNf_t5jJbU",
    "url": "https://youtube.com/watch?v=JYNf_t5jJbU"
  }
}
