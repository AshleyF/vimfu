{
  "title": "VimFu — zw Mark Word Incorrect",
  "description": "zw marks a word as incorrect in your spell file. Vim will flag it as misspelled from now on.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 451,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "spelling",
    "z commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f rules.txt .rules.txt.swp .rules.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Use a fresh temp spellfile so demo is independent of any persistent user dictionary"
    },
    {
      "line": "rm -f /tmp/vimfu-spell.add /tmp/vimfu-spell.add.spl"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "rules.txt",
      "content": "We really need to ship this.\nIt was very easy to fix.\nNever hardcode passwords here.\nAlways sanitize form data."
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with spell checking"
    },
    {
      "line": "nvim -c 'set spellfile=/tmp/vimfu-spell.add' -c 'set spell' rules.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "zw — Mark Word Incorrect",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Z W marks a word as incorrect. Even if the dictionary thinks it's fine, you can flag it."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: mark really ---"
    },
    {
      "say": "The word really is valid English. But style guides ban it as a filler. Z W to flag it.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "w",
      "overlay": "to really"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "zw",
      "overlay": "mark incorrect"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Now really is highlighted as misspelled. Your personal style rule."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: mark very ---"
    },
    {
      "say": "Flag very too.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j02w",
      "overlay": "to very"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "zw",
      "overlay": "mark incorrect"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Very is flagged. Vim will highlight it every time you open a file."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Z W. Mark words as bad. The opposite of Z G. Build your own banned word list."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f rules.txt ~/.config/nvim/spell/en.utf-8.add ~/.config/nvim/spell/en.utf-8.add.spl"
    }
  ],
