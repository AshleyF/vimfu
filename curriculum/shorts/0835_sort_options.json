{
  "title": "VimFu — :[range]sort Options",
  "description": "The :sort command has options: n for numeric sort, u for unique lines only, i for case-insensitive.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 737,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f mixed.txt .mixed.txt.swp .mixed.txt.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file with mixed content" },
    {
      "writeFile": "mixed.txt",
      "content": "item 10\nitem 2\nApple\napple\nitem 30\nBanana\nbanana\nitem 1\nApple\nitem 20"
    },
    { "line": "clear" },
    { "comment": "Launch nvim with line numbers" },
    { "line": "nvim -c 'set number' mixed.txt" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":[range]sort Options", "duration": 2.0 },
    { "wait": 0.7 },
    { "comment": "--- Intro ---" },
    { "say": "The sort command has useful options. N for numeric, U for unique, and I for case insensitive." },
    { "wait": 0.3 },
    { "comment": "--- Demo 1: numeric sort ---" },
    { "say": "Normal sort puts item ten before item two because one comes before two alphabetically. Use N for numeric.", "wait": false },
    { "wait": 0.3 },
    { "type": ":%sort n" },
    { "wait": 1.2 },
    "enter",
    { "wait": 0.6 },
    { "say": "Numeric order. Item one, two, ten, twenty, thirty. The numbers are sorted correctly." },
    { "wait": 0.3 },
    { "keys": "u", "overlay": "undo" },
    { "wait": 0.5 },
    { "comment": "--- Demo 2: unique ---" },
    { "say": "Sort U removes duplicate lines.", "wait": false },
    { "wait": 0.3 },
    { "type": ":%sort u" },
    { "wait": 1.2 },
    "enter",
    { "wait": 0.6 },
    { "say": "Duplicates removed. Each line appears only once." },
    { "wait": 0.3 },
    { "keys": "u", "overlay": "undo" },
    { "wait": 0.5 },
    { "comment": "--- Demo 3: case insensitive ---" },
    { "say": "Sort I ignores case. Apple and apple sort together.", "wait": false },
    { "wait": 0.3 },
    { "type": ":%sort i" },
    { "wait": 1.2 },
    "enter",
    { "wait": 0.6 },
    { "say": "Case insensitive. Apple and apple are next to each other regardless of capitalization." },
    { "wait": 0.3 },
    { "keys": "u", "overlay": "undo" },
    { "wait": 0.5 },
    { "comment": "--- Wrap up ---" },
    { "say": "Sort N for numbers. Sort U for unique. Sort I for case insensitive. You can combine them too." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    { "wait": 1.2 },
    "enter",
    { "comment": "Clean up" },
    { "line": "rm -f mixed.txt" }
  ]
}
