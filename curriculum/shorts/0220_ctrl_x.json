{
  "title": "VimFu — Ctrl-X",
  "description": "Ctrl-X decrements the number at or after the cursor. Use a count to decrement by more.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 361,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "keyboard"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp .demo.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*demo.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.py",
      "content": "lives = 9\narmor = 20\nround = 100"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-X",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control X decrements the number at or after the cursor. The opposite of control A."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: simple decrement ---"
    },
    {
      "say": "Line one. Lives equals nine. Press control X.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "x",
      "overlay": "decrement"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Nine became eight. One press, minus one."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: decrement with count ---"
    },
    {
      "say": "Go to line two. Type five, then control X.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j0"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "5",
      "overlay": "count 5"
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "x",
      "overlay": "decrement"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Armor dropped from twenty to fifteen. The count subtracts five."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 3: cursor finds next number ---"
    },
    {
      "say": "Line three, cursor on R. Control X finds the number.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j0"
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "x",
      "overlay": "decrement"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Round went from one hundred to ninety nine. Vim finds the next number on the line automatically."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Control X. Decrement a number. Pair it with control A to adjust values fast."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "etYJxM4tIFQ",
    "url": "https://youtube.com/watch?v=etYJxM4tIFQ"
  }
}
