{
  "title": "VimFu — Ctrl-H",
  "description": "Ctrl-H moves left one character, same as h. Also acts as backspace in insert mode and at the command line.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 381,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "keyboard"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f grid.py .grid.py.swp .grid.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*grid.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "grid.py",
      "content": "row = \"ABCDEFGH\"\ncol = \"12345678\"\npos = \"E4\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim grid.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-H",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control H moves left, same as H. In insert mode, it acts as backspace."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: move left in normal mode ---"
    },
    {
      "say": "Move to the end of line one. Now control H to go left.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "$",
      "overlay": "$  end of line"
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "h",
      "overlay": "left"
    },
    {
      "wait": 0.4
    },
    {
      "ctrl": "h",
      "overlay": "left"
    },
    {
      "wait": 0.4
    },
    {
      "ctrl": "h",
      "overlay": "left"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Three characters left. Identical to pressing H three times."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: in insert mode it's backspace ---"
    },
    {
      "say": "In insert mode, control H is backspace. Enter insert mode at the end of line three.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2j",
      "overlay": ""
    },
    {
      "wait": 0.2
    },
    {
      "keys": "A",
      "overlay": "A  append at end"
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "h",
      "overlay": "backspace"
    },
    {
      "wait": 0.4
    },
    {
      "ctrl": "h",
      "overlay": "backspace"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Deleted two characters backward. Control H is the original backspace. It predates the backspace key."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u001b",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "u  undo"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Control H. Left in normal mode, backspace in insert mode. A relic from the days before keyboards had a backspace key."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f grid.py"
    }
  ],
