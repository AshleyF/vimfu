{
  "title": "VimFu — :norm with Insert Mode",
  "description": "Use :norm with I to insert text at the beginning of lines. Normal mode keys that enter insert mode work inside :norm.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 760,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp .demo.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.py",
      "content": "start server\nload config\ncheck database\nopen ports\nbegin listening"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":norm with Insert Mode",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Colon norm can enter insert mode. Use capital I to prepend text to every line."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: type the command, narrate while it's on the cmdline, then commit ---"
    },
    {
      "say": "Let's comment out every line by prepending a hash and a space.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":%norm I# ",
      "overlay": ":%norm I# "
    },
    {
      "wait": 0.6
    },
    {
      "say": "Percent means every line. Capital I enters insert mode at the very start of the line. Then we type a hash and a space — the comment prefix."
    },
    {
      "wait": 0.4
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Every line is now commented out."
    },
    {
      "wait": 0.4
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Norm with I. Prepend text to every line. Great for commenting or adding prefixes."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "m9SYrWx6PEg",
    "url": "https://youtube.com/watch?v=m9SYrWx6PEg"
  }
}
