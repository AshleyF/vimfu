{
  "title": "VimFu \u2014 Ctrl-W Prefix",
  "description": "Ctrl-W is the window command prefix. Follow it with another key to split, navigate, resize, or close windows.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 379,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "keyboard"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f panel.py .panel.py.swp .panel.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*panel.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "panel.py",
      "content": "# Dashboard\n\ntitle = \"Mission Control\"\nstatus = \"online\"\nalerts = 0\nuptime = 99.9"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim panel.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-W Prefix",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control W is the window command prefix. It doesn't do anything by itself. You follow it with another key."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: horizontal split ---"
    },
    {
      "say": "Control W S splits horizontally.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "w",
      "overlay": "window..."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "s",
      "overlay": "split"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Two panes, same file. Top and bottom."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: navigate between windows ---"
    },
    {
      "say": "Control W W switches between them.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "w",
      "overlay": "window..."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "w",
      "overlay": "next window"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Moved to the bottom window. Control W W cycles through all windows."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 3: close window ---"
    },
    {
      "say": "Control W C closes the current window.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "w",
      "overlay": "window..."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "c",
      "overlay": "close window"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Back to one window. S to split, W to navigate, C to close. All start with control W."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Control W. The window prefix. We'll cover each window command in detail later."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f panel.py"
    }
  ],
  "youtube": {
    "videoId": "Nkh5qmnj-Fg",
    "url": "https://youtube.com/watch?v=Nkh5qmnj-Fg"
  }
}
