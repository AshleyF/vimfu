{
  "title": "VimFu — g< — Previous Output",
  "description": "Use g< to redisplay the output of the previous command that was shown at the bottom of the screen.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 653,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "advanced"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f output.txt .output.txt.swp .output.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "output.txt",
      "content": "one\ntwo\nthree\nfour\nfive"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim output.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "g< — Previous Output",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Sometimes command output disappears before you can read it. g less-than brings back the last page."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Run `:version`. It prints a page of information and waits at the hit-enter prompt.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":version",
      "beforeEnter": 1.0
    },
    {
      "wait": 1.0
    },
    {
      "say": "Dismiss it with Enter. Now the output is gone."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "say": "Press g less-than to see that last page again.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "g<",
      "overlay": "previous output"
    },
    {
      "wait": 0.8
    },
    {
      "say": "The previous command output is displayed again. Press Enter to dismiss it."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.3
    },
    {
      "say": "g less-than recalls the last page of command output."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f output.txt"
    }
  ],
  "youtube": {
    "videoId": "4uPRKgrM7VA",
    "url": "https://youtube.com/watch?v=4uPRKgrM7VA"
  }
}
