{
  "title": "VimFu — The Current Line .",
  "description": "In Ex commands, the dot . means the current line. :.d deletes the current line.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 707,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f data.txt .data.txt.swp .data.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "data.txt",
      "content": "line 1 — alpha\nline 2 — bravo\nline 3 — charlie\nline 4 — delta\nline 5 — echo\nline 6 — foxtrot\nline 7 — golf\nline 8 — hotel\nline 9 — india\nline 10 — juliet\nline 11 — kilo\nline 12 — lima"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers"
    },
    {
      "line": "nvim -c 'set number' data.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "The Current Line — Dot",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "In Ex commands, the dot means the current line. Whatever line the cursor is on."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: move to line 5, delete with dot ---"
    },
    {
      "say": "Move to line five.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":5"
    },
    {
      "wait": 1.0
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "say": "Now type colon dot d. Delete the current line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":.d"
    },
    {
      "wait": 1.0
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Line five is gone. The dot referred to whatever line the cursor was on."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Undo ---"
    },
    {
      "say": "Undo to bring it back.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.6
    },
    {
      "comment": "--- Demo 2: dot in a range ---"
    },
    {
      "say": "Dot also works in ranges. Colon dot comma dot plus three d. Delete from here to three lines below.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":.,.+3d"
    },
    {
      "wait": 1.2
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Four lines deleted. Dot meant the current line, and dot plus three meant three lines after it."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Dot equals the current line. Use it in any Ex command that takes a range."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f data.txt"
    }
  ],
  "youtube": {
    "videoId": "yyTVzEiPr08",
    "url": "https://youtube.com/watch?v=yyTVzEiPr08"
  }
}
