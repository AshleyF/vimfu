{
  "title": "VimFu — Surround — Leading Space Only",
  "description": "ysiws adds a leading space before the word but no trailing space.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 693,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f lead.txt .lead.txt.swp .lead.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "lead.txt",
      "content": "hello world\nfoo bar"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim lead.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Leading Space Only",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Lowercase S as the surround character adds a leading space before the surrounded region. No trailing space, just a space in front."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Y S I W S. Add a leading space before the word.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fw",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiws",
      "overlay": "ysiws"
    },
    {
      "wait": 0.8
    },
    {
      "say": "A space was added before world. Useful for inserting padding."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "S for space. A simple but useful surround target."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f lead.txt"
    }
  ]
}
