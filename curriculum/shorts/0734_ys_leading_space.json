{
  "title": "VimFu — Delete with s Alias",
  "description": "{key:d}{key:s}{key:s} deletes the nearest common surround, using {key:s} as an alias set.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 693,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f lead.txt .lead.txt.swp .lead.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "lead.txt",
      "content": "one = (hello)\ntwo = \"world\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim lead.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete with s Alias",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "For deleting and changing, {key:s} is an alias for common surrounds: brackets, parens, braces, angle brackets, and quotes."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside parentheses. {key:d}{key:s}{key:s} deletes the nearest surround from that alias set.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "dss"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "dss"
    },
    {
      "wait": 0.8
    },
    {
      "say": "The parentheses are gone. Line two uses the same {key:d}{key:s}{key:s} command on quotes.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfw",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "dss"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "dss"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Same command, different surround. {key:s} picks the nearest matching pair from the alias set."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f lead.txt"
    }
  ],
