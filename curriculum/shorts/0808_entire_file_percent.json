{
  "title": "VimFu — The Entire File %",
  "description": "The percent sign % means the entire file. It is shorthand for 1,$. :%d deletes everything.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 710,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f records.txt .records.txt.swp .records.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "records.txt",
      "content": "line 1 — alpha\nline 2 — bravo\nline 3 — charlie\nline 4 — delta\nline 5 — echo\nline 6 — foxtrot\nline 7 — golf\nline 8 — hotel\nline 9 — india\nline 10 — juliet\nline 11 — kilo\nline 12 — lima"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers"
    },
    {
      "line": "nvim -c 'set number' records.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "The Entire File — %",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Percent means the entire file. It is shorthand for one comma dollar. First line to last line."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: delete everything ---"
    },
    {
      "say": "Colon percent d. Delete every line in the file.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":%d"
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Everything is gone. The buffer is empty."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Undo brings it all back. Percent is incredibly useful."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Explain ---"
    },
    {
      "say": "You will see percent a lot. Percent yank copies the whole file. Percent substitute does a find and replace on every line."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Percent equals the entire file. One of the most common range specifiers in Vim."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f records.txt"
    }
  ],
  "youtube": {
    "videoId": "YZmQd4c66To",
    "url": "https://youtube.com/watch?v=YZmQd4c66To"
  }
}
