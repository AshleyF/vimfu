  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f tasks.txt .tasks.txt.swp .tasks.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "tasks.txt",
      "content": "line 1 — buy apples\nline 2 — fix the bug\nline 3 — call Mom\nline 4 — send invoice\nline 5 — water plants\nline 6 — clean kitchen\nline 7 — read chapter 5\nline 8 — update resume\nline 9 — walk the dog\nline 10 — write tests"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers"
    },
    {
      "line": "nvim -c 'set number' tasks.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
