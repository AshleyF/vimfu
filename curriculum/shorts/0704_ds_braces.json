{
  "title": "VimFu — Delete Surrounding Braces",
  "description": "ds} or dsB removes curly braces around the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 663,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f braces.js .braces.js.swp .braces.js.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "braces.js",
      "content": "let obj = {name: \"Kai\"}\nlet set = {1, 2, 3}\nlet map = {a: 1}"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim braces.js"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete Surrounding Braces",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "D S close brace deletes the surrounding curly braces. D S capital B is the alias."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside the braces. D S close brace.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fn",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds}",
      "overlay": "ds}"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Braces removed."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Line two. D S capital B.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jf1",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "dsB",
      "overlay": "dsB"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Same result. D S brace or D S capital B."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f braces.js"
    }
  ],
  "youtube": {
    "videoId": "hwT1Q5LnBx8",
    "url": "https://youtube.com/watch?v=hwT1Q5LnBx8"
  }
}
