{
  "title": "VimFu \u2014 [( ]) Unmatched Parens",
  "description": "[( jumps to the previous unmatched opening parenthesis. ]) jumps to the next unmatched closing parenthesis.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 458,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "bracket commands",
    "navigation"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f calc.py .calc.py.swp .calc.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with nested parens"
    },
    {
      "writeFile": "calc.py",
      "content": "# Damage Calculator\nresult = max(\n    base_attack * (\n        1 + crit_bonus\n    ),\n    min_damage\n)"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers"
    },
    {
      "line": "nvim -c 'set number' calc.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "[( ]) \u2014 Unmatched Parens",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Open bracket open paren jumps to the nearest unmatched opening paren above. Close bracket close paren jumps to the unmatched closing paren below."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: jump to enclosing paren with [( ---"
    },
    {
      "say": "Cursor is inside nested parentheses on line four. Open bracket open paren to find the enclosing paren.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "4G",
      "overlay": "go to line 4"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "[(",
      "overlay": "enclosing paren"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Jumped to the inner opening paren on line three. Hit it again.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "[(",
      "overlay": "outer paren"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Now at the outer paren on line two. Each jump finds the next unmatched paren up."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: jump forward with ]) ---"
    },
    {
      "say": "Close bracket close paren goes the other way.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "])",
      "overlay": "closing paren"
    },
    {
      "wait": 0.5
    },
    {
      "keys": "])",
      "overlay": "outer closing"
    },
    {
      "wait": 0.6
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Open bracket open paren and close bracket close paren. Jump between unmatched parentheses. Great for nested expressions."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f calc.py"
    }
  ]
}
