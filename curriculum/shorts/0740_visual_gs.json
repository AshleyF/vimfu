{
  "title": "VimFu — Visual gS",
  "description": "{key:g}{key:S} in visual mode surrounds the selection on separate lines.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 699,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f gs.js .gs.js.swp .gs.js.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "gs.js",
      "content": "const total = value;\nconsole.log(total);"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim gs.js"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Visual gS",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:S} surrounds a visual selection inline. {key:g}{key:S} surrounds that same selection on separate lines."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Select the JavaScript value.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fvviw",
      "overlay": "v → select"
    },
    {
      "wait": 0.5
    },
    {
      "keys": "S}"
    },
    {
      "wait": 0.8
    },
    {
      "say": "{key:S}{key:}} keeps the surround inline."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Undo, then {key:g}{key:v} reselects the exact same expression. Now use {key:g}{key:S}{key:}}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gv"
    },
    {
      "wait": 0.5
    },
    {
      "keys": "gS}"
    },
    {
      "wait": 0.8
    },
    {
      "say": "{key:g}{key:S} puts the braces on separate lines around that same selection."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Use {key:S} for inline visual surround. Use {key:g}{key:S} when the surrounding pair belongs on its own lines."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f gs.js"
    }
  ],
  "youtube": {
    "videoId": "lBCsOWTnUok",
    "url": "https://youtube.com/watch?v=lBCsOWTnUok"
  }
}
