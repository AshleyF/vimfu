  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f config.py .config.py.swp .config.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "config.py",
      "content": "# Config\n\nDEBUG = True\nVERBOSE = False\nMAX_RETRIES = 3\nTIMEOUT = 30\n\ndef load():\n    print(\"Config loaded\")"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim config.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Canceling a Command",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "If you start typing a colon command and change your mind, press Escape. Nothing will happen."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: cancel a delete ---"
    },
    {
      "say": "Watch. I'll type colon delete, then cancel.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":delete"
    },
    {
      "wait": 0.6
    },
    {
      "say": "I typed colon delete. But I changed my mind. Escape.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "say": "Nothing happened. The file is untouched."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: cancel a quit ---"
    },
    {
      "say": "Again. Start typing a quit command.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":q"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Wait, not yet. Escape.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "say": "Safe. Still in the editor."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Escape cancels any colon command. If you're not sure, just press Escape. No harm done."
