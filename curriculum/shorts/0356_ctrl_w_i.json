{
  "title": "VimFu \u2014 Ctrl-W i Split Declaration",
  "description": "Ctrl-W i splits the window and jumps to the declaration of the word under the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 497,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
