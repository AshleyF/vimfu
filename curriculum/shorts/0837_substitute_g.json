{
  "title": "VimFu — :s Flag g — All on Line",
  "description": "The g flag on :s replaces ALL occurrences on the line, not just the first one.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 739,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with repeated words"
    },
    {
      "writeFile": "demo.txt",
      "content": "foo bar foo baz foo\nold old old old old\nno repeats here"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":s Flag g — All on Line",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Without the G flag, colon S only replaces the first match. The G flag replaces all of them."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: without g flag ---"
    },
    {
      "say": "Line one has foo three times. Without G, only the first is replaced.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":s/foo/NEW/",
      "overlay": ":s/foo/NEW/"
    },
    {
      "wait": 1.2
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.6
    },
    {
      "say": "One replacement. Two foo's remain."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: with g flag ---"
    },
    {
      "say": "Now line two. Old appears five times. Use the G flag.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": "down"
    },
    {
      "wait": 0.3
    },
    {
      "type": ":s/old/new/g",
      "overlay": ":s/old/new/g"
    },
    {
      "wait": 1.2
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.6
    },
    {
      "say": "All five replaced in one command. The G flag means global across the line."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Add G at the end of your substitute command to replace every occurrence on the line."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.txt"
    }
  ],
  "youtube": {
    "videoId": "ds22V4ToEdY",
    "url": "https://youtube.com/watch?v=ds22V4ToEdY"
  }
}
