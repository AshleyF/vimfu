{
  "title": "VimFu — :pwd — Current Directory",
  "description": "Use :pwd to display the current working directory in Vim.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 811,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    { "writeFile": "demo.txt", "content": "hello world" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim demo.txt" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":pwd — Current Directory", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "P W D shows the current working directory. Same as the shell command but inside Vim." },
    { "wait": 0.3 },
    { "comment": "--- Demo: show pwd ---" },
    { "say": "Check where we are.", "wait": false },
    { "wait": 0.3 },
    { "type": ":pwd", "overlay": ":pwd" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "The working directory. This affects relative paths in commands like colon edit and colon write." },
    { "wait": 0.3 },
    { "comment": "--- Demo: change and check ---" },
    { "say": "Change directory with colon C D and check again.", "wait": false },
    { "wait": 0.3 },
    "enter",
    { "type": ":cd /tmp", "overlay": ":cd /tmp" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.3 },
    { "type": ":pwd", "overlay": ":pwd" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Now in temp. Colon P W D confirms the change." },
    { "wait": 0.3 },
    "enter",
    { "comment": "--- Wrap up ---" },
    { "say": "Colon P W D. Know where you are. Important for relative file paths." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f demo.txt" }
  ]
}
