{
  "title": "VimFu — :undolist Undo Info",
  "description": "View the undo tree with :undolist.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 582,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":undolist",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "Undo list shows the leaves of your undo tree. Vim tracks undo as a tree, not just a list."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Make some changes to create undo history.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "oalpha",
      "overlay": "open line"
    },
    "escape",
    {
      "wait": 0.2
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "obeta",
      "overlay": "open line"
    },
    "escape",
    {
      "wait": 0.3
    },
    {
      "say": "Check the undo tree.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":undolist",
      "overlay": ":undolist"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "say": "Each line is a branch. The undo tree lets you reach any previous state."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\r",
      "overlay": ""
    },
    {
      "say": "Undo list. See the full history of your editing branches."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "NrihsILMfzk",
    "url": "https://youtube.com/watch?v=NrihsILMfzk"
  }
}
