{
  "title": "VimFu — Ctrl-F — Edit Command",
  "description": "Press Ctrl-F while on the command line to open it in an editable window, where you can use all of Vim's editing power.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 616,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "command line"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f sample.py .sample.py.swp .sample.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "sample.py",
      "content": "# sample\nfoo = 1\nbar = 2\nbaz = 3\nqux = 4"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim sample.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Ctrl-F — Edit Command",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Control F opens the command line in a full editing window. You can use all your normal mode skills to edit the command."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Start typing a long substitute command.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":%s/foo/bar/g"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Now press Control F.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ctrl+f",
      "overlay": "edit window"
    },
    {
      "wait": 0.8
    },
    {
      "say": "The command opens in a buffer. You can see the full command history above. Use any Vim motions to edit the current line."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Change bar to baz using C I W.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "Fb"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "ciw",
      "overlay": "change word"
    },
    {
      "wait": 0.3
    },
    {
      "type": "baz"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Press Enter to execute the edited command.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Foo became baz. We edited the command with full Vim power before running it."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Control F on the command line. Edit commands with Vim's full editing power."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f sample.py"
    }
  ],
  "youtube": {
    "videoId": "lfF5OF_E9kU",
    "url": "https://youtube.com/watch?v=lfF5OF_E9kU"
  }
}
