{
  "title": "VimFu — :noh Clear Search Highlighting",
  "description": "After a search or substitute, :noh clears the highlighted matches until the next search.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 746,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.py .demo.py.swp .demo.py.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    { "writeFile": "demo.py", "content": "def hello():\n    print(\"hello\")\n    return \"hello\"\n\ndef world():\n    print(\"world\")" },
    { "line": "clear" },
    { "comment": "Launch nvim with hlsearch" },
    { "line": "nvim -c 'set hlsearch' demo.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":noh — Clear Search Highlighting", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "After searching, matches stay highlighted. Colon no H clears them." },
    { "wait": 0.3 },
    { "comment": "--- Demo 1: search creates highlights ---" },
    { "say": "Search for hello. Every match gets highlighted.", "wait": false },
    { "wait": 0.3 },
    { "type": "/hello", "overlay": "/hello" },
    { "wait": 0.3 },
    { "keys": "enter" },
    { "wait": 0.8 },
    { "say": "Three matches are highlighted in yellow. That can be distracting." },
    { "wait": 0.3 },
    { "comment": "--- Demo 2: clear with :noh ---" },
    { "say": "Type colon no H to turn off the highlights.", "wait": false },
    { "wait": 0.3 },
    { "type": ":noh", "overlay": ":noh" },
    { "wait": 0.3 },
    { "keys": "enter" },
    { "wait": 0.8 },
    { "say": "Clean. The highlights are gone. They'll come back on your next search." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Colon no H. Clear search highlighting. Many people map this to a key for quick access." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f demo.py" }
  ]
}
