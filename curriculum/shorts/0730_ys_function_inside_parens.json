{
  "title": "VimFu — Delete Function Call",
  "description": "{key:d}{key:s}{key:f} removes a surrounding function call and keeps the arguments.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 689,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f lisp.el .lisp.el.swp .lisp.el.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "lisp.el",
      "content": "result = print(value)\noutput = len(name)"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim lisp.el"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete Function Call",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Lowercase {key:f} is the function-call surround. {key:d}{key:s}{key:f} removes the function name and parentheses, but keeps the arguments."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside `print(value)`. Press {key:d}{key:s}{key:f}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fv",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "dsf"
    },
    {
      "wait": 0.8
    },
    {
      "say": "`print(value)` became just `value`. Line two: do the same to `len(name)`.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfn",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "dsf"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Now both function wrappers are gone and both arguments remain."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f lisp.el"
    }
  ],
  "youtube": {
    "videoId": "F_T8E7ZyNh8",
    "url": "https://youtube.com/watch?v=F_T8E7ZyNh8"
  }
}
