{
  "title": "VimFu — Function Inside Parens",
  "description": "ysiw<C-f>print↵ wraps the word with the function name inside the parens: (print word).",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 689,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f lisp.el .lisp.el.swp .lisp.el.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "lisp.el",
      "content": "result = value\noutput = name"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim lisp.el"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Function Inside Parens",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Control F places the function name inside the parentheses. This is the Lisp style. Instead of print paren word paren, you get open paren print space word close paren."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Y S I W, control F, type print, enter.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fv",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw\u0006",
      "overlay": "ysiw<C-f>"
    },
    {
      "wait": 0.3
    },
    {
      "type": "print"
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Open paren, print, space, value, close paren. Function name inside the parens."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Useful for Lisp, Scheme, or any S expression style code."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f lisp.el"
    }
  ]
}
