{
  "title": "VimFu — gt gT Tab Navigation",
  "description": "gt and gT switch between Vim tab pages. gt goes to the next tab, gT goes to the previous tab. Use a count to jump to a specific tab.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 407,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "g commands",
    "tabs"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f app.py config.py test.py .*.swp .*.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo files"
    },
    {
      "writeFile": "app.py",
      "content": "# Main App\ndef run():\n    print(\"Running...\")"
    },
    {
      "writeFile": "config.py",
      "content": "# Config\nDEBUG = True\nPORT = 8080"
    },
    {
      "writeFile": "test.py",
      "content": "# Tests\ndef test_run():\n    assert True"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim -p app.py config.py test.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "gt gT — Tab Navigation",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "G T and G shift T switch between Vim tabs. We opened three files in tabs with the dash P flag."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: gt to next tab ---"
    },
    {
      "say": "G T. Go to the next tab.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gt",
      "overlay": "next tab"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Now we're on config dot py. G T again.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gt",
      "overlay": "next tab"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Test dot py. One more G T wraps around to the first tab.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gt",
      "overlay": "wrap around"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Demo 2: gT to previous tab ---"
    },
    {
      "say": "G shift T goes the other way. Previous tab.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gT",
      "overlay": "previous tab"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Demo 3: count + gt ---"
    },
    {
      "say": "Use a count. Two G T jumps to tab two.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2gt",
      "overlay": "tab 2"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Direct jump. No cycling needed."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "G T and G shift T. Cycle through tabs. Add a count to jump directly."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":qa!"
    },
    "enter",
    {
      "line": "rm -f app.py config.py test.py"
    }
  ],
