{
  "title": "VimFu — :vs — Vertical Split",
  "description": "Use :vsplit (:vs) to split the window vertically, side by side.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 802,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f left.py right.py .*.swp .*.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo files"
    },
    {
      "writeFile": "left.py",
      "content": "# Left file\ndef left():\n    return 1"
    },
    {
      "writeFile": "right.py",
      "content": "# Right file\ndef right():\n    return 2"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim left.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":vs — Vertical Split",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "V split creates a vertical split — two windows side by side."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: vsplit with another file ---"
    },
    {
      "say": "Open right dot py next to the current file."
    },
    {
      "type": ":vs right.py",
      "overlay": ":vs right.py"
    },
    {
      "wait": 0.4
    },
    {
      "say": "V S — short for vertical split — places the new file alongside the current one."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Side by side. Perfect for comparing files. Use control W H and control W L to move between them."
    },
    {
      "keys": "ctrl+w"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "h"
    },
    {
      "wait": 0.5
    },
    {
      "keys": "ctrl+w"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "l"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon V split or colon V S. Vertical side-by-side windows."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":qa!"
    },
    "enter",
    {
      "line": "rm -f left.py right.py"
    }
  ],
  "youtube": {
    "videoId": "cnCevMcdPB8",
    "url": "https://youtube.com/watch?v=cnCevMcdPB8"
  }
}
