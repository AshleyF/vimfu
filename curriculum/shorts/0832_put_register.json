{
  "title": "VimFu — :pu {reg} — Put Register",
  "description": "The :pu command inserts the contents of a register below the current line. :pu! inserts above.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 734,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f parts.txt .parts.txt.swp .parts.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "parts.txt",
      "content": "line 1 — header\nline 2 — navigation\nline 3 — sidebar\nline 4 — content\nline 5 — footer"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers"
    },
    {
      "line": "nvim -c 'set number' parts.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":pu {reg} — Put Register",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Colon P U inserts the contents of a register below the current line. It's an Ex version of paste."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: yank into register, then :pu ---"
    },
    {
      "say": "First, yank line one into register A.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":1y a"
    },
    {
      "wait": 1.2
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "say": "Now move to line three. Put register A below.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":3"
    },
    {
      "wait": 1.2
    },
    "enter",
    {
      "wait": 0.3
    },
    {
      "type": ":pu a"
    },
    {
      "wait": 1.2
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Header was inserted after line three."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Demo: :pu! above ---"
    },
    {
      "say": "Use the bang to put above instead of below. Colon P U bang A.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":3"
    },
    {
      "wait": 1.2
    },
    "enter",
    {
      "wait": 0.3
    },
    {
      "type": ":pu! a"
    },
    {
      "wait": 1.2
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Inserted above line three this time."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon P U inserts below. Colon P U bang inserts above. Specify a register or use the default."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    {
      "wait": 1.2
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f parts.txt"
    }
  ],
