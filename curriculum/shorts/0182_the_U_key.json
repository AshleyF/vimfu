{
  "title": "VimFu — The U Key",
  "description": "In Neovim, capital U in normal mode undoes all changes on the current line. In visual mode, it converts text to uppercase.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 323,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "keyboard"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f badge.py .badge.py.swp .badge.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*badge.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "badge.py",
      "content": "name = \"hero\"\nrank = \"rookie\"\nteam = \"alpha squad\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim badge.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "The U Key",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Capital U has two powers. In normal mode, it undoes all changes on the current line. In visual mode, it uppercases text."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: visual U to uppercase ---"
    },
    {
      "say": "Uppercase hero. Visual select it, then capital U.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "f\"l",
      "overlay": ""
    },
    {
      "wait": 0.2
    },
    {
      "keys": "ve",
      "overlay": "select word"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "U",
      "overlay": "uppercase"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Hero became HERO. All caps."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: visual U on a whole line ---"
    },
    {
      "say": "Select the whole value on line three. Visual, then U.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2jf\"l",
      "overlay": ""
    },
    {
      "wait": 0.2
    },
    {
      "keys": "vi\"",
      "overlay": "select inner \""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "U",
      "overlay": "uppercase"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Alpha squad became ALPHA SQUAD. Visual select plus capital U. Quick uppercase."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Capital U. In visual mode, uppercase your selection. Combine with any visual selection for instant caps."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f badge.py"
    }
  ],
  "youtube": {
    "videoId": "sIJ9QmqXFrk",
    "url": "https://youtube.com/watch?v=sIJ9QmqXFrk"
  }
}
