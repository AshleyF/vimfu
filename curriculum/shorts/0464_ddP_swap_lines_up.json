{
  "title": "VimFu — ddkP — Swap Lines Up",
  "description": "Use ddkP to move the current line up one position. dd deletes the line, k moves to the previous line, and P puts it above.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 620,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "practical"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f order.txt .order.txt.swp .order.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "order.txt",
      "content": "first\nsecond\nthird\nfourth\nfifth"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim order.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "ddkP — Swap Lines Up",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:d}{key:d}{key:k}{key:P} moves the current line up one. {key:d}{key:d} deletes, {key:k} moves up, and {key:P} puts it above."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Move to the third line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2j"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now type {key:d}{key:d}{key:k}{key:P}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ddkP",
      "overlay": "swap up"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Third moved above second. It bubbled up one line."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Reset to the original order, then try on fourth.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2u",
      "overlay": "undo both edits"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": "fourth line"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ddkP",
      "overlay": "swap up"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Fourth moved above third. Use {key:d}{key:d}{key:p} to move down; add {key:k}{key:P} to move up."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f order.txt"
    }
  ],
  "youtube": {
    "videoId": "SOjlfZEHOlc",
    "url": "https://youtube.com/watch?v=SOjlfZEHOlc"
  }
}
