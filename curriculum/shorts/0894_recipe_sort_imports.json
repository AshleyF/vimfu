{
  "title": "VimFu — Recipe: Sort Imports",
  "description": "Use :1,6sort to sort just the import lines at the top of a file, leaving the rest untouched.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 830,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "recipes"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f imports.py .imports.py.swp .imports.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with unsorted imports"
    },
    {
      "writeFile": "imports.py",
      "content": "import sys\nimport json\nimport os\nimport re\nimport math\nimport csv\n\ndef main():\n    pass"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim imports.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Recipe: Sort Imports",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "These imports are in random order. Let's sort just the import block without touching the rest of the file."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Show line numbers ---"
    },
    {
      "say": "Turn on line numbers to see the range."
    },
    {
      "type": ":set number",
      "overlay": ":set number"
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "comment": "--- Sort import lines ---"
    },
    {
      "say": "Sort just the import lines."
    },
    {
      "type": ":1,6sort",
      "overlay": ":1,6sort"
    },
    {
      "wait": 0.4
    },
    {
      "say": "One comma six sort. Apply sort to lines one through six only — everything below stays put."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Imports are now alphabetical. The main function below is untouched."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon range sort. Sort any section of a file by specifying the line range."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f imports.py"
    }
  ],
