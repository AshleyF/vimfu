{
  "title": "VimFu — Useless Underscore Remap",
  "description": "The _ key is redundant with ^. Remap it to something useful like inserting a space.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 658,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "advanced",
    "remap"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "name   Alice\nrole Dev\ncity  Paris"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Remap _ (Underscore)",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "The underscore key moves to the first non-blank character. But caret already does that. Underscore is redundant."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Remap it to insert a space before the cursor. Handy when text needs a little manual alignment.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":nnoremap _ i <Esc>",
      "overlay": ":nnoremap _ i <Esc>",
      "beforeEnter": 1.2
    },
    {
      "wait": 0.5
    },
    {
      "say": "Now underscore inserts one space before the cursor and stays in normal mode.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j0w",
      "overlay": "role"
    },
    {
      "keys": "_",
      "overlay": "insert space"
    },
    {
      "keys": "_",
      "overlay": "insert space"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j0w",
      "overlay": "city"
    },
    {
      "keys": "_",
      "overlay": "insert space"
    },
    {
      "wait": 0.3
    },
    {
      "say": "A couple of taps lines the values up. One key, one space, no mode switching. Underscore is free real estate."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "Qh7SBKDKm5o",
    "url": "https://youtube.com/watch?v=Qh7SBKDKm5o"
  }
}
