{
  "title": "VimFu \u2014 z= in Practice",
  "description": "z= workflow: navigate to a misspelled word, see suggestions, and apply the fix. Full spelling correction flow.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 457,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "spelling",
    "z commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f report.txt .report.txt.swp .report.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with misspellings"
    },
    {
      "writeFile": "report.txt",
      "content": "The missle launch was a succss.\nAll systms are operatonal now.\nThe engne passed every tst.\nFinal reivew is complet."
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with spell checking"
    },
    {
      "line": "nvim -c 'set spell' report.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "z= in Practice",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Let's fix a whole document. Use close bracket S to jump to each typo and one Z equals to fix it."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: fix missle ---"
    },
    {
      "say": "Jump to the first typo.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "]s",
      "overlay": "next typo"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "1z=",
      "overlay": "fix spelling"
    },
    {
      "wait": 0.6
    },
    {
      "comment": "--- Demo 2: fix succss ---"
    },
    {
      "say": "Next one.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "]s",
      "overlay": "next"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "1z=",
      "overlay": "fix spelling"
    },
    {
      "wait": 0.6
    },
    {
      "comment": "--- Demo 3: fix systms ---"
    },
    {
      "say": "And the next.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "]s",
      "overlay": "next"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "1z=",
      "overlay": "fix spelling"
    },
    {
      "wait": 0.6
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Close bracket S to find typos. Z equals to fix them. A fast spelling workflow built into Vim."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f report.txt"
    }
  ]
}
