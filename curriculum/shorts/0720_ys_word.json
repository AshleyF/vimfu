{
  "title": "VimFu — Surround a Word",
  "description": "ysiw) wraps the inner word in parentheses. The core surround-add command.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 679,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f wrap.py .wrap.py.swp .wrap.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "wrap.py",
      "content": "name = hello\nval = world\nkey = data"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim wrap.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Surround a Word",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Y S adds a surrounding. Y S, then a motion, then the character. Y S I W close paren wraps the word in parentheses."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor on hello. Y S I W close paren.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw)",
      "overlay": "ysiw)"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Hello is wrapped in parentheses. Tight, no spaces."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Try quotes. Y S I W double quote.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw\"",
      "overlay": "ysiw\""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Wrapped in double quotes."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Brackets. Y S I W close bracket.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfw",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw]",
      "overlay": "ysiw]"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Y S I W. You surround inner word. The most common surround command."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f wrap.py"
    }
  ],
  "youtube": {
    "videoId": "uC5CsBAMFB8",
    "url": "https://youtube.com/watch?v=uC5CsBAMFB8"
  }
}
