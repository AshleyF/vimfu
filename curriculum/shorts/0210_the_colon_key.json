{
  "title": "VimFu — The : Key",
  "description": "Colon enters command-line mode. From here you can run Ex commands: save, quit, substitute, set options, and much more.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 351,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
