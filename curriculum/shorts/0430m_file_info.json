{
  "title": "VimFu — Ctrl-G / :file File Info",
  "description": "Show file name, status, and cursor position.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 584,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\nprint(\"hello\")\nprint(\"world\")\nx = 42\ny = 99"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Ctrl-G — File Info",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "{key:Ctrl-G} shows the file name, modification status, line count, and cursor position."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jj",
      "overlay": "move down"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ctrl+g",
      "overlay": "Ctrl-G"
    },
    {
      "wait": 0.5
    },
    {
      "say": "It shows the filename, which line you're on, total lines, and percentage through the file."
    },
    {
      "wait": 0.3
    },
    {
      "say": "`:file` shows the same information through an Ex command."
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":file",
      "overlay": ":file",
      "beforeEnter": 1.4
    },
    {
      "wait": 0.8
    },
    {
      "say": "Same file name, same position, same quick status check."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "6HyTZCutcII",
    "url": "https://youtube.com/watch?v=6HyTZCutcII"
  }
}
