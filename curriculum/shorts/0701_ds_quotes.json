{
  "title": "VimFu — Delete Surrounding Quotes",
  "description": "{key:d}{key:s}{key:\"} removes double quotes around the cursor. The same pattern works for other surroundings.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 660,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f quotes.py .quotes.py.swp .quotes.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "quotes.py",
      "content": "name = \"Alice\"\nlabel = 'hero'\ncmd = `ls -la`"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim quotes.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete Surrounding Quotes",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:d}{key:s}{key:\"} deletes the surrounding double quotes. Your cursor just needs to be inside them."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor is on line one, inside the quotes. {key:d}{key:s}{key:\"}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "f\"",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "ds\"",
      "duration": 0.8
    },
    {
      "keys": "ds\""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Both quotes removed. The text stays."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Line two has single quotes. {key:d}{key:s}{key:'}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jf'",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "ds'",
      "duration": 0.8
    },
    {
      "keys": "ds'"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Single quotes gone."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Backticks on line three. {key:d}{key:s}{key:`}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jf`",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "ds`",
      "duration": 0.8
    },
    {
      "keys": "ds`"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Gone. The same {key:d}{key:s} pattern also removes parentheses, brackets, braces, tags, and more."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f quotes.py"
    }
  ],
  "youtube": {
    "videoId": "pxkb3RQZdfI",
    "url": "https://youtube.com/watch?v=pxkb3RQZdfI"
  }
}
