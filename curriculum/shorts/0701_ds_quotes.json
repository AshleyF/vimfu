{
  "title": "VimFu — Delete Surrounding Quotes",
  "description": "ds\" removes double quotes around the cursor. Works with single quotes and backticks too.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 660,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f quotes.py .quotes.py.swp .quotes.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "quotes.py",
      "content": "name = \"Alice\"\nlabel = 'hero'\ncmd = `ls -la`"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim quotes.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete Surrounding Quotes",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "D S quote deletes the surrounding double quotes. Your cursor just needs to be inside them."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor is on line one, inside the quotes. D S double quote.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "f\"",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds\"",
      "overlay": "ds\""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Both quotes removed. The text stays."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Line two has single quotes. D S single quote.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jf'",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds'",
      "overlay": "ds'"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Single quotes gone."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Backticks on line three. D S backtick.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jf`",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds`",
      "overlay": "ds`"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Gone. D S works with any quote character."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f quotes.py"
    }
  ]
}
