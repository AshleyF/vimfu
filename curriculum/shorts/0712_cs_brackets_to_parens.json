{
  "title": "VimFu — Change Brackets to Parens",
  "description": "cs]) changes square brackets to parentheses around the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 671,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f convert.py .convert.py.swp .convert.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "convert.py",
      "content": "items = [1, 2, 3]\ncoord = [x, y]\ndata = {a: 1}"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim convert.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change Brackets to Parens",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "C S lets you swap any bracket type for another. C S bracket, paren changes square brackets to parentheses."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside the brackets. C S close bracket, close paren.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "f1",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs])",
      "overlay": "cs])"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Brackets became parentheses."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Braces to brackets. C S close brace, close bracket.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jjfa",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs}]",
      "overlay": "cs}]"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Braces became brackets. C S changes any pair to any other pair."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f convert.py"
    }
  ],
  "youtube": {
    "videoId": "A_WbEiC_eZs",
    "url": "https://youtube.com/watch?v=A_WbEiC_eZs"
  }
}
