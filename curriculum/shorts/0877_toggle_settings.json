{
  "title": "VimFu — Toggling Settings with no Prefix",
  "description": "Turn off boolean settings by prefixing with 'no', e.g., :set nonumber, :set nohlsearch.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 779,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp .demo.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.py",
      "content": "def one():\n    return 1\n\ndef two():\n    return 2\n\ndef three():\n    return 3"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Toggling with :set noX",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Every boolean setting can be turned off by adding N O in front. Set number turns it on. Set no number turns it off."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: toggle number ---"
    },
    {
      "say": "Turn on line numbers.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set number",
      "overlay": ":set number"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Set number — turn line numbers on."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Now turn them off with set no number.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set nonumber",
      "overlay": ":set nonumber"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Set no number — N-O prefix turns the same option off."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Gone. You can also use an exclamation mark to toggle. Set number bang flips the value.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: bang toggle (flip on) ---"
    },
    {
      "type": ":set number!",
      "overlay": ":set number!"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Bang at the end toggles — flip the current value."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "comment": "--- Demo: bang toggle (flip off) ---"
    },
    {
      "type": ":set number!",
      "overlay": ":set number!"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Toggle again to flip back."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Bang toggles on and off. Works with any boolean setting."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Set no X turns off. Set X bang toggles. Two ways to control boolean settings."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "HPVDHjRupHE",
    "url": "https://youtube.com/watch?v=HPVDHjRupHE"
  }
}
