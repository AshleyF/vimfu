{
  "title": "VimFu — Change Quotes",
  "description": "cs\"' changes double quotes to single quotes around the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 670,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f quotes.py .quotes.py.swp .quotes.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "quotes.py",
      "content": "name = \"Alice\"\ntitle = 'Hero'\npath = \"home/user\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim quotes.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change Quotes",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "C S changes one surrounding to another. C S double quote, single quote swaps double quotes to single."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside the double quotes. C S double quote, single quote.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fA",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs\"'",
      "overlay": "cs\"'"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Double quotes became single quotes."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Other direction too. Line two. C S single quote, double quote.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfH",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs'\"",
      "overlay": "cs'\""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Single quotes became double quotes."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Double to backtick. C S double quote, backtick.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs\"`",
      "overlay": "cs\"`"
    },
    {
      "wait": 0.8
    },
    {
      "say": "C S. First argument is what to find, second is the replacement."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f quotes.py"
    }
  ]
}
