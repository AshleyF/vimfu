{
  "title": "VimFu — Change — Trim Inner Space",
  "description": "cs({ — using the opening mark as target trims inner whitespace before replacing.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 673,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f trim.py .trim.py.swp .trim.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "trim.py",
      "content": "val = ( x + y )\narr = [ 1, 2, 3 ]"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim trim.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change — Trim Inner Space",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "The opening mark as target trims inner whitespace. So C S open paren targets the padded parens and strips the space."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Padded parens. C S open paren, close brace.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fx",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs(}",
      "overlay": "cs(}"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Parens became braces and the inner spaces were trimmed."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Compare. C S close paren, close brace.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs)}",
      "overlay": "cs)}"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Braces replaced parens, but the inner spaces remain. Close paren target keeps the content as is."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Opening mark as target trims space. Closing mark as target keeps space."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f trim.py"
    }
  ]
}
