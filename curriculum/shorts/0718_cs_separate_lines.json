{
  "title": "VimFu — Change on Separate Lines",
  "description": "cS\"( places the surrounded text on its own indented line.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 677,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f multi.py .multi.py.swp .multi.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "multi.py",
      "content": "val = \"x + y + z\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim multi.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change on Separate Lines",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Capital C S changes surroundings and puts the content on its own indented line. It's the multi-line version of C S."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Quotes around the expression. Capital C S, double quote, open paren.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fx",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cS\"(",
      "overlay": "cS\"("
    },
    {
      "wait": 0.8
    },
    {
      "say": "The quotes became parentheses, and the text moved to its own indented line. Opening paren above, closing paren below."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Capital C S. When you need the content on separate lines."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f multi.py"
    }
  ],
  "youtube": {
    "videoId": "xIQzg072tTg",
    "url": "https://youtube.com/watch?v=xIQzg072tTg"
  }
}
