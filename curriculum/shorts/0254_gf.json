  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f main.py utils.py .main.py.swp .main.py.swo .utils.py.swp .utils.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create target file first"
    },
    {
      "writeFile": "utils.py",
      "content": "# Utility Functions\n\ndef clamp(value, lo, hi):\n    return max(lo, min(hi, value))\n\ndef lerp(a, b, t):\n    return a + (b - a) * t"
    },
    {
      "comment": "Create main file that references utils.py"
    },
    {
      "writeFile": "main.py",
      "content": "# Main Application\nimport utils\nfrom utils import clamp\n\n# See utils.py for helpers\n\ndef run():\n    x = clamp(150, 0, 100)\n    print(f\"Clamped: {x}\")\n\nif __name__ == \"__main__\":\n    run()"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim main.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
