{
  "title": "VimFu — :!! Repeat Last Shell",
  "description": "The :!! command repeats the last shell command you ran.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 561,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "shell"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\nprint(\"test\")"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":!! — Repeat Last",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "Colon bang bang repeats the last shell command. Run it once, then repeat easily."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Run date first.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":!date",
      "overlay": ":!date"
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "keys": "enter",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now repeat it.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":!!",
      "overlay": "repeat"
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "keys": "enter",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "say": "Same command ran again. Great for running tests or builds repeatedly."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "uCPG6JqKRKI",
    "url": "https://youtube.com/watch?v=uCPG6JqKRKI"
  }
}
