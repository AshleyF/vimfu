{
  "title": "VimFu — :new New Window",
  "description": "Open a new empty window with :new.",
  "speed": 0.55, "rows": 20, "cols": 40, "humanize": 0.7, "seed": 578,
  "ttsVoice": "echo", "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "line": "export TERM=xterm-256color" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.py .demo.py.swp" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "writeFile": "demo.py", "content": "# Demo\nprint(\"hello\")\nprint(\"world\")" },
    { "line": "clear" },
    { "line": "nvim demo.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "overlay": "VimFu", "caption": ":new — New Window", "duration": 2.0 },
    { "wait": 0.7 },
    { "say": "Colon new opens a new empty window above. It creates an unnamed buffer you can start typing in." },
    { "wait": 0.3 },
    { "type": ":new", "overlay": ":new" }, "enter",
    { "wait": 0.5 },
    { "say": "A new split appeared. The buffer has no name yet. You can type and save it later with colon W filename." },
    { "wait": 0.3 },
    { "say": "Colon vnew does the same but with a vertical split. Quick scratch pads." },
    { "wait": 1.5 }
  ],
  "teardown": [ "escape", { "type": ":qa!" }, "enter", { "line": "rm -f demo.py" } ]
}
