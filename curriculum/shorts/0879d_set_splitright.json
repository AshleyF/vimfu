{
  "title": "VimFu — :set splitright",
  "description": "Use :set splitright (or :set spr) to make vertical splits open to the right.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 785,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.py .demo.py.swp .demo.py.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    { "writeFile": "demo.py", "content": "def main():\n    print(\"hi\")\n    return 0\n\nmain()" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim demo.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":set splitright", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "By default, vertical splits open to the left. Set split right makes new splits open to the right instead." },
    { "wait": 0.3 },
    { "comment": "--- Demo: enable and vsplit ---" },
    { "say": "Set it and create a vertical split.", "wait": false },
    { "wait": 0.3 },
    { "type": ":set splitright", "overlay": ":set splitright" },
    { "wait": 0.6 },
    { "say": "Set split right — new vertical splits will open to the right of the current window." },
    { "wait": 0.4 },
    "enter",
    { "wait": 0.5 },
    { "type": ":vsplit", "overlay": ":vsplit" },
    { "wait": 0.6 },
    { "say": "Create a vertical split and watch the new window appear on the right." },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "The new window opened to the right. Cursor is in the right pane. This matches how most people expect splits to work." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Set split right or set S P R. Pair it with set split below for natural split behavior." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":qa!" },
    "enter",
    { "line": "rm -f demo.py" }
  ]
}
