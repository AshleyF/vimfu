  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f list.py .list.py.swp .list.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*list.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "list.py",
      "content": "zebra\napple\nmango\nbanana\ncherry"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim list.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
