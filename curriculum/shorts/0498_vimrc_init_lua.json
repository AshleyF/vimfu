{
  "title": "VimFu — The vimrc / init.lua",
  "description": "Where to put your personal Vim configuration: .vimrc for Vim, init.lua (or init.vim) for Neovim.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 654,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "advanced"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f config.txt .config.txt.swp .config.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "config.txt",
      "content": "Vim Configuration Guide\nalpha\nbeta\ngamma"
    },
    {
      "writeFile": "init.lua",
      "content": "vim.opt.number = true\nvim.opt.relativenumber = true\nvim.opt.cursorline = true"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim config.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "wait": 0.8
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "The vimrc / init.lua",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Every setting and mapping you've learned can live in your config file."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Classic Vim uses `~/.vimrc`. Neovim usually uses `init.lua` in its config directory."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Here is a tiny `init.lua`: line numbers, relative numbers, and cursorline.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":edit init.lua",
      "beforeEnter": 0.8
    },
    {
      "wait": 0.8
    },
    {
      "say": "Now go back to the text file. No line numbers yet."
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":edit config.txt",
      "beforeEnter": 0.8
    },
    {
      "wait": 0.6
    },
    {
      "say": "Load that config with `:luafile init.lua`.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":luafile init.lua",
      "beforeEnter": 1.1
    },
    {
      "wait": 0.8
    },
    {
      "say": "Now the config visibly changed the editor: line numbers and relative numbers are on. Your startup config makes those choices permanent."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f config.txt init.lua"
    }
  ],
