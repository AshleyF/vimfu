  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f game.c .game.c.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with #define macros and usage"
    },
    {
      "writeFile": "game.c",
      "content": "// Game Engine\nint result = ATTACK * 2;\nint block = DEFEND + 5;\nint hp = HP_MAX;\nint base_dmg = 10;\nint base_def = 5;\n\nvoid swing(void) {\n    base_dmg += 1;\n}\n\nvoid parry(void) {\n    base_def += 1;\n}\n\nvoid rest(void) {\n    hp = HP_MAX;\n}\n\nvoid step(void) {\n    swing();\n    parry();\n}\n\nint main(void) {\n    step();\n    rest();\n    return 0;\n}\n\n#define ATTACK 25\n#define DEFEND 10\n#define HP_MAX 100"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim -c 'silent! nunmap <C-W>d' game.c"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
