{
  "title": "VimFu — :wqa / :xa — Write All + Quit",
  "description": "Use :wqa or :xa to save all modified buffers and quit Vim in one command.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 807,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f a.py b.py .*.swp .*.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo files"
    },
    {
      "writeFile": "a.py",
      "content": "print(\"a\")"
    },
    {
      "writeFile": "b.py",
      "content": "print(\"b\")"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim -o a.py b.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":wqa / :xa — Write All + Quit",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "W Q A saves all files and quits. X A is a shorter alias. One command to save everything and exit."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: explain the commands ---"
    },
    {
      "say": "You already know W A saves all, and Q A quits all. W Q A combines them. X A does the same thing with fewer keystrokes."
    },
    {
      "wait": 0.5
    },
    {
      "say": "X A only writes files that have actually been modified. If nothing changed, it skips the write."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: show the command ---"
    },
    {
      "say": "Make a change, then type X A."
    },
    {
      "keys": "o"
    },
    {
      "type": "# done"
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "type": ":xa",
      "overlay": ":xa"
    },
    {
      "wait": 0.4
    },
    {
      "say": "X A here would save and quit everything. We'll cancel to keep the demo running."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- don't actually quit, escape ---"
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon W Q A or colon X A. Save all and quit. The perfect end-of-session command."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":qa!"
    },
    "enter",
    {
      "line": "rm -f a.py b.py"
    }
  ],
  "youtube": {
    "videoId": "FsgOQ_DH4Bg",
    "url": "https://youtube.com/watch?v=FsgOQ_DH4Bg"
  }
}
