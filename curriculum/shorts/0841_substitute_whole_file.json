{
  "title": "VimFu — :%s/old/new/g Whole File",
  "description": "The % range means the entire file. :%s/old/new/g substitutes across every line.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 743,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp .demo.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.py",
      "content": "name = \"foo\"\nprint(name)\nif name == \"foo\":\n    greet(name)\n# name is foo"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":%s/old/new/g — Whole File",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Percent S is the most common way to do find and replace across an entire file."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: type the command, narrate while preview is on screen, then commit ---"
    },
    {
      "say": "The word foo appears on several lines. Let's rename it to bar everywhere.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":%s/foo/bar/g",
      "overlay": ":%s/foo/bar/g"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Percent means the entire file. The G flag means every occurrence on each line, not just the first. Neovim is previewing the matches that are about to change."
    },
    {
      "wait": 0.4
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Every foo is now bar."
    },
    {
      "wait": 0.4
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Without percent, colon S only affects the current line. Percent is the key to whole file substitution."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "YNJ77yZwPHg",
    "url": "https://youtube.com/watch?v=YNJ77yZwPHg"
  }
}
