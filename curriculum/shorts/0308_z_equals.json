{
  "title": "VimFu — z= Spelling Suggestions",
  "description": "z= shows spelling suggestions for the word under the cursor. Pick a number to replace the misspelled word.",
  "speed": 0.55,
  "rows": 24,
  "cols": 40,
  "humanize": 0.7,
  "seed": 449,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "spelling",
    "z commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f story.txt .story.txt.swp .story.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with misspellings"
    },
    {
      "writeFile": "story.txt",
      "content": "The brav knight rode into\nthe darkk forest. His sowrd\nglowed with enchantd light.\nVictory was certan."
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with spell checking"
    },
    {
      "line": "nvim -c 'set spell' -c 'set spellsuggest=best,9' story.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "z= — Spelling Suggestions",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Z equals shows spelling suggestions for the word under the cursor. A count up front skips the menu and picks directly."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: plain z= shows the menu, pick 1 ---"
    },
    {
      "say": "Brav on line one is misspelled. Press Z equals to see the suggestion menu.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "w",
      "overlay": "next word"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "z=",
      "overlay": "suggestion menu"
    },
    {
      "wait": 1.4
    },
    {
      "say": "A numbered list of candidates. Type the number and enter to pick one. One for brave.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": "1"
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Fixed. Brav is now brave."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: skip the menu with a count ---"
    },
    {
      "say": "Power-user shortcut: prefix with the number to auto-pick without seeing the menu. One Z equals.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": "next line"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "1z=",
      "overlay": "auto-pick first"
    },
    {
      "wait": 0.6
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Z equals for the menu. Count Z equals to skip it. Spell check built right into Vim."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f story.txt"
    }
  ],
  "youtube": {
    "videoId": "12VeqJpWM98",
    "url": "https://youtube.com/watch?v=12VeqJpWM98"
  }
}
