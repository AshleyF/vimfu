{
  "title": "VimFu — :set hlsearch",
  "description": "Use :set hlsearch (or :set hls) to highlight all matches when searching.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 771,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp .demo.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.py",
      "content": "def get_name():\n    name = input(\"Name: \")\n    return name\n\ndef greet(name):\n    print(f\"Hi {name}\")\n\nname = get_name()\ngreet(name)"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":set hlsearch",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "H L search highlights every match of your search pattern. It makes it easy to see all occurrences at once."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: enable hlsearch and search ---"
    },
    {
      "say": "Turn it on and search for name.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set hlsearch",
      "overlay": ":set hlsearch"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Set H-L search — highlight every match when you search."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "type": "/name",
      "overlay": "/name"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Now search for the word name."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Every occurrence of name is highlighted. You can jump between them with N and shift N."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: clear highlights ---"
    },
    {
      "say": "To clear the highlights, use no H L search.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":nohlsearch",
      "overlay": ":nohlsearch"
    },
    {
      "wait": 0.6
    },
    {
      "say": "No H-L search clears the highlights until your next search."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Highlights cleared. They come back on the next search."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Set H L search to highlight matches. No H L search to clear them. Short form is set H L S."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "ggVKXnhbhyI",
    "url": "https://youtube.com/watch?v=ggVKXnhbhyI"
  }
}
