{
  "title": "VimFu — :qa — Quit All",
  "description": "Use :qa to quit all windows. Use :qa! to force quit and discard all unsaved changes.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 805,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f a.py b.py .*.swp .*.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo files"
    },
    {
      "writeFile": "a.py",
      "content": "# File A\nprint(\"a\")"
    },
    {
      "writeFile": "b.py",
      "content": "# File B\nprint(\"b\")"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with splits"
    },
    {
      "line": "nvim -o a.py b.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":qa — Quit All",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Colon Q A quits all windows at once. If any buffer has unsaved changes, Vim will warn you. Add a bang to force quit."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: make a change then try qa ---"
    },
    {
      "say": "First, make a change in this file."
    },
    {
      "keys": "o"
    },
    {
      "type": "# changed"
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "say": "Now try to quit all."
    },
    {
      "type": ":qa",
      "overlay": ":qa"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Q A — short for quit all — tries to close every buffer."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Vim refuses. Unsaved changes. Use Q A bang to discard them and quit anyway."
    },
    {
      "type": ":qa!",
      "overlay": ":qa!"
    },
    {
      "wait": 0.4
    },
    {
      "say": "The bang forces it. Everything closes, even modified buffers."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- explanation only, don't actually quit ---"
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon Q A to quit all. Colon Q A bang to force it. The fastest way to exit everything."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":qa!"
    },
    "enter",
    {
      "line": "rm -f a.py b.py"
    }
  ],
