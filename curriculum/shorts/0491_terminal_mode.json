{
  "title": "VimFu — Terminal Mode",
  "description": "Use :term to open a terminal inside Vim and Ctrl-\\ Ctrl-N to switch back to normal mode.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 647,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "advanced"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f termtest.txt .termtest.txt.swp .termtest.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "termtest.txt",
      "content": "editing a file"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim termtest.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Terminal Mode",
      "duration": 1.2
    },
    {
      "wait": 0.2
    },
    {
      "say": "Vim and Neovim can run a terminal inside the editor. Open one with `:term`."
    },
    {
      "wait": 0.2
    },
    {
      "ex": ":term",
      "beforeEnter": 0.7
    },
    {
      "wait": 0.8
    },
    {
      "say": "The terminal buffer is open. Press {key:i} so your keys go to the shell."
    },
    {
      "wait": 0.2
    },
    {
      "keys": "i",
      "overlay": "terminal mode"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now type a shell command."
    },
    {
      "wait": 0.2
    },
    {
      "type": "echo hello from the terminal"
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "The shell ran inside Vim. To use normal-mode keys here, leave terminal mode first."
    },
    {
      "wait": 0.2
    },
    {
      "say": "Hold Control and press backslash. Then hold Control and press the N key.",
      "wait": false
    },
    {
      "wait": 0.2
    },
    {
      "keys": "ctrl+\\",
      "overlay": "Ctrl-\\"
    },
    {
      "keys": "ctrl+n",
      "overlay": "normal mode"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Now normal-mode keys work in the terminal buffer."
    },
    {
      "wait": 0.2
    },
    {
      "say": "Press {key:i} to send keys back to the shell.",
      "wait": false
    },
    {
      "wait": 0.2
    },
    {
      "keys": "i",
      "overlay": "back to terminal mode"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Control plus backslash, then Control plus the N key, exits. The {key:i} key re-enters. That's the cycle."
    },
    {
      "wait": 0.6
    }
  ],
  "teardown": [
    {
      "comment": "Exit the terminal and quit nvim"
    },
    {
      "keys": "ctrl+\\"
    },
    {
      "keys": "ctrl+n"
    },
    {
      "type": ":qa!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f termtest.txt"
    }
  ],
  "youtube": {
    "videoId": "dEEM-aZ54VY",
    "url": "https://youtube.com/watch?v=dEEM-aZ54VY"
  }
}
