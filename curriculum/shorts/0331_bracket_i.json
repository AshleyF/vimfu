{
  "title": "VimFu — [i ]i Show Include",
  "description": "[i shows the first line matching the word under the cursor in included files. ]i searches from the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 472,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "bracket commands",
    "C"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f main.c .main.c.swp .main.c.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "main.c",
      "content": "#include <stdio.h>\n#include <stdlib.h>\n\nint main() {\n    printf(\"Hello dungeon!\");\n    int *loot = malloc(100);\n    free(loot);\n    return 0;\n}"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers"
    },
    {
      "line": "nvim -c 'set number' main.c"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "[i ]i — Show Include",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "{key:[i} searches the current file and any included headers for the first line matching the word under the cursor. It echoes that line to the command line."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: find printf ---"
    },
    {
      "say": "Cursor on printf on line five. {key:[i} to find the first match.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "5G",
      "overlay": "go to line 5"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "w",
      "overlay": "to printf"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "[i",
      "overlay": "show match"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Watch the bottom of the screen. Vim followed the include and pulled in the printf declaration from stdio dot h."
    },
    {
      "wait": 2.5
    },
    {
      "keys": "\r",
      "overlay": "dismiss"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: find malloc ---"
    },
    {
      "say": "Try malloc on line six. {key:[i} again.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "6G",
      "overlay": "go to line 6"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "3w",
      "overlay": "to malloc"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "[i",
      "overlay": "show match"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Vim found the first mention of malloc inside stdlib dot h and echoed that line. Cursor never moved."
    },
    {
      "wait": 2.5
    },
    {
      "keys": "\r",
      "overlay": "dismiss"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "{key:[i}. Echo the first matching line from this file or any header it includes. Use {key:gd} to actually jump."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f main.c"
    }
  ],
  "youtube": {
    "videoId": "nFyMkBbrOU0",
    "url": "https://youtube.com/watch?v=nFyMkBbrOU0"
  }
}
