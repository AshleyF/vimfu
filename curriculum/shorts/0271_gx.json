{
  "title": "VimFu — gx Open URL or File",
  "description": "gx opens the URL or file path under the cursor in your default browser or application. Click links without leaving Vim.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 412,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "g commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f links.md .links.md.swp .links.md.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    { "writeFile": "links.md", "content": "# Bookmarks\n\nhttps://neovim.io\nhttps://vim.org\nhttps://github.com\n\nLocal: ~/vimfu/links.md" },
    { "line": "clear" },
    { "line": "nvim links.md" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": "gx — Open URL or File", "duration": 2.0 },
    { "wait": 0.7 },
    { "comment": "--- Intro ---" },
    { "say": "G X opens the URL or file path under the cursor. Vim sends it to your system's default handler." },
    { "wait": 0.3 },
    { "comment": "--- Demo 1: open a URL ---" },
    { "say": "Cursor on the neo vim URL. Line three.", "wait": false },
    { "wait": 0.3 },
    { "keys": "3G0", "overlay": "on URL" },
    { "wait": 0.3 },
    { "say": "G X.", "wait": false },
    { "wait": 0.3 },
    { "keys": "gx", "overlay": "open URL" },
    { "wait": 0.8 },
    { "say": "Vim opens the link in your default browser. You can keep editing without switching windows." },
    { "wait": 0.3 },
    { "comment": "--- Demo 2: another URL ---" },
    { "say": "Try another. Line five. GitHub.", "wait": false },
    { "wait": 0.3 },
    { "keys": "5G0", "overlay": "line 5" },
    { "wait": 0.3 },
    { "keys": "gx", "overlay": "open URL" },
    { "wait": 0.6 },
    { "say": "Opened. G X works with any URL, file path, or anything your system knows how to handle." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "G X. Open what's under the cursor. URLs, files, whatever. Your system handler takes care of the rest." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f links.md" }
  ]
}
