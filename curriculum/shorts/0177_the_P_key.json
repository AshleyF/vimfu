{
  "title": "VimFu — The P Key",
  "description": "Capital P puts (pastes) before the cursor, or above for line-wise text. P for put before.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 318,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "keyboard"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f words.txt .words.txt.swp .words.txt.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*words.txt*"
    },
    {
      "comment": "Create demo file — word pairs, one per line"
    },
    {
      "writeFile": "words.txt",
      "content": "alpha bravo\ncharlie delta\necho foxtrot\ngolf hotel"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim words.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "The P Key",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Capital P puts text before the cursor. For lines, it pastes above."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: line-wise P to paste above ---"
    },
    {
      "say": "Yank the second line. Move to the top. Capital P.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": ""
    },
    {
      "wait": 0.2
    },
    {
      "keys": "yy",
      "overlay": "yank line"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gg",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "P",
      "overlay": "put above"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Charlie delta above the first line. Line-wise P puts above."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: character-wise P to paste before cursor ---"
    },
    {
      "say": "Now yank a word. Move to delta. Capital P.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "yaw",
      "overlay": "yank a word"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jw",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "P",
      "overlay": "put before"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Alpha inserted before delta. For characters, P puts text before the cursor."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Capital P. Put before. Lines paste above. Words paste before the cursor. The mirror of lowercase P."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f words.txt"
    }
  ],
  "youtube": {
    "videoId": "wsKhdl9yT7U",
    "url": "https://youtube.com/watch?v=wsKhdl9yT7U"
  }
}
