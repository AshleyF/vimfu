{
  "title": "VimFu — :! Shell Command",
  "description": "Run a shell command from inside Vim without leaving.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 560,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "shell"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\nprint(\"hello\")"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":! — Shell Command",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "Colon bang runs a shell command from inside Vim."
    },
    {
      "wait": 0.3
    },
    {
      "say": "List files in the current directory.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":!ls",
      "overlay": ":!ls"
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "File listing appears. Press Enter to return to Vim."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "say": "Back in the editor. Any command works. L S, date, python, make. Run it, see the output, and come back."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Colon bang. Your shell inside Vim."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "3fdaAADO-JY",
    "url": "https://youtube.com/watch?v=3fdaAADO-JY"
  }
}
