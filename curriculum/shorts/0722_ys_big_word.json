{
  "title": "VimFu — Surround a WORD",
  "description": "ysaW} wraps the WORD (including punctuation) in braces.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 681,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f bigw.py .bigw.py.swp .bigw.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "bigw.py",
      "content": "path = /home/user\nurl = http://example.com"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim bigw.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Surround a WORD",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Y S A capital W targets a big WORD, including punctuation. Small W would only grab one segment between slashes."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor on the path. Y S A capital W, close brace.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "f/",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysaW}",
      "overlay": "ysaW}"
    },
    {
      "wait": 0.8
    },
    {
      "say": "The entire path including slashes is wrapped in braces."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Compare with small W. Y S I W close brace.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fh",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw}",
      "overlay": "ysiw}"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Only home is wrapped. Small W stops at punctuation. Capital W grabs everything."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f bigw.py"
    }
  ]
}
