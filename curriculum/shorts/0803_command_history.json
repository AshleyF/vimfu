{
  "title": "VimFu — Command History",
  "description": "Use the up and down arrows in command-line mode to recall previous commands. Vim remembers your command history.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 705,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f settings.py .settings.py.swp .settings.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "settings.py",
      "content": "# Settings\n\ntheme = \"dark\"\nfont_size = 14\ntab_width = 4\nauto_save = True\nwrap_lines = False\nshow_hidden = False"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim settings.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Command History",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Vim remembers your command history. Press colon, then use the up and down arrows to recall previous commands."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Build up history ---"
    },
    {
      "say": "First, let's run a few commands.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set number"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "type": ":set cursorline"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "type": ":set relativenumber"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "say": "Three commands in the history. Now type colon and press up.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Recall with up arrow ---"
    },
    {
      "type": ":"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u001b[A",
      "overlay": "↑ previous"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Set relativenumber. Our last command. Up again.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u001b[A",
      "overlay": "↑ previous"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Set cursorline. Press down to go forward.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u001b[B",
      "overlay": "↓ next"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Back to set relativenumber. Escape to cancel.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    "escape",
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Up and down arrows in the command line scroll through history. Very handy for repeating commands."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f settings.py"
    }
  ],
  "youtube": {
    "videoId": "d_Mva0vbkL0",
    "url": "https://youtube.com/watch?v=d_Mva0vbkL0"
  }
}
