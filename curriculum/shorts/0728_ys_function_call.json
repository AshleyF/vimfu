{
  "title": "VimFu — Surround with Function Call",
  "description": "ysiwfprint↵ wraps the word in a function call: print(word).",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 687,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f func.py .func.py.swp .func.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "func.py",
      "content": "result = value\noutput = name\ndata = items"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim func.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Surround with Function Call",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Lowercase F as the surround character wraps text in a function call. Type F, then the function name, then enter."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor on value. Y S I W, F, then type print and enter.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fv",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "type": "ysiwfprint",
      "overlay": "ysiwfprint↵"
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Value became print open paren value close paren. Tight, no spaces."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Line two. Wrap name in len.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfn",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "type": "ysiwflen",
      "overlay": "ysiwflen↵"
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Len of name. F wraps in a function call."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f func.py"
    }
  ],
  "youtube": {
    "videoId": "Df4bLbvd9-w",
    "url": "https://youtube.com/watch?v=Df4bLbvd9-w"
  }
}
