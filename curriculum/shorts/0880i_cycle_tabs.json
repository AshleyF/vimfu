{
  "title": "VimFu — :tabn / :tabp — Cycle Tabs",
  "description": "Use :tabnext (:tabn) and :tabprev (:tabp) to cycle through tabs. Also gt and gT.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 797,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f a.py b.py c.py .*.swp .*.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo files" },
    { "writeFile": "a.py", "content": "# File A" },
    { "writeFile": "b.py", "content": "# File B" },
    { "writeFile": "c.py", "content": "# File C" },
    { "line": "clear" },
    { "comment": "Launch nvim with tabs" },
    { "line": "nvim -p a.py b.py c.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":tabn / :tabp — Cycle Tabs", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "Cycle through tabs with tab next and tab previous. Or use the shorter G T and G shift T." },
    { "wait": 0.3 },
    { "comment": "--- Demo: cycle with commands ---" },
    { "say": "Go to the next tab.", "wait": false },
    { "wait": 0.3 },
    { "type": ":tabn", "overlay": ":tabn" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "File B. Next again.", "wait": false },
    { "wait": 0.3 },
    { "type": ":tabn", "overlay": ":tabn" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "File C. Now go back with tab previous.", "wait": false },
    { "wait": 0.3 },
    { "type": ":tabp", "overlay": ":tabp" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "comment": "--- Demo: gt and gT ---" },
    { "say": "Even faster. G T goes forward. G shift T goes back.", "wait": false },
    { "wait": 0.3 },
    { "keys": "gt" },
    { "wait": 0.6 },
    { "keys": "gT" },
    { "wait": 0.6 },
    { "comment": "--- Wrap up ---" },
    { "say": "Tab next, tab previous. Or G T and G shift T. Quick tab navigation." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":qa!" },
    "enter",
    { "line": "rm -f a.py b.py c.py" }
  ]
}
