{
  "title": "VimFu — :set incsearch",
  "description": "Use :set incsearch (or :set is) to search incrementally, highlighting matches as you type.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 772,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.py .demo.py.swp .demo.py.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    { "writeFile": "demo.py", "content": "def process_data():\n    data = load()\n    result = transform(data)\n    save(result)\n\ndef transform(data):\n    return [x * 2 for x in data]\n\ndef load():\n    return [1, 2, 3]" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim demo.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":set incsearch", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "Incremental search shows matches as you type each character. You can see results before pressing enter." },
    { "wait": 0.3 },
    { "comment": "--- Demo: enable and search incrementally ---" },
    { "say": "Enable it and search for transform.", "wait": false },
    { "wait": 0.3 },
    { "type": ":set incsearch", "overlay": ":set incsearch" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.5 },
    { "say": "Watch the cursor jump as I type each letter.", "wait": false },
    { "wait": 0.3 },
    { "type": "/t" },
    { "wait": 0.4 },
    { "type": "r" },
    { "wait": 0.4 },
    { "type": "a" },
    { "wait": 0.4 },
    { "type": "n" },
    { "wait": 0.4 },
    { "type": "s" },
    { "wait": 0.6 },
    { "say": "Already on the match. Press enter to confirm.", "wait": false },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "comment": "--- Wrap up ---" },
    { "say": "Set inc search or set I S. The cursor jumps to the first match as you type. Neovim has this on by default." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f demo.py" }
  ]
}
