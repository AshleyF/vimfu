{
  "title": "VimFu — :changes Show Change List",
  "description": "The :changes command displays the change list — a history of positions where text was modified.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 754,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.txt",
      "content": "first\nsecond\nthird\nfourth\nfifth\nsixth"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with -i NONE so shada doesn't restore stale changes from prior sessions"
    },
    {
      "line": "nvim -i NONE demo.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":changes — Show Change List",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Colon changes shows where you've made edits. Every change is recorded."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: three deliberate edits, then show ---"
    },
    {
      "say": "Append 'edit' to line one.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "A",
      "overlay": "append"
    },
    {
      "wait": 0.2
    },
    {
      "type": " edit"
    },
    {
      "wait": 0.2
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "say": "Down to line four, do the same.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "3j",
      "overlay": "down 3 lines"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "A",
      "overlay": "append"
    },
    {
      "wait": 0.2
    },
    {
      "type": " edit"
    },
    {
      "wait": 0.2
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "say": "Down to line six, one more.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2j",
      "overlay": "down 2 lines"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "A",
      "overlay": "append"
    },
    {
      "wait": 0.2
    },
    {
      "type": " edit"
    },
    {
      "wait": 0.2
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "comment": "--- Show change list, narrate while popup is on screen ---"
    },
    {
      "type": ":changes",
      "overlay": ":changes"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 1.0
    },
    {
      "say": "Three changes — lines one, four, and six. Exactly our edits. Use G semicolon to step backward through them, G comma forward."
    },
    {
      "wait": 0.5
    },
    {
      "keys": "q",
      "overlay": "dismiss"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon changes. See everywhere you've edited."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.txt"
    }
  ],
  "youtube": {
    "videoId": "xd_ntyD0wk0",
    "url": "https://youtube.com/watch?v=xd_ntyD0wk0"
  }
}
