{
  "title": "VimFu — Surround the Whole Line",
  "description": "yss) or yssb wraps the entire line in parentheses, ignoring leading whitespace.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 683,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f line.py .line.py.swp .line.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "line.py",
      "content": "hello world\n    return x + y\nprint result"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim line.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Surround the Whole Line",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Y S S wraps the entire line. The double S means line. It ignores leading whitespace."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor on line one. Y S S close paren.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "yss)",
      "overlay": "yss)"
    },
    {
      "wait": 0.8
    },
    {
      "say": "The whole line is wrapped in parentheses."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Line two has indentation. Y S S close paren.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "yss)",
      "overlay": "yss)"
    },
    {
      "wait": 0.8
    },
    {
      "say": "The content is wrapped, but the indentation is preserved outside the parens."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Y S S B is the alias. B for bracket. Same as Y S S close paren."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f line.py"
    }
  ]
}
