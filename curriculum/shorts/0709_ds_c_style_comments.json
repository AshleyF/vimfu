{
  "title": "VimFu — Delete C-Style Comments",
  "description": "With a custom surround, {key:d}{key:s}{key:/} removes `/* ... */` comment delimiters around the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 668,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f code.c .code.c.swp .code.c.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "code.c",
      "content": "x = /* temp */ 42;\ny = /* old */ 99;"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim -c 'lua require(\"nvim-surround\").setup({ surrounds = { [\"/\"] = { find = \"/%*.-%*/\", delete = \"^(/%*%s*)().-(%s*%*/)()$\" } } })' code.c"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete C-Style Comments",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "With a custom surround, {key:d}{key:s}{key:/} removes C style comment delimiters. It strips the slash star and star slash wrapper."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside the comment. {key:d}{key:s}{key:/}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ft",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "ds/"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "ds/"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Comment delimiters removed. The text inside stays clean. Leave that result on line one."
    },
    {
      "say": "Line two. Same operation: {key:d}{key:s}{key:/}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfo",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "ds/"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "ds/"
    },
    {
      "wait": 0.8
    },
    {
      "say": "{key:d}{key:s}{key:/}. Quick way to uncomment C style blocks after you define the comment surround."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f code.c"
    }
  ],
  "youtube": {
    "videoId": "pZumit6crq0",
    "url": "https://youtube.com/watch?v=pZumit6crq0"
  }
}
