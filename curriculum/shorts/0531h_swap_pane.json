  ],
  "setup": [
    {
      "comment": "Kill any stale tmux sessions"
    },
    {
      "line": "tmux kill-server 2>/dev/null; true"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "clear"
    },
    {
      "line": "tmux"
    },
    {
      "waitForScreen": "0:zsh",
      "timeout": 30.0
    },
    {
      "line": "echo 'TOP'"
    },
    {
      "keys": "\u0002\"",
      "overlay": ""
    },
    {
      "waitForScreen": "~",
      "timeout": 10.0
    },
    {
      "line": "echo 'BOTTOM'"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "swap-pane",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Swap-pane swaps the active pane with another. Dash capital U swaps up, dash capital D swaps down."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Bottom pane is active. Swap it up.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0002",
      "overlay": "prefix"
    },
    {
      "wait": 0.3
    },
    {
      "keys": ":",
      "overlay": ":  command"
    },
    {
      "wait": 0.3
    },
    {
      "type": "swap-pane -U"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\r",
      "overlay": ""
    },
    {
      "wait": 0.6
    },
    {
      "say": "The two panes swapped positions. Bottom moved to top. Short form is swapp. Same as control B, open brace or close brace."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Swap-pane. Rearrange your panes."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "line": "exit"
    },
    {
      "line": "exit"
    }
  ],
