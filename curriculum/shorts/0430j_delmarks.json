{
  "title": "VimFu — :delmarks Delete Marks",
  "description": "Remove marks you no longer need.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 581,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "marks"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "line 1\nline 2\nline 3\nline 4\nline 5"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim -i NONE +'silent! delmarks!' demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":delmarks — Delete Marks",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "`:delmarks` removes marks you no longer need. Start by setting three lowercase marks."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ma",
      "overlay": "set mark a"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jjmb",
      "overlay": "set mark b"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jjmc",
      "overlay": "set mark c"
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":marks",
      "overlay": ":marks",
      "beforeEnter": 1.1
    },
    {
      "wait": 2.2
    },
    "enter",
    {
      "wait": 0.3
    },
    {
      "say": "Delete only mark `a`.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":delmarks a",
      "overlay": ":delmarks a",
      "beforeEnter": 1.1
    },
    {
      "wait": 0.5
    },
    {
      "ex": ":marks",
      "overlay": ":marks",
      "beforeEnter": 1.1
    },
    {
      "wait": 2.2
    },
    "enter",
    {
      "wait": 0.3
    },
    {
      "say": "Now `:delmarks!` deletes all lowercase marks in this buffer.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":delmarks!",
      "overlay": ":delmarks!",
      "beforeEnter": 1.1
    },
    {
      "wait": 0.5
    },
    {
      "ex": ":marks",
      "overlay": ":marks",
      "beforeEnter": 1.1
    },
    {
      "wait": 2.2
    },
    "enter",
    {
      "say": "`:delmarks a` removes one mark. `:delmarks!` clears the lowercase marks."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "_AQV8JDqwvk",
    "url": "https://youtube.com/watch?v=_AQV8JDqwvk"
  }
}
