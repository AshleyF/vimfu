{
  "title": "VimFu — Delete Surrounding Angle Brackets",
  "description": "ds> or dsa removes angle brackets around the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 664,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f angles.txt .angles.txt.swp .angles.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "angles.txt",
      "content": "type = <string>\nval  = <int>\nref  = <T>"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim angles.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete Surrounding Angle Brackets",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "D S greater than removes surrounding angle brackets. D S A is the alias. A for angle."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside the angle brackets. D S greater than.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fs",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds>",
      "overlay": "ds>"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Angle brackets gone."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Line two. D S A.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfi",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "dsa",
      "overlay": "dsa"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Same result. D S angle or D S A."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f angles.txt"
    }
  ],
  "youtube": {
    "videoId": "9atjrr8k9PI",
    "url": "https://youtube.com/watch?v=9atjrr8k9PI"
  }
}
