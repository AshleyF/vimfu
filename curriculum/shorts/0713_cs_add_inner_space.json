{
  "title": "VimFu — Change — Add Inner Space",
  "description": "cs){ or cs)[ — using the opening mark as replacement adds space inside.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 672,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f padding.py .padding.py.swp .padding.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "padding.py",
      "content": "val = (x+y)\narr = [1,2,3]"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim padding.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change — Add Inner Space",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "When replacing surroundings, the opening mark adds spaces inside. The closing mark does not."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Parens around x plus y. C S close paren, open brace. Open brace adds space.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fx",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs){",
      "overlay": "cs){"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Parens became braces with spaces inside. Open brace adds padding."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Compare with close brace. C S close paren, close brace.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs)}",
      "overlay": "cs)}"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Braces, no extra space. Close mark gives tight wrapping."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Same with brackets. C S bracket, open bracket.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jf1",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs][",
      "overlay": "cs]["
    },
    {
      "wait": 0.8
    },
    {
      "say": "Spaces added. Opening mark means add space."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f padding.py"
    }
  ],
  "youtube": {
    "videoId": "lTXR4Ej-hFU",
    "url": "https://youtube.com/watch?v=lTXR4Ej-hFU"
  }
}
