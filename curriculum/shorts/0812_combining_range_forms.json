{
  "title": "VimFu — Combining Range Forms",
  "description": "Mix and match range forms. Use marks, line numbers, dot, and $ together in one range.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 714,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f catalog.txt .catalog.txt.swp .catalog.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "catalog.txt",
      "content": "line 1 — alpha\nline 2 — bravo\nline 3 — charlie\nline 4 — delta\nline 5 — echo\nline 6 — foxtrot\nline 7 — golf\nline 8 — hotel\nline 9 — india\nline 10 — juliet\nline 11 — kilo\nline 12 — lima"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers"
    },
    {
      "line": "nvim -c 'set number' catalog.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Combining Range Forms",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "You can mix different range forms in one command. Marks, numbers, dot, and dollar all work together."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: mark + dollar ---"
    },
    {
      "say": "Set mark A on line five.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":5"
    },
    {
      "wait": 1.0
    },
    "enter",
    {
      "wait": 0.3
    },
    {
      "keys": "ma",
      "overlay": "mark a"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Now delete from mark A to the end. Colon quote A comma dollar d.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":'a,$d"
    },
    {
      "wait": 1.2
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Everything from line five to the end is gone. Mark plus dollar."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Demo 2: number + dot ---"
    },
    {
      "say": "Another mix. Colon one comma dot d. Delete from line one to the current line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":1,.d"
    },
    {
      "wait": 1.2
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Lines one through five are gone. Number on the left, dot on the right."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Any range form on either side of the comma. Mix marks, numbers, dot, and dollar freely."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f catalog.txt"
    }
  ],
  "youtube": {
    "videoId": "StIk1MVlaEw",
    "url": "https://youtube.com/watch?v=StIk1MVlaEw"
  }
}
