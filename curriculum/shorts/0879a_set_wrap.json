{
  "title": "VimFu — :set wrap / nowrap",
  "description": "Use :set wrap and :set nowrap to control whether long lines wrap on screen.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 782,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with a long line"
    },
    {
      "writeFile": "demo.txt",
      "content": "Short line\nThis is a very long line that goes on and on and should extend well beyond the visible width of the terminal window to demonstrate wrapping behavior\nAnother short line\nEnd of file"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers (makes wrap behaviour easier to see)"
    },
    {
      "line": "nvim -c 'set number' demo.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":set wrap / nowrap",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Wrap controls whether long lines wrap to the next screen line or extend off the edge."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: show wrap (default) ---"
    },
    {
      "say": "By default, wrap is on. The long line wraps to multiple screen lines.",
      "wait": false
    },
    {
      "wait": 0.8
    },
    {
      "comment": "--- Demo: turn off wrap ---"
    },
    {
      "say": "Turn off wrapping.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set nowrap",
      "overlay": ":set nowrap"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Set no wrap — long lines extend off the right edge instead of wrapping."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Now the long line is cut off at the screen edge. The text is still there, just hidden."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: turn wrap back on ---"
    },
    {
      "say": "Turn wrap back on.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set wrap",
      "overlay": ":set wrap"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Set wrap brings wrapping back — long lines wrap to fit the window."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Set wrap shows full lines. Set no wrap hides overflow. Most developers prefer no wrap for code."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.txt"
    }
  ],
  "youtube": {
    "videoId": "mRFHTU2Dwyg",
    "url": "https://youtube.com/watch?v=mRFHTU2Dwyg"
  }
}
