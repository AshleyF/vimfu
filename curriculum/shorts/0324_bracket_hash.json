{
  "title": "VimFu — [# ]# Preprocessor",
  "description": "[# jumps to the previous unmatched #if or #ifdef. ]# jumps to the next unmatched #endif. For C/C++ code.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 465,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "bracket commands",
    "C"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f config.h .config.h.swp .config.h.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with preprocessor directives"
    },
    {
      "writeFile": "config.h",
      "content": "#ifndef CONFIG_H\n#define CONFIG_H\n\n#ifdef DEBUG\n  int log_level = 3;\n  int verbose = 1;\n  int trace = 1;\n#endif\n\nint max_hp = 100;\n\n#endif"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers"
    },
    {
      "line": "nvim -c 'set number' config.h"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "[# ]# — Preprocessor",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "{key:[#} jumps to the previous unmatched if-def. {key:]#} jumps to the next unmatched end-if."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: jump from inside a block ---"
    },
    {
      "say": "Cursor is inside the debug block on line five. {key:[#} to find the enclosing if-def.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "5G",
      "overlay": "go to line 5"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "[#",
      "overlay": "enclosing #ifdef"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Jumped to the if-def DEBUG on line four."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: jump to endif ---"
    },
    {
      "say": "{key:]#} finds the matching end-if from inside the block.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": "into block"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "]#",
      "overlay": "matching #endif"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Landed on the end-if. Matches preprocessor blocks just like parens and braces."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "{key:[#} and {key:]#}. Navigate C preprocessor blocks. Jump between if-def and end-if."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f config.h"
    }
  ],
  "youtube": {
    "videoId": "ahxVR2nDY6o",
    "url": "https://youtube.com/watch?v=ahxVR2nDY6o"
  }
}
