{
  "title": "VimFu — Recipe: Number All Lines",
  "description": "Use a substitute with an expression to prepend line numbers to every line in the file.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 823,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "recipes"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f items.txt .items.txt.swp .items.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with a simple list"
    },
    {
      "writeFile": "items.txt",
      "content": "apple\nbanana\ncherry\ndate\nelderberry\nfig\ngrape"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim items.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Recipe: Number All Lines",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Here's a plain list with no line numbers. Let's prepend a number to each line."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Number lines ---"
    },
    {
      "say": "Use a substitute with an expression in the replacement."
    },
    {
      "type": ":%s/^/\\=line('.').' '/",
      "overlay": ":%s/^/\\=line('.').' '/"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Backslash equals turns the replacement into a Vim expression. Line of dot returns the current line number, followed by a space."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Each line now starts with its number. One apple, two banana, three cherry, and so on."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Backslash equals turns the replacement into a Vim expression. Powerful for dynamic substitutions."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f items.txt"
    }
  ],
