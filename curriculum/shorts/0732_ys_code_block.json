{
  "title": "VimFu — Surround with Code Block",
  "description": "ysiw<C-]> wraps the word in braces on separate lines, like a code block.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 691,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f block.js .block.js.swp .block.js.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "block.js",
      "content": "return x + y"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim block.js"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Surround with Code Block",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Control close bracket wraps the text in braces on separate lines. It creates a code block layout."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Y S S, control close bracket.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "yss\u001d",
      "overlay": "yss<C-]>"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Opening brace above, content indented, closing brace below. A code block in one keystroke sequence."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Control close bracket. Quick way to wrap in a block."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f block.js"
    }
  ]
}
