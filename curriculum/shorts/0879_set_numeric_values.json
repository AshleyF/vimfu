{
  "title": "VimFu — Setting Numeric Values with =",
  "description": "Use :set option=N to assign numeric values to settings like scrolloff, tabstop, etc.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 781,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    { "writeFile": "demo.txt", "content": "Line 1\nLine 2\nLine 3\nLine 4\nLine 5\nLine 6\nLine 7\nLine 8\nLine 9\nLine 10" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim demo.txt" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": "Setting Numeric Values with =", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "Numeric settings use equals to assign a value. No space around the equals sign." },
    { "wait": 0.3 },
    { "comment": "--- Demo: set scrolloff ---" },
    { "say": "Set scroll off to three.", "wait": false },
    { "wait": 0.3 },
    { "type": ":set scrolloff=3", "overlay": ":set scrolloff=3" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.5 },
    { "say": "Verify it.", "wait": false },
    { "wait": 0.3 },
    { "type": ":set scrolloff?", "overlay": ":set so?" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    "enter",
    { "comment": "--- Demo: set tabstop ---" },
    { "say": "Set tab stop to two.", "wait": false },
    { "wait": 0.3 },
    { "type": ":set tabstop=2", "overlay": ":set ts=2" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.5 },
    { "type": ":set ts?", "overlay": ":set ts?" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    "enter",
    { "comment": "--- Wrap up ---" },
    { "say": "Set option equals value. No spaces. Works for scroll off, tab stop, shift width, and many more." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f demo.txt" }
  ]
}
