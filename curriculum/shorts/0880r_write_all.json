  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f one.py two.py .*.swp .*.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo files"
    },
    {
      "writeFile": "one.py",
      "content": "print(\"one\")"
    },
    {
      "writeFile": "two.py",
      "content": "print(\"two\")"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim -o one.py two.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":wa — Write All",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "W A writes all modified buffers. Save everything at once instead of saving each file individually."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: modify both files ---"
    },
    {
      "say": "First, change both files."
    },
    {
      "keys": "o"
    },
    {
      "type": "# edited"
    },
    "escape",
    {
      "wait": 0.3
    },
    {
      "keys": "ctrl+w"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "j"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "o"
    },
    {
      "type": "# also edited"
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "comment": "--- Demo: save all ---"
    },
    {
      "say": "Now save both at once."
    },
    {
      "type": ":wa",
      "overlay": ":wa"
    },
    {
      "wait": 0.4
    },
    {
      "say": "W A — short for write all — saves every modified buffer in one shot."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Both files saved. No need to switch windows and save individually."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon W A. Write all. Save everything in one command."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":qa!"
    },
    "enter",
    {
      "line": "rm -f one.py two.py"
    }
  ],
