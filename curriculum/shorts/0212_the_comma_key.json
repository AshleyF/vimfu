{
  "title": "VimFu — The , Key",
  "description": "Comma repeats the last f, t, F, or T in the opposite direction. Go back to the previous match.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 353,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "keyboard"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f path.py .path.py.swp .path.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*path.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "path.py",
      "content": "route = \"/home/user/docs/work/notes\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim path.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "The , Key",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Comma repeats the last F or T in the opposite direction. Semicolon goes forward, comma goes back."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: f/ then ; then , ---"
    },
    {
      "say": "F slash to find the first slash. Semicolon twice to go forward.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "f/",
      "overlay": "f/  find /"
    },
    {
      "wait": 0.3
    },
    {
      "keys": ";",
      "overlay": ";  repeat find"
    },
    {
      "wait": 0.3
    },
    {
      "keys": ";",
      "overlay": ";  repeat find"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Overshot. Comma to go back.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": ",",
      "overlay": ",  reverse find"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Back one slash. Comma again.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": ",",
      "overlay": ",  reverse find"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Back to the first slash. Semicolon and comma are a pair. Forward and backward on the same find."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Comma. Reverse the last find. Semicolon forward, comma back."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f path.py"
    }
  ],
  "youtube": {
    "videoId": "1kgHggMC6OM",
    "url": "https://youtube.com/watch?v=1kgHggMC6OM"
  }
}
