{
  "title": "VimFu — Visual Range '<,'>",
  "description": "After making a visual selection, pressing : automatically inserts the visual range markers '<,'>.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 711,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f colors.py .colors.py.swp .colors.py.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    {
      "writeFile": "colors.py",
      "content": "# Colors\nred = \"#ff0000\"\ngreen = \"#00ff00\"\nblue = \"#0000ff\"\nyellow = \"#ffff00\"\ncyan = \"#00ffff\"\nmagenta = \"#ff00ff\"\nwhite = \"#ffffff\"\nblack = \"#000000\"\norange = \"#ffa500\""
    },
    { "line": "clear" },
    { "comment": "Launch nvim with line numbers" },
    { "line": "nvim -c 'set number' colors.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": "Visual Range — '<,'>", "duration": 2.0 },
    { "wait": 0.7 },
    { "comment": "--- Intro ---" },
    { "say": "When you make a visual selection and press colon, Vim fills in the range automatically." },
    { "wait": 0.3 },
    { "comment": "--- Demo: select lines and delete ---" },
    { "say": "Move to line three. Enter visual line mode with shift V.", "wait": false },
    { "wait": 0.3 },
    { "type": ":3" },
    "enter",
    { "wait": 0.3 },
    { "keys": "V", "overlay": "V visual line" },
    { "wait": 0.5 },
    { "say": "Select down three lines.", "wait": false },
    { "wait": 0.3 },
    { "keys": "jjj", "overlay": "select down" },
    { "wait": 0.5 },
    { "say": "Now press colon. Watch the command line.", "wait": false },
    { "wait": 0.3 },
    { "type": ":" },
    { "wait": 0.6 },
    { "say": "See the angle brackets? That is the visual range. It means the selected lines. Type d and Enter.", "wait": false },
    { "wait": 0.3 },
    { "type": "d" },
    "enter",
    { "wait": 0.6 },
    { "say": "The selected lines are deleted. Vim used the visual range as the target." },
    { "wait": 0.3 },
    { "keys": "u", "overlay": "undo" },
    { "wait": 0.5 },
    { "comment": "--- Wrap up ---" },
    { "say": "Select lines visually, press colon, and the range is filled in for you. Works with any Ex command." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "comment": "Clean up" },
    { "line": "rm -f colors.py" }
  ]
}
