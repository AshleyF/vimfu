{
  "title": "VimFu — The Last Line $",
  "description": "In Ex commands, $ means the last line of the file. :$ jumps to the end.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 708,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f log.txt .log.txt.swp .log.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "log.txt",
      "content": "line 1 — alpha\nline 2 — bravo\nline 3 — charlie\nline 4 — delta\nline 5 — echo\nline 6 — foxtrot\nline 7 — golf\nline 8 — hotel\nline 9 — india\nline 10 — juliet\nline 11 — kilo\nline 12 — lima"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers"
    },
    {
      "line": "nvim -c 'set number' log.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "The Last Line — $",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Dollar sign means the last line of the file. Whatever line that happens to be."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: jump to last line ---"
    },
    {
      "say": "Colon dollar sign. Jump to the last line.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":$"
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Cursor is on line twelve. The last line."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: jump back to top ---"
    },
    {
      "say": "Colon one to go back to the top.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":1"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "comment": "--- Demo 3: delete from line 10 to the end ---"
    },
    {
      "say": "Dollar is useful in ranges. Colon ten comma dollar d. Delete from line ten to the end.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":10,$d"
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "Lines ten through twelve are gone. Dollar meant the last line."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Dollar sign equals the last line. Use it to target the end of any file."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f log.txt"
    }
  ],
  "youtube": {
    "videoId": "sVzxU0QMyS8",
    "url": "https://youtube.com/watch?v=sVzxU0QMyS8"
  }
}
