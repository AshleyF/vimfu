  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f exit.py .exit.py.swp .exit.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*exit.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "exit.py",
      "content": "status = \"ready\"\nmission = \"go\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim exit.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
