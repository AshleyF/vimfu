{
  "title": "VimFu — gF Go to File at Line",
  "description": "gF opens the file under the cursor and jumps to a specific line number. Works with patterns like filename:42 or filename line 42.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
