  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f errors.log helpers.py .errors.log.swp .errors.log.swo .helpers.py.swp .helpers.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create target file"
    },
    {
      "writeFile": "helpers.py",
      "content": "# Helpers Module\nimport os\nimport sys\n\ndef read_file(path):\n    with open(path) as f:\n        return f.read()\n\ndef write_file(path, data):\n    with open(path, 'w') as f:\n        f.write(data)\n\ndef safe_divide(a, b):\n    if b == 0:\n        raise ValueError(\"Division by zero\")\n    return a / b"
    },
    {
      "comment": "Create error log with file:line references"
    },
    {
      "writeFile": "errors.log",
      "content": "Build errors:\n  helpers.py:15 ValueError\n  helpers.py:6  missing file\nAll done."
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with line numbers"
    },
    {
      "line": "nvim -c 'set number' -c 'edit helpers.py' -c 'buffer errors.log' errors.log"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
