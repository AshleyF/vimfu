{
  "title": "VimFu — Ctrl-T Indent in Insert",
  "description": "Ctrl-T in insert mode inserts one shiftwidth of indentation at the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 513,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "insert mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\ndef run():\npass"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-T — Indent in Insert",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control T in insert mode increases the indentation of the current line by one shift width. No need to leave insert mode to indent."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: indent pass ---"
    },
    {
      "say": "Line three says pass, but it's not indented. Let's fix it.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2j",
      "overlay": "to line 3"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "I",
      "overlay": "insert at start"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Control T to indent.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0014",
      "overlay": "indent"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Indented one level. Press it again for another level.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0014",
      "overlay": "indent more"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Two levels deep. Each Control T adds one shift width."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Control T in insert mode. Indent the line without leaving insert. Pair it with Control D to unindent."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "C_Z9YEBpmzU",
    "url": "https://youtube.com/watch?v=C_Z9YEBpmzU"
  }
}
