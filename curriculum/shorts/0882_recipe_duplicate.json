    {
      "type": ":1,3t 11",
      "overlay": ":1,3t 11"
    },
    {
      "wait": 0.4
    },
    {
      "say": "One comma three t eleven. Copy lines one through three, paste after line eleven."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "The server block is duplicated at the bottom. The original stays in place."
