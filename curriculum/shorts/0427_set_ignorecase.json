{
  "title": "VimFu — :set ignorecase / smartcase",
  "description": "Control case sensitivity in Vim searches with :set ignorecase and :set smartcase.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 568,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "settings"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\ndef greet(Name):\n    return f\"Hello {Name}\"\n\nname = \"World\"\nprint(greet(name))"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":set ignorecase / smartcase",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "By default, Vim searches are case sensitive. Set ignorecase makes searches match any case."
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set ignorecase",
      "overlay": ":set ignorecase"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "type": "/name",
      "overlay": "/name"
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Searching for lowercase name now matches both Name and name."
    },
    {
      "wait": 0.5
    },
    {
      "keys": "n"
    },
    {
      "wait": 0.5
    },
    {
      "keys": "n"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Add smartcase to be case insensitive only when your search is all lowercase. If you type an uppercase letter, it becomes case sensitive."
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set smartcase",
      "overlay": ":set smartcase"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "type": "/Name",
      "overlay": "/Name"
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Now searching for capital Name only matches the uppercase version."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "tJipYx9_OmQ",
    "url": "https://youtube.com/watch?v=tJipYx9_OmQ"
  }
}
