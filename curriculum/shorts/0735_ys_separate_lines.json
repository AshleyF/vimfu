{
  "title": "VimFu — Surround on Separate Lines",
  "description": "ySiw( indents the surrounded text onto its own line.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 694,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f sep.py .sep.py.swp .sep.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "sep.py",
      "content": "result = value\ndata = items"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim sep.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Surround on Separate Lines",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Capital Y S puts the surrounded text on its own indented line. The opening and closing marks go on separate lines."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Capital Y S I W, open paren.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fv",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ySiw(",
      "overlay": "ySiw("
    },
    {
      "wait": 0.8
    },
    {
      "say": "Value is on its own indented line with parens above and below."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Capital Y S. The multi-line surround."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f sep.py"
    }
  ],
  "youtube": {
    "videoId": "jZK1KrMjJjc",
    "url": "https://youtube.com/watch?v=jZK1KrMjJjc"
  }
}
