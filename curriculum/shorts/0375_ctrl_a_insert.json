{
  "title": "VimFu \u2014 Ctrl-A Insert Previous Text",
  "description": "Ctrl-A in insert mode re-inserts the text you typed in the previous insert session.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 516,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "insert mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\nline1 = \nline2 = "
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-A \u2014 Insert Previous",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control A in insert mode re-inserts the text you typed in the previous insert session. Like a quick repeat."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: type text, then re-insert ---"
    },
    {
      "say": "Go to line two and type a value.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jA",
      "overlay": "next line, append"
    },
    {
      "wait": 0.3
    },
    {
      "type": "\"hello\"",
      "overlay": ""
    },
    {
      "wait": 0.4
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now go to line three and insert the same text.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jA",
      "overlay": "next line, append"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0001",
      "overlay": "insert previous"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Hello inserted again. The same text from the previous insert session, without retyping."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Control A. Re-insert previously typed text. A quick way to repeat what you just typed somewhere else."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ]
}
