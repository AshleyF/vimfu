  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f quest.py .quest.py.swp .quest.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*quest.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "quest.py",
      "content": "town = \"haven\"\nforest = \"darkwood\"\ncave = \"crystal\"\nriver = \"silver\"\npeak = \"thunder\"\nlake = \"mirror\"\nruins = \"ancient\"\nfort = \"dragon\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim quest.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
