{
  "title": "VimFu — g Ctrl-A / g Ctrl-X — Sequences",
  "description": "Use {key:g}{key:Ctrl-A} in visual mode to create incrementing number sequences, and {key:g}{key:Ctrl-X} for decrementing sequences.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 627,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "practical"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f list.txt .list.txt.swp .list.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "list.txt",
      "content": "0. apple\n0. banana\n0. cherry\n0. date\n0. elderberry"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim list.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "g Ctrl-A / g Ctrl-X — Sequences",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "In visual mode, press {key:g}, then {key:Ctrl-A}, to create incrementing sequences. Instead of adding the same number to each line, each line gets one more."
    },
    {
      "wait": 0.3
    },
    {
      "say": "All lines start with zero. Select them all with V and G.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "V",
      "overlay": "visual line"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "G",
      "overlay": "to last line"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Now press {key:g}, then {key:Ctrl-A}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "g",
      "overlay": "g prefix"
    },
    {
      "ctrl": "a",
      "overlay": "sequence"
    },
    {
      "wait": 0.6
    },
    {
      "say": "The zeros became 1, 2, 3, 4, 5. Each line incremented one more than the last."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Undo and try {key:g}, then {key:Ctrl-X}, for a decrementing sequence.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "V",
      "overlay": "visual line"
    },
    {
      "wait": 0.2
    },
    {
      "keys": "G"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "g",
      "overlay": "g prefix"
    },
    {
      "ctrl": "x",
      "overlay": "decrement"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Now they go negative: minus 1, minus 2, minus 3, and so on. Use {key:g}, then {key:Ctrl-A}, or {key:g}, then {key:Ctrl-X}. Perfect for numbered lists."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f list.txt"
    }
  ],
  "youtube": {
    "videoId": "AS4LL2c2rcI",
    "url": "https://youtube.com/watch?v=AS4LL2c2rcI"
  }
}
