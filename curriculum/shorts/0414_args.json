{
  "title": "VimFu — :args Argument List",
  "description": "The :args command shows the files passed as arguments when Vim was launched.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 555,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f a.py b.py c.py .a.py.swp .b.py.swp .c.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "a.py",
      "content": "# A"
    },
    {
      "writeFile": "b.py",
      "content": "# B"
    },
    {
      "writeFile": "c.py",
      "content": "# C"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim a.py b.py c.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":args — Argument List",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "Colon args shows the argument list. These are the files you passed when you launched Vim."
    },
    {
      "wait": 0.3
    },
    {
      "type": ":args",
      "overlay": ":args"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "say": "Three files. The one in square brackets is the current file. Use colon next and colon previous to move through them."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "say": "Colon args. See what you started with. Navigate with colon next and colon previous."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":qa!"
    },
    "enter",
    {
      "line": "rm -f a.py b.py c.py"
    }
  ],
  "youtube": {
    "videoId": "C8-GqmxJy-o",
    "url": "https://youtube.com/watch?v=C8-GqmxJy-o"
  }
}
