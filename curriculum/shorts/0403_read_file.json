{
  "title": "VimFu — :r {file} Read File",
  "description": "The :r command inserts the contents of another file below the cursor.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 544,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f main.py header.py .main.py.swp" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "writeFile": "header.py", "content": "# Author: VimFu\n# License: MIT" },
    { "writeFile": "main.py", "content": "# Main\nprint(\"hello\")" },
    { "line": "clear" },
    { "line": "nvim main.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "overlay": "VimFu", "caption": ":r — Read File", "duration": 2.0 },
    { "wait": 0.7 },
    { "say": "Colon R inserts the contents of another file below your cursor." },
    { "wait": 0.3 },
    { "say": "Insert the header file here.", "wait": false },
    { "wait": 0.3 },
    { "ex": ":r header.py", "overlay": ":r header.py" },
    { "wait": 0.5 },
    { "say": "The header content was inserted below the cursor line. Two lines pulled in from another file." },
    { "wait": 0.3 },
    { "say": "Colon R. Pull in content from any file. Great for templates, headers, or snippets." },
    { "wait": 1.5 }
  ],
  "teardown": [
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f main.py header.py" }
  ]
}
