{
  "title": "VimFu — :bd — Delete Buffer",
  "description": "Use :bd to remove a buffer from the buffer list. Use :bd! to force-close an unsaved buffer.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 793,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f one.py two.py three.py .*.swp .*.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo files" },
    { "writeFile": "one.py", "content": "print(\"one\")" },
    { "writeFile": "two.py", "content": "print(\"two\")" },
    { "writeFile": "three.py", "content": "print(\"three\")" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim one.py two.py three.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":bd — Delete Buffer", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "Buffer delete removes a buffer from the list. The file stays on disk. It just closes it in Vim." },
    { "wait": 0.3 },
    { "comment": "--- Demo: list, then delete current ---" },
    { "say": "Check the buffer list.", "wait": false },
    { "wait": 0.3 },
    { "type": ":ls", "overlay": ":ls" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    "enter",
    { "say": "Delete the current buffer.", "wait": false },
    { "wait": 0.3 },
    { "type": ":bd", "overlay": ":bd" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Buffer one is gone. Vim switched to the next buffer. Check the list.", "wait": false },
    { "wait": 0.3 },
    { "type": ":ls", "overlay": ":ls" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    "enter",
    { "say": "Only two buffers remain." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Colon B D deletes a buffer. Use B D bang to force-close unsaved changes." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":qa!" },
    "enter",
    { "line": "rm -f one.py two.py three.py" }
  ]
}
