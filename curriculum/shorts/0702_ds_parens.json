{
  "title": "VimFu — Delete Surrounding Parentheses",
  "description": "ds) or dsb removes parentheses around the cursor. Both do the same thing.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 661,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f parens.py .parens.py.swp .parens.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "parens.py",
      "content": "result = (42)\nvalue = (x + y)\ndata = (a, b, c)"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim parens.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Delete Surrounding Parentheses",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "D S close paren deletes the surrounding parentheses. D S B does the same thing. B for bracket."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside the parens. D S close paren.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "f4",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds)",
      "overlay": "ds)"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Parentheses removed. Just the number remains."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Line two. D S B, the alias.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfx",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "dsb",
      "overlay": "dsb"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Same result. B is short for bracket, meaning round bracket."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "D S paren or D S B. Both remove parentheses."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f parens.py"
    }
  ]
}
