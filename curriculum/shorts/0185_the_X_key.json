  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f profile.py .profile.py.swp .profile.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*profile.py*"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "profile.py",
      "content": "player = \" Kai\"\nhp = 1009\nrank = \"x_knight\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim before recording"
    },
    {
      "line": "nvim profile.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "The X Key",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Capital X deletes the character before the cursor. Like backspace, but in normal mode."
    },
    {
      "wait": 0.3
    },
    {
      "say": "It's the opposite of lowercase X. Lowercase deletes under the cursor. Capital deletes behind it."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: stray space before name ---"
    },
    {
      "say": "This string has a stray space before the name. Jump to the K with F K.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fK",
      "overlay": ""
    },
    {
      "wait": 0.5
    },
    {
      "say": "The cursor is on the K. The space is right behind it. Capital X.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "X",
      "overlay": "delete before"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Gone. Lowercase X would have deleted the K. Capital X deleted the space before it."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: extra zero in number ---"
    },
    {
      "say": "HP should be 109. There's an extra zero. Jump down.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": ""
    },
    {
      "wait": 0.5
    },
    {
      "say": "Cursor lands right on the 9. The extra zero is behind it. Capital X.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "X",
      "overlay": "delete before"
    },
    {
      "wait": 0.6
    },
    {
      "say": "1009 became 109. The zero before the cursor is gone."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 3: counted X to remove prefix ---"
    },
    {
      "say": "The rank has a stray X underscore prefix. Jump down and find the K.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": ""
    },
    {
      "wait": 0.2
    },
    {
      "keys": "fk",
      "overlay": ""
    },
    {
      "wait": 0.5
    },
    {
      "say": "Two junk characters before the K. Two capital X.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "2X",
      "overlay": "delete 2 before"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Both the underscore and the X are gone. Knight. Capital X takes a count, just like lowercase X."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Capital X. Backspace in normal mode. Use it when the trash is behind your cursor and the thing you want to keep is under it."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f profile.py"
    }
  ],
