{
  "title": "VimFu — Surround with Tag",
  "description": "ysiw<em> wraps the word in an HTML tag pair.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 684,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f tag.html .tag.html.swp .tag.html.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "tag.html",
      "content": "Hello World\nClick Here\nRead More"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim tag.html"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Surround with Tag",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Type a tag with angle brackets as the surround character and Y S creates both the opening and closing tag."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor on Hello. Y S I W, then type the tag.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiwtem>\r",
      "overlay": "ysiwt em>"
    },
    {
      "wait": 0.3
    },
    {
      "wait": 0.8
    },
    {
      "say": "Hello is wrapped in em tags. Opening and closing generated."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Wrap the whole line in a P tag. Y S S, then the tag.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysstp>\r",
      "overlay": "ysst p>"
    },
    {
      "wait": 0.3
    },
    {
      "wait": 0.8
    },
    {
      "say": "Entire line wrapped in P tags. Y S with a tag. Essential for H T M L."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f tag.html"
    }
  ]
}
