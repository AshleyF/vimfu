{
  "title": "VimFu — Surround with Tag",
  "description": "{key:y}{key:s}{key:i}{key:w}{key:t} opens a tag prompt; type `em>` to wrap the word in an HTML tag pair.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 684,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f tag.html .tag.html.swp .tag.html.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "tag.html",
      "content": "Hello World\nClick Here\nRead More"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim tag.html"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Surround with Tag",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:y}{key:s} can surround text with an HTML tag. Use {key:t} to open the tag prompt at the bottom."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor on Hello. Press {key:y}{key:s}{key:i}{key:w}{key:t}. When the prompt appears, type `em>`.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiwt"
    },
    {
      "wait": 0.8
    },
    {
      "type": "em>"
    },
    {
      "wait": 0.5
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "The tag name was typed at the prompt. Opening and closing em tags were generated."
    },
    {
      "say": "Line two: wrap the whole line. Press {key:y}{key:s}{key:s}{key:t}, then type `p>` at the prompt.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysst"
    },
    {
      "wait": 0.8
    },
    {
      "type": "p>"
    },
    {
      "wait": 0.5
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Now both examples show the prompt flow: command first, tag name at the bottom, generated tag pair on the line."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f tag.html"
    }
  ],
  "youtube": {
    "videoId": "7kzZPJtI5bs",
    "url": "https://youtube.com/watch?v=7kzZPJtI5bs"
  }
}
