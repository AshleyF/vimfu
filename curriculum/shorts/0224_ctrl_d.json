  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f loot.py .loot.py.swp .loot.py.swo"
    },
    {
      "line": "rm -f ~/.local/state/nvim/swap/*loot.py*"
    },
    {
      "comment": "Create a long demo file"
    },
    {
      "writeFile": "loot.py",
      "content": "# Loot Table\n\ncommon = [\n    \"wooden sword\",\n    \"cloth hat\",\n    \"torn map\",\n    \"rusty key\",\n]\n\nuncommon = [\n    \"silver dagger\",\n    \"leather boots\",\n    \"health potion\",\n    \"fire scroll\",\n]\n\nrare = [\n    \"enchanted bow\",\n    \"mithril shield\",\n    \"dragon scale\",\n    \"void crystal\",\n]\n\nlegendary = [\n    \"excalibur\",\n    \"phoenix feather\",\n    \"time amulet\",\n    \"shadow cloak\",\n]\n\ndef roll_loot(luck):\n    if luck > 90:\n        return legendary\n    if luck > 60:\n        return rare\n    return common"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim at top"
    },
    {
      "line": "nvim loot.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-D",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control D scrolls half a page down. Paired with control U for smooth scrolling."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: half page down ---"
    },
    {
      "say": "We're at the top. Control D.",
