    },
    {
      "wait": 0.6
    },
    {
      "say": "Half a page down. We can still see some of the previous screen at the top."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: again ---"
    },
    {
      "say": "Again.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "d",
      "overlay": "half page down"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Into the rare items now. One more."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 3: one more, then back ---"
    },
    {
      "ctrl": "d",
      "overlay": "half page down"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Near the bottom. Control U goes back up.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "u",
      "overlay": "half page up"
    },
    {
      "wait": 0.6
