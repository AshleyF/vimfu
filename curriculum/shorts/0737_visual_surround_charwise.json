{
  "title": "VimFu — Visual Surround — Characterwise",
  "description": "In characterwise visual mode, {key:S} wraps an arbitrary selection in the given surround.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 696,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f visual.py .visual.py.swp .visual.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "visual.py",
      "content": "total = red + green + blue + alpha\nroute = /api/v1/users"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim visual.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Visual Surround — Charwise",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "In *visual mode,* {key:S} surrounds the selection. If one motion fits, use {key:y}{key:s} with that motion. Use visual surround for awkward spans or text you already highlighted."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Select just `green + blue` from the middle of this expression.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fg",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "v11l",
      "overlay": "v → select"
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:S}{key:]} surrounds the selected expression with brackets.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "S]"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Only the selected span was wrapped. The rest of the expression stayed outside."
    },
    {
      "say": "Another awkward selection: quote only `/api/v1` inside the route.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j0f/",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "v6l",
      "overlay": "v → select"
    },
    {
      "wait": 0.5
    },
    {
      "keys": "S\""
    },
    {
      "wait": 0.8
    },
    {
      "say": "That kind of oddly shaped substring is where *visual mode* earns its keep: select exactly what you mean, then press {key:S} and the surround."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f visual.py"
    }
  ],
  "youtube": {
    "videoId": "9UaHTAZIv9Y",
    "url": "https://youtube.com/watch?v=9UaHTAZIv9Y"
  }
}
