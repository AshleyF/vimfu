  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file with blank lines" },
    { "writeFile": "demo.txt", "content": "header\n\nfirst item\n\n\nsecond item\n\nthird item\n\n\n\nfooter" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim demo.txt" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":g with :d — Delete Blank Lines", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "A classic use of global. Delete all blank lines in the file." },
    { "wait": 0.3 },
    { "comment": "--- Demo ---" },
    { "say": "This file is full of empty lines. Caret dollar matches an empty line. Global delete removes them all.", "wait": false },
    { "wait": 0.3 },
    { "type": ":g/^$/d", "overlay": ":g/^$/d" },
    { "wait": 0.3 },
    { "keys": "enter" },
    { "wait": 0.8 },
    { "say": "All blank lines gone. The file went from twelve lines to five. Clean and compact." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "G slash caret dollar slash D. Delete all blank lines. A classic Vim one-liner." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f demo.txt" }
  ]
