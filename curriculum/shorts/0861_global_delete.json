{
  "title": "VimFu — :g with :d — Delete Blank Lines",
  "description": "Use :g/^$/d to delete all blank lines in a file. The pattern ^$ matches empty lines.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 763,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
