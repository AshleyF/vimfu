{
  "title": "VimFu — The : Register",
  "description": "The \": register contains the last Ex command you ran. Use it to recall or paste your previous command.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 640,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "advanced"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f cmdreg.txt .cmdreg.txt.swp .cmdreg.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "cmdreg.txt",
      "content": "one\ntwo\nthree\nfour\nfive"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim cmdreg.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "The : Register",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "The colon register, quote colon, stores the last ex command you ran."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Run a substitution command first.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":%s/two/TWO/g",
      "beforeEnter": 1.1
    },
    {
      "wait": 0.5
    },
    {
      "say": "That command is now in the colon register. It stores the last Ex command, without the leading colon.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "say": "Open a note line. In insert mode, {key:Ctrl-R} then {key::} inserts that register.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "Go",
      "overlay": "new note line"
    },
    {
      "wait": 0.3
    },
    {
      "type": "Last command: "
    },
    {
      "keys": "ctrl+r",
      "overlay": "insert register"
    },
    {
      "type": ":"
    },
    {
      "keys": "escape"
    },
    {
      "wait": 0.6
    },
    {
      "say": "The command is now in the file. {key:Ctrl-R}{key::} inserted the colon register."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f cmdreg.txt"
    }
  ],
  "youtube": {
    "videoId": "uL3Fk2ZhuBc",
    "url": "https://youtube.com/watch?v=uL3Fk2ZhuBc"
  }
}
