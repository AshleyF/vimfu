{
  "title": "VimFu — What Is Surround?",
  "description": "The surround plugin lets you add, change, and delete surroundings -- parentheses, brackets, quotes, and tags.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 659,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f surround.py .surround.py.swp .surround.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "surround.py",
      "content": "title = \"hello\"\ncoords = (10, 20)\nflag = enabled\nlabel = important"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim surround.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "What Is Surround?",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Surround lets you add, change, and delete wrappers: quotes, parentheses, brackets, and HTML tags."
    },
    {
      "wait": 0.3
    },
    {
      "say": "We'll use each family once, and keep the edits on screen."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Think of it this way: {key:d}{key:s} deletes a surround. {key:c}{key:s} changes one. {key:y}{key:s} adds one.",
      "wait": false
    },
    {
      "wait": 0.5
    },
    {
      "say": "Start with double quotes around hello. Delete them with {key:d}{key:s}{key:\"}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "f\"",
      "overlay": ""
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:d}{key:s}{key:\"} deletes the surrounding quotes.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ds\"",
      "overlay": "ds\""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Quotes gone. Now put back single quotes with {key:y}{key:s}{key:i}{key:w}{key:'}.",
      "wait": false
    },
    {
      "keys": "ysiw'",
      "overlay": "ysiw'"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Line two: change parentheses to brackets with {key:c}{key:s}{key:)}{key:]}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jf(",
      "overlay": "coords"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cs)]",
      "overlay": "cs)]"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Line three: add parentheses around enabled.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j0ww",
      "overlay": "enabled"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiw)",
      "overlay": "ysiw)"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Line four: add an em tag around important.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "j0ww",
      "overlay": "important"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ysiwtem>\r",
      "overlay": "ysiwt em>"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Delete, change, add, and tags. That's the shape of surround."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f surround.py"
    }
  ],
  "youtube": {
    "videoId": "vOikNlXurD4",
    "url": "https://youtube.com/watch?v=vOikNlXurD4"
  }
}
