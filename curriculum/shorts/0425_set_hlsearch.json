{
  "title": "VimFu — :set hlsearch",
  "description": "Toggle search highlighting with :set hlsearch and :set nohlsearch in Vim.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 566,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "settings"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\ndef greet(name):\n    return f\"Hello {name}\"\n\nresult = greet(\"World\")\nprint(result)"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":set hlsearch",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "The hlsearch setting highlights all matches when you search. It's usually on by default."
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set hlsearch",
      "overlay": ":set hlsearch"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "type": "/name",
      "overlay": "/name"
    },
    "enter",
    {
      "wait": 1.0
    },
    {
      "say": "After searching for name, every match is highlighted. This makes it easy to spot all occurrences."
    },
    {
      "wait": 0.5
    },
    {
      "say": "To disable highlighting, use set nohlsearch."
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set nohlsearch",
      "overlay": ":set nohlsearch"
    },
    "enter",
    {
      "wait": 1.0
    },
    {
      "say": "The highlights are gone. The shorthand is set hls and set nohls."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "vRm_nbEBzx0",
    "url": "https://youtube.com/watch?v=vRm_nbEBzx0"
  }
}
