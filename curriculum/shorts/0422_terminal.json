{
  "title": "VimFu — :terminal Terminal Inside Vim",
  "description": "The :terminal command opens a terminal emulator inside Vim.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 563,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "terminal"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\nprint(\"hi\")"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":terminal — Terminal",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "`:terminal` opens a full terminal inside Vim. A shell right in your editor."
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":terminal",
      "overlay": ":terminal",
      "beforeEnter": 1.1
    },
    {
      "wait": 0.8
    },
    {
      "say": "Neovim opens the terminal buffer in *normal mode,* so press {key:i} before typing shell commands."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "i",
      "overlay": "terminal input"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now run `ls` inside the embedded shell.",
      "wait": false
    },
    {
      "wait": 0.2
    },
    {
      "type": "ls",
      "overlay": ""
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "That command ran in the terminal buffer. To return to terminal *normal mode,* press {key:Ctrl-\\\\}, then {key:Ctrl-N}."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u001c\u000e",
      "overlay": "normal mode"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Now you can navigate the terminal buffer with Vim keys. Close it with `:bd!` or `:q`."
    },
    {
      "wait": 0.3
    },
    {
      "say": "`:terminal`. Open a shell, press {key:i} to type shell commands, and use {key:Ctrl-\\\\}, then {key:Ctrl-N} to get back."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":qa!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "lN36WuDqf5Q",
    "url": "https://youtube.com/watch?v=lN36WuDqf5Q"
  }
}
