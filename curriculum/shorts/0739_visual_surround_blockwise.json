{
  "title": "VimFu — Visual Surround — Blockwise",
  "description": "In blockwise visual mode (Ctrl-V), S surrounds each line in the block individually.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 698,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f cols.txt .cols.txt.swp .cols.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "cols.txt",
      "content": "alpha = 1\nbeta  = 2\ngamma = 3"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim cols.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Visual Surround — Blockwise",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "In block visual mode, capital S surrounds each line individually. Every line in the block gets its own pair."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Select the numbers in a block. Control V, then move down.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "f1",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0016jj",
      "overlay": "Ctrl-V → select block"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Capital S, double quote.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "S\"",
      "overlay": "S\""
    },
    {
      "wait": 0.8
    },
    {
      "say": "Each number is individually wrapped in quotes. One, two, three, each quoted."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Block visual S. Surround each line in the block separately."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f cols.txt"
    }
  ]
}
