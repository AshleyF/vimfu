{
  "title": "VimFu \u2014 v_d / v_c \u2014 Delete/Change",
  "description": "In visual mode, d deletes the selected text. c deletes the selection and drops you into insert mode to type a replacement.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 591,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "visual mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f pets.py .pets.py.swp .pets.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "pets.py",
      "content": "# pets\ncat = \"whiskers\"\ndog = \"buddy\"\nfish = \"nemo\"\nbird = \"tweety\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim pets.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "v_d / v_c",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "In visual mode, D deletes the selection. C deletes and enters insert mode for a replacement."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Select the fish line. Capital V, then D.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "3j"
    },
    {
      "keys": "V",
      "overlay": "select line"
    },
    {
      "wait": 0.4
    },
    {
      "keys": "d",
      "overlay": "delete"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Line gone. D removes the selection completely."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.4
    },
    {
      "say": "Now let's use C. Select the name whiskers.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gg0jf\""
    },
    {
      "keys": "vi\"",
      "overlay": "select inside quotes"
    },
    {
      "wait": 0.5
    },
    {
      "say": "C to change it.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "c",
      "overlay": "change"
    },
    {
      "wait": 0.4
    },
    {
      "type": "mittens"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Selection deleted, typed the replacement. Now escape.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "say": "Whiskers became mittens. C is select, delete, insert, all in one."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u"
    },
    {
      "wait": 0.3
    },
    {
      "say": "D to delete a selection. C to change it. Two essential visual mode operations."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f pets.py"
    }
  ]
}
