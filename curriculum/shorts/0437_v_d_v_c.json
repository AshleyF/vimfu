{
  "title": "VimFu — Visual Delete/Change",
  "description": "Use visual delete or change when the range is awkward enough that selecting it first makes sense.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 591,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "visual mode"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f note.txt .note.txt.swp .note.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "note.txt",
      "content": "# launch note\nPlease replace the old staging setup\nbefore the demo, then notify QA."
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim note.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "visual delete/change",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Visual delete and change are for ranges you want to see before you commit."
    },
    {
      "wait": 0.3
    },
    {
      "say": "This edit changes from `old` through `demo` across the line break.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jwww",
      "overlay": "start"
    },
    {
      "keys": "v",
      "overlay": "visual"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "/",
      "overlay": "search end"
    },
    {
      "type": "demo"
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.4
    },
    {
      "keys": "e",
      "overlay": "extend"
    },
    {
      "wait": 0.5
    },
    {
      "say": "If one motion names the range -- a word, a line, text inside quotes -- use the operator and that motion. Here, the visible selection is the point.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "c",
      "overlay": "change"
    },
    {
      "type": "production backup"
    },
    {
      "wait": 0.4
    },
    "escape",
    {
      "wait": 0.5
    },
    {
      "say": "{key:c} replaced the selected range. {key:d} would delete the same awkward span."
    },
    {
      "wait": 0.4
    },
    {
      "say": "Use visual delete and change when the shape is easier to see than to name."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f note.txt"
    }
  ],
  "youtube": {
    "videoId": "yVSJmFG6JgQ",
    "url": "https://youtube.com/watch?v=yVSJmFG6JgQ"
  }
}
