{
  "title": "VimFu — :set incsearch",
  "description": "Enable incremental search with :set incsearch to see matches as you type in Vim.",
  "speed": 0.55, "rows": 20, "cols": 40, "humanize": 0.7, "seed": 567,
  "ttsVoice": "echo", "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands", "settings"],
  "setup": [
    { "line": "export TERM=xterm-256color" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.py .demo.py.swp" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "writeFile": "demo.py", "content": "# Demo\ndef greet(name):\n    return f\"Hello {name}\"\n\nresult = greet(\"World\")\nprint(result)" },
    { "line": "clear" },
    { "line": "nvim demo.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "overlay": "VimFu", "caption": ":set incsearch", "duration": 2.0 },
    { "wait": 0.7 },
    { "say": "Incremental search shows matches in real time as you type your search pattern." },
    { "wait": 0.3 },
    { "type": ":set incsearch", "overlay": ":set incsearch" },
    "enter",
    { "wait": 0.5 },
    { "say": "Watch how the cursor jumps to the first match as I type each character." },
    { "wait": 0.3 },
    { "type": "/g" },
    { "wait": 0.5 },
    { "type": "r" },
    { "wait": 0.5 },
    { "type": "e" },
    { "wait": 0.5 },
    { "type": "e" },
    { "wait": 0.5 },
    { "type": "t" },
    { "wait": 0.5 },
    "enter",
    { "wait": 0.7 },
    { "say": "The cursor moved to greet as I typed. Without incsearch, Vim only jumps after you press enter." },
    { "wait": 1.5 }
  ],
  "teardown": [ "escape", { "type": ":q!" }, "enter", { "line": "rm -f demo.py" } ]
}
