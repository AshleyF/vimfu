{
  "title": "VimFu — :set incsearch",
  "description": "Enable incremental search with :set incsearch to see matches as you type in Vim.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 567,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands",
    "settings"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "# Demo\nred_alert = True\nready = False\nreturn_value = 42\nprint(return_value)"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":set incsearch",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "`incsearch` shows matches in real time as you type your search pattern."
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":set incsearch",
      "overlay": ":set incsearch",
      "beforeEnter": 1.1
    },
    {
      "wait": 0.5
    },
    {
      "say": "Watch the early pattern match the wrong line first, then jump to the right line as the pattern becomes more specific."
    },
    {
      "wait": 0.3
    },
    {
      "type": "/"
    },
    {
      "wait": 0.3
    },
    {
      "type": "r"
    },
    {
      "wait": 0.5
    },
    {
      "type": "e"
    },
    {
      "wait": 0.5
    },
    {
      "type": "t"
    },
    {
      "wait": 0.5
    },
    "enter",
    {
      "wait": 0.7
    },
    {
      "say": "`r` and `re` match `red_alert`. When the pattern becomes `ret`, `incsearch` jumps to `return_value` before {key:Enter}."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "LtE_evTprDM",
    "url": "https://youtube.com/watch?v=LtE_evTprDM"
  }
}
