{
  "title": "VimFu — Ctrl-B / Ctrl-E — Start/End",
  "description": "Use {key:Ctrl-B} to jump to the beginning and {key:Ctrl-E} to jump to the end of the command line.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 608,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "command line"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp .demo.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.py",
      "content": "# demo\nfoo = \"foo\"\nother = \"foo\"\nmessage = \"foo foo\""
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Ctrl-B / Ctrl-E — Start/End",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:Ctrl-B} jumps to the beginning of the command line. {key:Ctrl-E} jumps to the end."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Start with a local substitute: `:s/foo/bar`. Then decide it should cover the whole file and every match.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":s/foo/bar"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Use {key:Ctrl-B} to jump back and add `%` before the command.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ctrl+b",
      "overlay": "beginning"
    },
    {
      "wait": 0.3
    },
    {
      "type": "%"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Now use {key:Ctrl-E} to jump to the end and add `/g`.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "ctrl+e",
      "overlay": "end"
    },
    {
      "wait": 0.3
    },
    {
      "type": "/g"
    },
    {
      "wait": 0.6
    },
    {
      "say": "The command is now `:%s/foo/bar/g`: whole file, every match.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter",
      "overlay": "run"
    },
    {
      "wait": 0.8
    },
    {
      "say": "{key:Ctrl-B} and {key:Ctrl-E} are useful when you need to edit both ends of a command before running it."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "Ox6hTfSO7Pg",
    "url": "https://youtube.com/watch?v=Ox6hTfSO7Pg"
  }
}
