{
  "title": "VimFu — :retab — Fix Tabs",
  "description": "Use :retab to convert between tabs and spaces based on your expandtab and tabstop settings.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 808,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.py .demo.py.swp .demo.py.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file with tabs" },
    { "writeFile": "demo.py", "content": "def hello():\n\tprint(\"hi\")\n\treturn True\n\ndef world():\n\tprint(\"world\")" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim demo.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":retab — Fix Tabs", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "Re tab converts tabs to spaces or spaces to tabs based on your settings. Fix mixed indentation in one command." },
    { "wait": 0.3 },
    { "comment": "--- Demo: show tabs with list ---" },
    { "say": "Turn on list mode to see the tabs.", "wait": false },
    { "wait": 0.3 },
    { "type": ":set list", "overlay": ":set list" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Those arrows are tab characters. Convert them to spaces.", "wait": false },
    { "wait": 0.3 },
    { "comment": "--- Demo: retab ---" },
    { "type": ":set expandtab tabstop=4", "overlay": ":set et ts=4" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.3 },
    { "type": ":retab", "overlay": ":retab" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Tabs replaced with four spaces each. The file now uses consistent spacing." },
    { "wait": 0.3 },
    { "type": ":set nolist" },
    "enter",
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Colon re tab. Fix indentation across the whole file. Set expand tab and tab stop first to control the output." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f demo.py" }
  ]
}
