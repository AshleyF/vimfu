{
  "title": "VimFu — :[range]> Indent Lines",
  "description": "The :> ex command shifts lines right by one shiftwidth. Use a range to indent specific lines.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 755,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp .demo.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.py",
      "content": "def greet():\nprint(\"hello\")\nprint(\"world\")\nreturn True\n\nx = greet()"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim -c 'set shiftwidth=4' demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":[range]> — Indent Lines",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Colon greater than shifts lines to the right. It adds one shiftwidth of indentation."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: indent single line ---"
    },
    {
      "say": "Indent line two. It should be inside the function.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":2>",
      "overlay": ":2>"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Line two shifted right by four spaces."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: indent range ---"
    },
    {
      "say": "Indent lines three and four together.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":3,4>",
      "overlay": ":3,4>"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "enter"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Both lines indented. Now the function body is properly indented."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Colon range greater than. Indent lines from the command line."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "chMeFGkU_iw",
    "url": "https://youtube.com/watch?v=chMeFGkU_iw"
  }
}
