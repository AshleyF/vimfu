{
  "title": "VimFu \u2014 :set fdm=syntax \u2014 Fold by Syntax",
  "description": "Set the fold method to syntax to create folds based on the language syntax, such as functions, classes, and blocks.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 650,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "advanced"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f syntax.c .syntax.c.swp .syntax.c.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "syntax.c",
      "content": "#include <stdio.h>\n\nint add(int a, int b) {\n    return a + b;\n}\n\nint main() {\n    int x = add(3, 4);\n    printf(\"%d\\n\", x);\n    return 0;\n}"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim syntax.c"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Fold by Syntax",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "Syntax-based folding uses the language's syntax rules to create folds. Functions, blocks, and other structures fold automatically."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Set the fold method to syntax.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set foldmethod=syntax"
    },
    "enter",
    {
      "wait": 0.6
    },
    {
      "say": "The C functions may have folded based on their brace blocks. Close all folds with Z M.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "zM",
      "overlay": "close all"
    },
    {
      "wait": 0.6
    },
    {
      "say": "The function bodies are hidden. Only the signatures and braces remain visible."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Open just the add function. Move to it and press Z O.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "gg"
    },
    {
      "keys": "2j"
    },
    {
      "keys": "zo",
      "overlay": "open fold"
    },
    {
      "wait": 0.6
    },
    {
      "say": "The add function is open while main stays folded. Syntax folding knows where each block starts and ends."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Open everything with Z R.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "zR",
      "overlay": "open all"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Set fold method syntax. It uses the language definition to create meaningful folds. Great for C, JavaScript, and other brace-based languages."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f syntax.c"
    }
  ]
}
