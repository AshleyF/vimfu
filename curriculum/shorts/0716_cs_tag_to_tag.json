{
  "title": "VimFu — Change Tag to Tag",
  "description": "{key:c}{key:s}{key:t} opens a prompt for changing the nearest tag pair to a new tag.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 675,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f swap.html .swap.html.swp .swap.html.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "swap.html",
      "content": "<p>Hello World</p>\n<span>Click Me</span>\n<em>important</em>"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim swap.html"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change Tag to Tag",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "{key:c}{key:s}{key:t} changes the nearest tag to a new tag. After {key:t}, type the replacement tag at the bottom prompt."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside the paragraph tag. Press {key:c}{key:s}{key:t}; when the prompt appears, type `div>`.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fH",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cst"
    },
    {
      "wait": 0.8
    },
    {
      "type": "div>"
    },
    {
      "wait": 0.5
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "The prompt text changed both the opening and closing tags."
    },
    {
      "say": "Line two: use the same prompt to change span to strong.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfC",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "keys": "cst"
    },
    {
      "wait": 0.8
    },
    {
      "type": "strong>"
    },
    {
      "wait": 0.5
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Both lines changed tags. {key:c}{key:s}{key:t} starts the change; the new tag name is typed at the bottom."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f swap.html"
    }
  ],
  "youtube": {
    "videoId": "djCDS6VW4Ic",
    "url": "https://youtube.com/watch?v=djCDS6VW4Ic"
  }
}
