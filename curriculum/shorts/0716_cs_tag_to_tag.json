{
  "title": "VimFu — Change Tag to Tag",
  "description": "cst<div> changes the nearest tag to a different tag.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 675,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f swap.html .swap.html.swp .swap.html.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "swap.html",
      "content": "<p>Hello World</p>\n<span>Click Me</span>\n<em>important</em>"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim swap.html"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Change Tag to Tag",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "C S T changes the nearest tag to a new tag. T as the target means find the enclosing tag."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Cursor inside the P tag. C S T, then type the new tag.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fH",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "type": "cst<div>",
      "overlay": "cst<div>"
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "P tag became div tag. Both opening and closing updated."
    },
    {
      "wait": 0.3
    },
    {
      "keys": "u",
      "overlay": "undo"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Line two. Change span to strong.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfC",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "type": "cst<strong>",
      "overlay": "cst<strong>"
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Span became strong. C S T. Tag to tag in one move."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f swap.html"
    }
  ]
}
