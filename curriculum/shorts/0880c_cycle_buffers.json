{
  "title": "VimFu — :bn / :bp — Cycle Buffers",
  "description": "Use :bnext (:bn) and :bprev (:bp) to cycle through open buffers.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 791,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f alpha.py beta.py gamma.py .*.swp .*.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo files" },
    { "writeFile": "alpha.py", "content": "# Alpha file\nprint(\"alpha\")" },
    { "writeFile": "beta.py", "content": "# Beta file\nprint(\"beta\")" },
    { "writeFile": "gamma.py", "content": "# Gamma file\nprint(\"gamma\")" },
    { "line": "clear" },
    { "comment": "Launch nvim with multiple files" },
    { "line": "nvim alpha.py beta.py gamma.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":bn / :bp — Cycle Buffers", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "B next and B previous cycle through your open buffers. Quick way to switch files." },
    { "wait": 0.3 },
    { "comment": "--- Demo: cycle forward ---" },
    { "say": "Go to the next buffer.", "wait": false },
    { "wait": 0.3 },
    { "type": ":bn", "overlay": ":bn" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Now in beta. Next again.", "wait": false },
    { "wait": 0.3 },
    { "type": ":bn", "overlay": ":bn" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Gamma. It wraps around.", "wait": false },
    { "wait": 0.3 },
    { "comment": "--- Demo: cycle backward ---" },
    { "say": "Go back with B previous.", "wait": false },
    { "wait": 0.3 },
    { "type": ":bp", "overlay": ":bp" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Back to beta. B next and B prev. Simple cycling." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Colon B N for next, colon B P for previous. Cycle through all your buffers." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":qa!" },
    "enter",
    { "line": "rm -f alpha.py beta.py gamma.py" }
  ]
}
