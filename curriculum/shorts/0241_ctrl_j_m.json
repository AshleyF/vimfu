    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control J moves down like J. Control M moves to the next line first non-blank, like Enter. Why care? You can remap J to something else and still move down with Control J."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: Ctrl-J moves down ---"
    },
    {
      "say": "Control J. Down one line, same column.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ctrl": "j",
      "overlay": "down"
    },
    {
      "wait": 0.4
    },
    {
      "ctrl": "j",
      "overlay": "down"
    },
    {
      "wait": 0.4
    },
    {
      "ctrl": "j",
      "overlay": "down"
    },
    {
      "wait": 0.5
    },
    {
      "say": "Three lines down. Column zero stays at zero, just like J."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 2: Ctrl-M ---"
    },
    {
      "say": "Back to the top. Now Control M.",
