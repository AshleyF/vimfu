{
  "title": "VimFu — Querying Settings with ?",
  "description": "Use :set option? to check the current value of any setting.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 780,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.txt",
      "content": "Hello world\nThis is a demo\nFor querying settings"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Querying Settings with ?",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Add a question mark after any setting name to see its current value. Works for booleans and numbers."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: query boolean setting ---"
    },
    {
      "say": "Check if line numbers are on.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set number?",
      "overlay": ":set number?"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Append a question mark to any option name to see its current value."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "It says no number. Line numbers are off. Turn them on and check again.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "type": ":set number"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Turn line numbers on."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.3
    },
    {
      "type": ":set number?",
      "overlay": ":set number?"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Query again — confirm the new value."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    "enter",
    {
      "comment": "--- Demo: query numeric setting ---"
    },
    {
      "say": "Query a numeric setting. Check tab stop.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set tabstop?",
      "overlay": ":set ts?"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Same question mark syntax works for numeric options too."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Tab stop equals eight. That's the default."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Set option question mark. Quick way to check any setting value."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.txt"
    }
  ],
  "youtube": {
    "videoId": "lfNSJSGT1oQ",
    "url": "https://youtube.com/watch?v=lfNSJSGT1oQ"
  }
}
