{
  "title": "VimFu — :retab Fix Tabs",
  "description": "Convert between tabs and spaces with :retab.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 580,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.py .demo.py.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.py",
      "content": "def hello():\n\tprint(\"hi\")\n\tif True:\n\t\tprint(\"yes\")"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim +'set list listchars=tab:>-,space:.' demo.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":retab — Fix Tabs",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "`:retab` converts tabs to spaces based on your `tabstop` and `expandtab` settings. Tabs show as `>---`; spaces show as dots."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Set `expandtab` and `tabstop` to four.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":set expandtab tabstop=4",
      "overlay": ":set et ts=4",
      "beforeEnter": 1.2
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now run `:retab`.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "ex": ":retab",
      "overlay": ":retab",
      "beforeEnter": 1.2
    },
    {
      "wait": 0.5
    },
    {
      "say": "The tab markers disappear. The indentation is now ordinary spaces, shown as dots."
    },
    {
      "wait": 0.3
    },
    {
      "say": "`:retab!` also replaces sequences of spaces with tabs. `:retab` is the quick fix for mixed indentation."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.py"
    }
  ],
  "youtube": {
    "videoId": "BtTLabOnvdA",
    "url": "https://youtube.com/watch?v=BtTLabOnvdA"
  }
}
