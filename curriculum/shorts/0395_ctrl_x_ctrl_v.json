  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.vim .demo.vim.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.vim",
      "content": "let g:loaded = 1\n"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.vim"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-X Ctrl-V \u2014 Vim Commands",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Control X Control V completes Vim commands. When you're writing Vim script, it suggests command names, options, and variables."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: complete a vim command ---"
    },
    {
      "say": "Let's write a Vim script line.",
