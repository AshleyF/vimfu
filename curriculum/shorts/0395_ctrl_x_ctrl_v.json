    },
    {
      "wait": 0.3
    },
    {
      "keys": "Go",
      "overlay": "new line"
    },
    {
      "wait": 0.3
    },
    {
      "type": "set",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "say": "Control X Control V to see Vim completions.",
      "wait": false
    },
    {
      "wait": 0.3
