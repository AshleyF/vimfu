{
  "title": "VimFu — Ctrl-X Ctrl-V Vim Command Complete",
  "description": "Ctrl-X Ctrl-V in insert mode completes Vim command-line words — useful for scripting.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 536,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "insert mode",
    "completion"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.vim .demo.vim.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "demo.vim",
      "content": "let g:loaded = 1\n"
    },
    {
      "line": "clear"
    },
    {
      "line": "nvim demo.vim"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": "Ctrl-X Ctrl-V — Vim Commands",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Press {key:Ctrl-X}, then {key:Ctrl-V} in *insert mode* to complete Vim command names while editing Vimscript."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo 1: complete a vim command ---"
    },
    {
      "say": "Start a new Vimscript line and type the command prefix `setl`.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "Go",
      "overlay": "new line"
    },
    {
      "wait": 0.3
    },
    {
      "type": "setl",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "say": "Now invoke Vim command completion.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "\u0018\u0016",
      "overlay": "vim commands"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Vim fills in `setlocal`, the only matching command name.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": " number",
      "overlay": "finish line"
    },
    {
      "wait": 0.3
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "{key:Ctrl-X}, then {key:Ctrl-V}. Vim command completion helps you write Vimscript and `vimrc` lines without spelling every command by hand."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.vim"
    }
  ],
  "youtube": {
    "videoId": "XBYBfpdCais",
    "url": "https://youtube.com/watch?v=XBYBfpdCais"
  }
}
