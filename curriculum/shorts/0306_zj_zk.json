  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f dungeon.py .dungeon.py.swp .dungeon.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file with multiple functions"
    },
    {
      "writeFile": "dungeon.py",
      "content": "# Dungeon Generator\ndef gen_room(size):\n    width = size * 2\n    height = size\n    return width, height\n\ndef gen_monster(level):\n    hp = level * 50\n    attack = level * 10\n    return hp, attack\n\ndef gen_treasure(rarity):\n    gold = rarity * 100\n    item = pick_item(rarity)\n    return gold, item\n\ndef gen_trap(danger):\n    damage = danger * 25\n    return damage"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim with indent folds closed"
    },
    {
      "line": "nvim -c 'set foldmethod=indent' -c 'set number' dungeon.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
