{
  "title": "VimFu — Delete — Opening Mark Trims Space",
  "description": "{key:d}{key:s}{key:(} vs {key:d}{key:s}{key:)} -- using the opening mark also removes inner whitespace.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 666,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "surround"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f spaces.py .spaces.py.swp .spaces.py.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "spaces.py",
      "content": "val = ( x + y )\ncopy = ( x + y )"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim +'set list listchars=space:.' spaces.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": "Opening Mark Trims Space",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "say": "When you delete surroundings, the closing mark just removes the pair. But the opening mark also trims inner whitespace."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Spaces are shown as dots, so the difference is visible."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Line one has spaces inside the parentheses. {key:d}{key:s}{key:)}.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "fx",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "ds)"
    },
    {
      "wait": 0.8
    },
    {
      "keys": "ds)"
    },
    {
      "wait": 0.8
    },
    {
      "say": "Parens removed, but the inner spaces remain. Leave that result on line one."
    },
    {
      "say": "Now use {key:d}{key:s}{key:(} on line two.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jfx",
      "overlay": ""
    },
    {
      "wait": 0.3
    },
    {
      "overlay": "ds("
    },
    {
      "wait": 0.8
    },
    {
      "keys": "ds("
    },
    {
      "wait": 0.8
    },
    {
      "say": "Now compare them. Line one kept the inner spaces. Line two trimmed them."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Closing mark, keep spaces. Opening mark, trim spaces. Same rule applies to brackets and braces."
    },
    {
      "wait": 1.0
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "comment": "Clean up"
    },
    {
      "line": "rm -f spaces.py"
    }
  ],
  "youtube": {
    "videoId": "ORXoFOZH-JM",
    "url": "https://youtube.com/watch?v=ORXoFOZH-JM"
  }
}
