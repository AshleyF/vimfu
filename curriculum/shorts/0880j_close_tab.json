{
  "title": "VimFu — :tabc — Close Tab",
  "description": "Use :tabclose (:tabc) to close the current tab.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 798,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f a.py b.py c.py .*.swp .*.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo files" },
    { "writeFile": "a.py", "content": "# File A" },
    { "writeFile": "b.py", "content": "# File B" },
    { "writeFile": "c.py", "content": "# File C" },
    { "line": "clear" },
    { "comment": "Launch nvim with tabs" },
    { "line": "nvim -p a.py b.py c.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":tabc — Close Tab", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "Tab close closes the current tab. The buffer stays in memory, just the tab goes away." },
    { "wait": 0.3 },
    { "comment": "--- Demo: go to middle tab and close ---" },
    { "say": "Move to the second tab and close it.", "wait": false },
    { "wait": 0.3 },
    { "keys": "gt" },
    { "wait": 0.6 },
    { "type": ":tabc", "overlay": ":tabclose" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Tab B is gone. Now two tabs remain. The buffer is still accessible with colon B." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Colon tab close or colon tab C. Close the current tab without losing the buffer." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":qa!" },
    "enter",
    { "line": "rm -f a.py b.py c.py" }
  ]
}
