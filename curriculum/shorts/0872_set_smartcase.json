{
  "title": "VimFu — :set smartcase",
  "description": "Use :set smartcase (or :set scs) with ignorecase to be case-insensitive unless you type an uppercase letter.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 774,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "comment": "Set TERM for proper color support in Neovim"
    },
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "comment": "Prepare workspace"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "comment": "Create demo file"
    },
    {
      "writeFile": "demo.txt",
      "content": "Error: file not found\nerror in config\nERROR: disk full\nNo error here\nFatal Error detected"
    },
    {
      "line": "clear"
    },
    {
      "comment": "Launch nvim"
    },
    {
      "line": "nvim demo.txt"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "comment": "--- Title card ---"
    },
    {
      "overlay": "VimFu",
      "caption": ":set smartcase",
      "duration": 2.0
    },
    {
      "wait": 0.5
    },
    {
      "comment": "--- Intro ---"
    },
    {
      "say": "Smart case works with ignore case. Search lowercase to match everything. Include an uppercase letter to match exact case."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: enable both settings ---"
    },
    {
      "say": "Turn on both settings.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":set ignorecase smartcase hlsearch",
      "overlay": ":set ignorecase smartcase hlsearch"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Three options at once — ignore case, smart case, highlight matches."
    },
    {
      "wait": 0.4
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "comment": "--- Demo: lowercase search ---"
    },
    {
      "say": "Search lowercase error. Matches all cases.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": "/error",
      "overlay": "/error"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Lowercase pattern — smart case treats this as case insensitive."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "All five lines match. Now search with a capital E.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Demo: uppercase search ---"
    },
    {
      "type": "/Error",
      "overlay": "/Error"
    },
    {
      "wait": 0.6
    },
    {
      "say": "Capital E in the pattern — smart case switches to exact case."
    },
    {
      "wait": 0.3
    },
    "enter",
    {
      "wait": 0.8
    },
    {
      "say": "Only two matches. Smart case detected the capital letter and switched to exact case."
    },
    {
      "wait": 0.3
    },
    {
      "comment": "--- Wrap up ---"
    },
    {
      "say": "Set smart case or S C S. Lowercase matches all, uppercase exact."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    {
      "comment": "Quit nvim without saving"
    },
    "escape",
    {
      "type": ":q!"
    },
    "enter",
    {
      "line": "rm -f demo.txt"
    }
  ],
  "youtube": {
    "videoId": "iO9f66TGw64",
    "url": "https://youtube.com/watch?v=iO9f66TGw64"
  }
}
