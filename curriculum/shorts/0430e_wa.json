{
  "title": "VimFu \u2014 :wa Write All",
  "description": "Save all modified buffers at once.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 576,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": [
    "vim",
    "neovim",
    "nvim",
    "vimfu",
    "tutorial",
    "terminal",
    "editor",
    "coding",
    "programming",
    "ex commands"
  ],
  "setup": [
    {
      "line": "export TERM=xterm-256color"
    },
    {
      "line": "mkdir -p ~/vimfu && cd ~/vimfu"
    },
    {
      "line": "rm -f a.py b.py .*.swp"
    },
    {
      "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null"
    },
    {
      "writeFile": "a.py",
      "content": "# File A"
    },
    {
      "writeFile": "b.py",
      "content": "# File B"
    },
    {
      "line": "clear"
    },
    {
      "line": "sleep 0.5"
    },
    {
      "line": "nvim a.py b.py"
    },
    {
      "waitForScreen": "All",
      "timeout": 30.0
    },
    {
      "ifScreen": "swap file",
      "thenKeys": "d"
    }
  ],
  "steps": [
    {
      "overlay": "VimFu",
      "caption": ":wa \u2014 Write All",
      "duration": 2.0
    },
    {
      "wait": 0.7
    },
    {
      "say": "Colon W A saves all modified buffers at once. Every open file, saved in one command."
    },
    {
      "wait": 0.3
    },
    {
      "say": "Make changes in both files.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "keys": "jA",
      "overlay": "append"
    },
    {
      "type": "\nx = 1",
      "overlay": ""
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "type": ":bn",
      "overlay": ":bn"
    },
    "enter",
    {
      "wait": 0.3
    },
    {
      "keys": "jA",
      "overlay": "append"
    },
    {
      "type": "\ny = 2",
      "overlay": ""
    },
    {
      "keys": "escape",
      "overlay": "Esc"
    },
    {
      "wait": 0.3
    },
    {
      "say": "Save everything.",
      "wait": false
    },
    {
      "wait": 0.3
    },
    {
      "type": ":wa",
      "overlay": "write all"
    },
    "enter",
    {
      "wait": 0.5
    },
    {
      "say": "All buffers saved. One command instead of switching and saving each file."
    },
    {
      "wait": 1.5
    }
  ],
  "teardown": [
    "escape",
    {
      "type": ":qa!"
    },
    "enter",
    {
      "line": "rm -f a.py b.py"
    }
  ]
}
