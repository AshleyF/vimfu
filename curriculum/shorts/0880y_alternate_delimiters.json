{
  "title": "VimFu — :s Alternate Delimiters",
  "description": "Use any character as the substitute delimiter instead of slash — useful when the pattern contains slashes.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 813,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f paths.txt .paths.txt.swp .paths.txt.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file with file paths" },
    { "writeFile": "paths.txt", "content": "/usr/local/bin/python\n/usr/local/lib/libfoo.so\n/usr/local/share/docs" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim paths.txt" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":s Alternate Delimiters", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "When your search or replacement contains slashes, escaping them gets ugly. Use a different delimiter instead." },
    { "wait": 0.3 },
    { "comment": "--- Demo: use # as delimiter ---" },
    { "say": "Replace usr local with opt using hash as the delimiter.", "wait": false },
    { "wait": 0.3 },
    { "type": ":%s#/usr/local#/opt#g", "overlay": ":%s#/usr/local#/opt#g" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Clean. No escaped slashes. The hash separates the pattern from the replacement." },
    { "wait": 0.3 },
    { "comment": "--- Demo: undo and use ! ---" },
    { "say": "Undo. You can use almost any character. Try exclamation mark.", "wait": false },
    { "wait": 0.3 },
    { "keys": "u" },
    { "wait": 0.5 },
    { "type": ":%s!/usr/local!/opt!g", "overlay": ":%s!/usr/local!/opt!g" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Same result. Pick whatever character doesn't appear in your pattern." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Any character works as a delimiter. Hash, bang, pipe, at sign. Pick one that avoids escaping." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f paths.txt" }
  ]
}
