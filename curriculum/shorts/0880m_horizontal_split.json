{
  "title": "VimFu — :sp — Horizontal Split",
  "description": "Use :split (:sp) to split the window horizontally, showing the same or a different file.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 801,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.py other.py .*.swp .*.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo files" },
    { "writeFile": "demo.py", "content": "def greet():\n    print(\"hello\")\n\ndef farewell():\n    print(\"bye\")" },
    { "writeFile": "other.py", "content": "# Another file\nx = 42" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim demo.py" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":sp — Horizontal Split", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "Split creates a horizontal split. Two windows stacked top and bottom." },
    { "wait": 0.3 },
    { "comment": "--- Demo: split same file ---" },
    { "say": "Split the current file.", "wait": false },
    { "wait": 0.3 },
    { "type": ":sp", "overlay": ":split" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Two windows showing the same file. Edit the top, scroll the bottom independently." },
    { "wait": 0.3 },
    { "comment": "--- Demo: split with different file ---" },
    { "say": "You can also split and open a different file.", "wait": false },
    { "wait": 0.3 },
    { "type": ":sp other.py", "overlay": ":sp other.py" },
    { "wait": 0.3 },
    "enter",
    { "wait": 0.8 },
    { "say": "Now three windows. Use control W and arrow keys to move between them." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Colon split or colon S P. Horizontal window split. Add a filename to open a different file." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":qa!" },
    "enter",
    { "line": "rm -f demo.py other.py" }
  ]
}
