{
  "title": "VimFu — :norm on a Range",
  "description": "Limit :norm to specific lines by giving it a range like :5,10norm dd.",
  "speed": 0.55,
  "rows": 20,
  "cols": 40,
  "humanize": 0.7,
  "seed": 761,
  "ttsVoice": "echo",
  "playlist": "VimFu",
  "tags": ["vim", "neovim", "nvim", "vimfu", "tutorial", "terminal", "editor", "coding", "programming", "ex commands"],
  "setup": [
    { "comment": "Set TERM for proper color support in Neovim" },
    { "line": "export TERM=xterm-256color" },
    { "comment": "Prepare workspace" },
    { "line": "mkdir -p ~/vimfu && cd ~/vimfu" },
    { "line": "rm -f demo.txt .demo.txt.swp .demo.txt.swo" },
    { "line": "find ~/.local/state/nvim/swap -mindepth 1 -delete 2>/dev/null" },
    { "comment": "Create demo file" },
    { "writeFile": "demo.txt", "content": "keep this\nkeep this\ndelete me\ndelete me\ndelete me\nkeep this\nkeep this" },
    { "line": "clear" },
    { "comment": "Launch nvim" },
    { "line": "nvim demo.txt" },
    { "waitForScreen": "All", "timeout": 30.0 },
    { "ifScreen": "swap file", "thenKeys": "d" }
  ],
  "steps": [
    { "comment": "--- Title card ---" },
    { "overlay": "VimFu", "caption": ":norm on a Range", "duration": 2.0 },
    { "wait": 0.5 },
    { "comment": "--- Intro ---" },
    { "say": "Give norm a range to limit which lines it affects." },
    { "wait": 0.3 },
    { "comment": "--- Demo: delete specific lines ---" },
    { "say": "Lines three through five say delete me. Use norm D D on just those lines.", "wait": false },
    { "wait": 0.3 },
    { "type": ":3,5norm dd", "overlay": ":3,5norm dd" },
    { "wait": 0.3 },
    { "keys": "enter" },
    { "wait": 0.8 },
    { "say": "Three lines deleted. The keep lines are untouched. The range limited norm to lines three through five." },
    { "wait": 0.3 },
    { "comment": "--- Wrap up ---" },
    { "say": "Colon range norm. Run normal mode keys on a specific set of lines." },
    { "wait": 1.5 }
  ],
  "teardown": [
    { "comment": "Quit nvim without saving" },
    "escape",
    { "type": ":q!" },
    "enter",
    { "line": "rm -f demo.txt" }
  ]
}
